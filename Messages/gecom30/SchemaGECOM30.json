              },
              "NUMACS": {
                "type": "string",
                "description": "Excise duty number (Alcohol)",
                "maxLength": 4
              },
              "NUMACS1": {
                "type": "string",
                "description": "Excise duty product code",
                "maxLength": 4
              },
              "NUMACS2": {
                "type": "string",
                "description": "Excise duty product code",
                "maxLength": 4
              },
              "NUMACS3": {
                "type": "string",
                "description": "Excise duty product code",
                "maxLength": 4
              },
              "NUMACS4": {
                "type": "string",
                "description": "Excise duty product code",
                "maxLength": 4
              },
              "NUMACS5": {
                "type": "string",
                "description": "Excise duty product code",
                "maxLength": 4
              }
            }
          },
          "GEEX3010": {
            "type": "array",
            "description": "Product components declaration",
            "maxItems": 99,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "CODPRN": {
                  "type": "string",
