                "maxLength": 3
              },
              "NBHIMM": {
                "type": "string",
                "description": "Number of immobilization hours",
                "maxLength": 3
              },
              "IMMLOT": {
                "type": "string",
                "description": "Immobilization reason applicable to a batch",
                "maxLength": 3
              },
              "EMBUVC": {
                "type": "string",
                "description": "CSU packaging code",
                "maxLength": 3
              },
              "CODMTI": {
                "type": "string",
                "description": "Commercial code",
                "maxLength": 3
              },
              "CODOWN": {
                "type": "string",
                "description": "Owner code",
                "maxLength": 14
              },
              "DS3PRO": {
                "type": "string",
                "description": "Product designation line 3",
                "maxLength": 35
              },
              "CODRSQ": {
                "type": "string",
                "description": "Risk typology code",
                "maxLength": 3
              },
              "INDTEM": {
                "type": "string",
