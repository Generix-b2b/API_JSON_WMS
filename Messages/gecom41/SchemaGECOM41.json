          "minimum": 0,
          "maximum": 999999999
        },
        "QTBENT": {
          "description": "Number of packaging returned (Input)",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "PRXEMB": {
          "description": "Indicative unit price of the packaging",
          "type": "string",
          "pattern": "^[0-9]{1,4}\\.[0-9]{2}$",
