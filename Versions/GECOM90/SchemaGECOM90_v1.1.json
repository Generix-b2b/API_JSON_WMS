          "description": "Internal product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "DATFVI": {
          "description": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "SIGUVC": {
          "description": "Sign of total CSUs - see EnumSign",
          "$ref": "#/$defs/Enums/EnumSign"
        },
        "TOTUVC": {
          "description": "Total CSUs in stock (RAQ included)",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "SIGPOI": {
          "description": "Sign of total weight - see EnumSign",
          "$ref": "#/$defs/Enums/EnumSign"
        },
        "TOTPOI": {
          "description": "Total weight in stock in Kg (RAQ included)",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "ENCUVC": {
          "description": "CSUs being stored",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "ENCPOI": {
          "description": "Weight being stored",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "PRPUVC": {
          "description": "CSUs reserved for a preparation",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "PRPPOI": {
          "description": "Weight reserved for a preparation",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "UVCKAI": {
          "description": "CSUs on dock-remaining",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "KAIPOI": {
          "description": "Total weight on dock-remaining",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Weight on dock-remaining",
            "type": "number",
            "minimum": 0,
            "maximum": 99999999.999,
            "multipleOf": 0.001
          }
        },
        "TOPEDI": {
          "description": "EDI movement feedback indicator - see EnumTOPEDI",
          "$ref": "#/$defs/Enums/EnumTOPEDI"
        },
        "IMOCOM": {
          "description": "Immobilization marketability - see EnumIMOCOM",
          "$ref": "#/$defs/Enums/EnumIMOCOM"
        }
      },
      "required": [
        "CODACT",
        "CODPRO"
      ],
      "additionalProperties": false
    },
