{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom80/SchemaGECOM80.json",
  "title": "GECOM80 - Stock Movement",
  "x-wms-icon": "GECOM80",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client]/endpoint",
    "category": "Outbound",
    "version": "v1.1",
    "releaseDate": "2026-06-25"
  },
  "description": "JSON for stock movement feedback from the WMS",
  "type": "object",
  "properties": {
    "stockMovements": {
      "description": "Stock movement header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX8000"
      }
    }
  },
  "required": [
    "stockMovements"
  ],
  "$defs": {
    "GEEX8000": {
      "description": "Stock movement header",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "DATMVT": {
          "description": "Movement date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUMVT": {
          "description": "Movement time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        },
        "DATRGL": {
          "description": "Adjustment date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "CODMDU": {
          "description": "Module code",
          "type": "string",
          "maxLength": 2
        },
        "CODFON": {
          "description": "Function code",
          "type": "string",
          "pattern": "^[0-9]{1,1}$"
        },
        "CODMVT": {
          "description": "Journaling movement code - see EnumCODMVT",
          "$ref": "#/$defs/Enums/EnumCODMVT"
        },
        "SENMVT": {
          "description": "Physical movement direction - see EnumSENMVT",
          "$ref": "#/$defs/Enums/EnumSENMVT"
        },
        "MOTMVT": {
          "description": "Reason for the journaled movement",
          "type": "string",
          "maxLength": 3
        },
        "EDIMVT": {
          "description": "Movement code for EDI",
          "type": "string",
          "maxLength": 3
        },
        "REFMVT": {
          "description": "Movement reference",
          "type": "string",
          "maxLength": 30
        },
        "UVCMVT": {
          "description": "Number of units of the adjustment movement",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "type": "string",
          "maxLength": 14
        },
        "CODPRO": {
          "description": "Product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODPRN": {
          "description": "Product code from a bill of materials",
          "type": "string",
          "maxLength": 17
        },
        "SPCPRO": {
          "description": "Product sub-pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "CODSIT": {
          "description": "Storage site code",
          "type": "string",
          "maxLength": 3
        },
        "ZONSTS": {
          "description": "Warehouse storage area",
          "type": "string",
          "maxLength": 1
        },
        "ALLSTS": {
          "description": "Aisle code in the area",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "DPLSTS": {
          "description": "Location displacement in the aisle",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "NIVSTS": {
          "description": "Location level in the column",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODLOT": {
          "description": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "NUMLOT": {
          "description": "Internal goods batch number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "CODPAL": {
          "description": "Stored pallet code per EAN128 standards",
          "type": "string",
          "maxLength": 18
        },
        "DATFVI": {
          "description": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "NUMDIM": {
          "description": "De-immobilization number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "CODTIE": {
          "description": "Third-party code (Supplier or Customer)",
          "type": "string",
          "maxLength": 14
        },
        "TYPTIE": {
          "description": "Third-party type - see EnumTYPTIE",
          "$ref": "#/$defs/Enums/EnumTYPTIE"
        },
        "NUMCDE": {
          "description": "Order number (Reception or delivery)",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNUCDE": {
          "description": "Order sub-number (Reception/Delivery)",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODUTI": {
          "description": "User code responsible for the movement",
          "type": "string",
          "maxLength": 10
        },
        "UNIPRO": {
          "description": "Product unit of measure",
          "type": "string",
          "maxLength": 3
        },
        "GEEX8001": {
          "description": "Stock movement additional information",
          "$ref": "#/$defs/GEEX8001Wrapper"
        },
        "GEEX8060": {
          "description": "Immobilization / de-immobilization movement",
          "$ref": "#/$defs/GEEX8060Wrapper"
        },
        "GEEX8090": {
          "description": "Positive release complementary movement",
          "$ref": "#/$defs/GEEX8090Wrapper"
        }
      },
      "required": [
        "DATMVT",
        "CODMVT",
        "SENMVT",
        "MOTMVT",
        "CODACT",
        "CODPRO"
      ],
      "additionalProperties": false
    },
    "GEEX8001Wrapper": {
      "description": "Stock movement additional information",
      "type": "object",
      "properties": {
        "ANAPRO": {
          "description": "Product analysis code",
          "type": "string",
          "maxLength": 15
        },
        
        "NLILIV": {
          "description": "Line number for the delivery interface",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODTLI": {
          "description": "Delivery type code",
          "type": "string",
          "maxLength": 3
        },
        "DATFAB": {
          "description": "Manufacturing date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "MOTSAP": {
          "description": "S.A.P. reason",
          "type": "string",
          "maxLength": 4
        },
        "CODSAP": {
          "description": "S.A.P. code (+/-)",
          "type": "string",
          "maxLength": 3
        },
        "STOSAP": {
          "description": "S.A.P. storage location (+/-)",
          "type": "string",
          "maxLength": 4
        },
        "STASAP": {
          "description": "S.A.P. status (+/-)",
          "type": "string",
          "maxLength": 1
        },
        "MESPRO": {
          "description": "Product measurement method - see EnumMESPRO",
          "$ref": "#/$defs/Enums/EnumMESPRO"
        },
        "DIPMVT": {
          "description": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "CODRGT": {
          "description": "Region code for transport",
          "type": "string",
          "maxLength": 3
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "NUMGRP": {
          "description": "Group identification number",
          "type": "string",
          "pattern": "^[0-9]{1,10}$"
        },
        "PDBPAL": {
          "description": "Gross weight of the pallet in Kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "PDBMVT": {
          "description": "Gross weight moved",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "FAMPRO": {
          "description": "Product classification family",
          "type": "string",
          "maxLength": 10
        },
        "INDPRO": {
          "description": "Configurable product indicators",
          "type": "array",
          "maxItems": 10,
          "items": {
            "description": "Configurable product indicators",
            "type": "string",
            "maxLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "GEEX8060Wrapper": {
      "description": "Immobilization / de-immobilization movement",
      "type": "object",
      "properties": {
        "MOTIMM": {
          "description": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "DATIMM1": {
          "description": "Immobilization start date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "DATIMM2": {
          "description": "Immobilization end date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "SITPAL": {
          "description": "Origin site of the updated pallet",
          "type": "string",
          "maxLength": 3
        },
        "HEUIMM1": {
          "description": "Immobilization start time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        },
        "HEUIMM2": {
          "description": "Immobilization end time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        },
        "CODSAP": {
          "description": "S.A.P. code (+/-)",
          "type": "string",
          "maxLength": 3
        },
        "STOSAP": {
          "description": "S.A.P. storage location (+/-)",
          "type": "string",
          "maxLength": 4
        },
        "STASAP": {
          "description": "S.A.P. status (+/-)",
          "type": "string",
          "maxLength": 1
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "IMMPAL": {
          "description": "Pallet immobilization management / false = No, true = Yes",
          "type": "boolean",
          "default": false
        },
        "CODRIM": {
          "description": "Immobilization reasons code",
          "type": "string",
          "maxLength": 3
        }
      },
      "additionalProperties": false
    },
    "GEEX8090Wrapper": {
      "description": "Positive release complementary movement",
      "type": "object",
      "properties": {
        "NUMPAL": {
          "description": "Stored pallet number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "SNUPAL": {
          "description": "Stored pallet sub-number",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "ETAPAL": {
          "description": "Stored pallets status code - see EnumETAPAL",
          "$ref": "#/$defs/Enums/EnumETAPAL"
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Immobilization reason",
            "type": "string",
            "maxLength": 3
          }
        },
        "DATLIB": {
          "description": "Support code release date",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Support code release date (format YYYYMMDD)",
            "type": "string",
            "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": [
              "20250125"
            ]
          }
        },
        "HEULIB": {
          "description": "Support code release time",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Support code release time (format HHMMSS)",
            "type": "string",
            "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
            "examples": [
              "143023"
            ]
          }
        },
        "INDLIB": {
          "description": "Positive release indicator / false = Pallet to release, true = Pallet already released",
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "boolean"
          }
        },
        "DATSTO": {
          "description": "Storage start and end dates (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUSTO": {
          "description": "Storage start and end times (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        },
        "IMMBKL": {
          "description": "Immobilization reason from a Black List",
          "type": "string",
          "maxLength": 3
        },
        "PALIMM": {
          "description": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "DATBKL": {
          "description": "Black List creation date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUBKL": {
          "description": "Black List creation time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        },
        "DATIMM": {
          "description": "Immobilization end date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUIMM": {
          "description": "Immobilization end time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "143023"
          ]
        }
      },
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / (blank) = Empty, 2 = Modification",
        "type": "string",
        "enum": [
          "",
          "2"
        ]
      },
      "EnumCODMVT": {
        "description": "Journaling movement code / 00 = Administrative movement, 10 = Storage, 20 = Destocking, 30 = Transfer, 40 = Quantity adjustment, 80 = Immobilization",
        "type": "string",
        "enum": [
          "00",
          "10",
          "20",
          "30",
          "40",
          "80"
        ]
      },
      "EnumSENMVT": {
        "description": "Physical movement direction / + = Storage or De-immobilization, - = Destocking or Immobilization",
        "type": "string",
        "enum": [
          "+",
          "-"
        ]
      },
      "EnumTYPTIE": {
        "description": "Third-party type / 0 = Third-party code not filled, 1 = Supplier, 2 = Customer",
        "type": "string",
        "enum": [
          "0",
          "1",
          "2"
        ]
      },
      "EnumMESPRO": {
        "description": "Product measurement method / 1 = Unit measurement, 2 = Variable measurement, 3 = Regulated measurement",
        "type": "string",
        "enum": [
          "1",
          "2",
          "3"
        ],
        "default": "1"
      },
      "EnumETAPAL": {
        "description": "Stored pallets status code / 10 = Pallet already at picking, 20 = Pallet to bring down to picking, 30 = Complete pallet to destock, 40 = Stored pallet, 50 = Pallet being stored, 60 = Pallet being shipped, 70 = Pallet reserved for copacking, 90 = Heterogeneous pallet restocked",
        "type": "string",
        "enum": [
          "10",
          "20",
          "30",
          "40",
          "50",
          "60",
          "70",
          "90"
        ]
      }
    }
  }
}