{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/blob/main/SchemaGECOM50.json",
  "title": "GECOM50 - Delivery Orders",
  "type": "object",
  "description": "JSON schema generated by GENERIX GROUP SP",
  "properties": {
    "deliveryOrders": {
      "type": "array",
      "description": "Delivery Orders Header",
      "minItems": 1,
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Creation, 2 = Modify or Create, 7 = Header Modification, 8 = Attribute Modification, 9 = Cancellation",
            "enum": ["1", "2", "7", "8", "9"],
            "default": "2"
          },
          "NUMLIV": {
            "type": "string",
            "description": "Order number to be delivered",
            "pattern": "^[0-9]{1,8}$"
          },
          "SNULIV": {
            "type": "string",
            "description": "Sub-number of the order to be delivered",
            "pattern": "^[0-9]{1,3}$"
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "CODCLI": {
            "type": "string",
            "description": "Customer code of the stock owner",
            "minLength": 1,
            "maxLength": 14
          },
          "REFLIV": {
            "type": "string",
            "description": "Delivery reference",
            "minLength": 1,
            "maxLength": 30
          },
          "CODTLI": {
            "type": "string",
            "description": "Delivery type code",
            "minLength": 3,
            "maxLength": 3
          },
          "DTILIV": {
            "type": "string",
            "description": "Initially scheduled delivery date",
            "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
          },
          "HEILIV": {
            "type": "string",
            "description": "Originally scheduled delivery time",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$"
          },
          "CLILIV": {
            "type": "string",
            "description": "Customer code to deliver",
            "maxLength": 14
          },
          "TYPLIV": {
            "type": "string",
            "description": "Delivery type (notion of collected/delivered) / 1 = Delivered, 2 = Collected",
            "enum": ["1", "2"],
            "default": "1"
          },
          "CODMOP": {
            "type": "string",
            "description": "Preparation mode code for a customer",
            "maxLength": 3
          },
          "CODTRA": {
            "type": "string",
            "description": "Carrier code",
            "maxLength": 14
          },
          "CODRGT": {
            "type": "string",
            "description": "Area code for transport",
            "maxLength": 3
          },
          "TOULIV": {
            "type": "string",
            "description": "Goods delivery round",
            "pattern": "^[0-9]{1,4}$"
          },
          "ORDLIV": {
            "type": "string",
            "description": "Delivery order in the tour",
            "pattern": "^[0-9]{1,4}$"
          },
          "KAILIV": {
            "type": "string",
            "description": "Cargo shipping dock",
            "pattern": "^[0-9]{1,3}$"
          },
          "MSGPRP": {
            "type": "array",
            "description": "Message to edit on the packing slip",
            "minItems": 0,
            "maxItems": 2,
            "items": {
              "type": "string",
              "maxLength": 30
            }
          },
          "MSGLIV": {
            "type": "array",
            "description": "Message to edit on the delivery note",
            "minItems": 0,
            "maxItems": 2,
            "items": {
              "type": "string",
              "maxLength": 30
            }
          },
          "GSTALC": {
            "type": "string",
            "description": "Alcohol management mode / 0 = No alcohol management, 1 = Delivery with Release (DSAC), 2 = Delivery under Acquit (DAC), 3 = Duty free, tax free",
            "enum": ["0", "1", "2", "3"],
            "default": "0"
          },
          "CODSIT": {
            "type": "string",
            "description": "Storage site code",
            "maxLength": 3
          },
          "IGLSIT": {
            "type": "string",
            "description": "GE site identifier for Infolog GL",
            "pattern": "^[0-9]{1,3}$"
          },
          "CODBAS": {
            "type": "string",
            "description": "Database code",
            "maxLength": 3
          },
          "TYPCDE": {
            "type": "boolean",
            "description": "Order type (provisional or firm) / false = Firm order, true = Provisional order",
            "default": false
          },
          "CUMLIG": {
            "type": "string",
            "description": "Total number of lines in the order",
            "pattern": "^[0-9]{1,4}$"
          },
          "CUMPOI": {
            "type": "string",
            "description": "Cumulated gross weight of the order in Kg",
            "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
          },
          "CUMVOL": {
            "type": "string",
            "description": "Cumulated order volumes in Dm3",
            "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
          },
          "CUMCOL": {
            "type": "string",
            "description": "Total number of packages",
            "pattern": "^[0-9]{1,7}$"
          },
          "GEEX5001": {
            "type": "object",
            "description": "Delivery Order Additional 01 Header Information",
            "additionalProperties": false,
            "properties": {
              "TOPLIV": {
                "type": "array",
                "description": "Indicators for specific users",
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "maxLength": 1
                }
              },
              "DIPLIV": {
                "type": "string",
                "description": "Data transit area between software",
                "maxLength": 50
              },
              "DATEXP": {
                "type": "string",
                "description": "Goods dispatch date",
                "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
              },
              "HEUEXP": {
                "type": "string",
                "description": "Goods dispatch time",
                "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$"
              },
              "MNTCRB": {
                "type": "string",
                "description": "Cash on delivery amount",
                "pattern": "^[0-9]{1,11}\\.[0-9]{3}$"
              },
              "REFCLI": {
                "type": "string",
                "description": "Recipient's order reference",
                "maxLength": 30
              },
              "CRILIV": {
                "type": "string",
                "description": "Order extraction criteria",
                "maxLength": 20
              },
              "PTYCLI": {
                "type": "string",
                "description": "Store service priority",
                "maxLength": 3
              },
              "CODLDP": {
                "type": "string",
                "description": "Preparation location code",
                "maxLength": 3
              },
              "EDICLF": {
                "type": "string",
                "description": "Final customer code for EDI",
                "maxLength": 14
              },
              "EDICLI": {
                "type": "string",
                "description": "Customer code for EDI",
                "maxLength": 14
              },
              "EDITRA": {
                "type": "string",
                "description": "Carrier code for EDI",
                "maxLength": 14
              },
              "DATCHT": {
                "type": "string",
                "description": "Goods loading date",
                "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
              },
              "HEUCHT": {
                "type": "string",
                "description": "Goods loading time",
                "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$"
              }
            }
          },
          "GEEX5002": {
            "type": "object",
            "description": "Delivery Order Additional 02 Header Information",
            "additionalProperties": false,
            "properties": {
              "NUMTOU": {
                "type": "string",
                "description": "Return record number",
                "pattern": "^[0-9]{1,8}$"
              },
              "DATPTD": {
                "type": "string",
                "description": "Last preparation date",
                "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
              },
              "HEUPTD": {
                "type": "string",
                "description": "Last preparation time",
                "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
              },
              "CODAFI": {
                "type": "string",
                "description": "Affiliation code",
                "maxLength": 10
              },
              "CODDDO": {
                "type": "string",
                "description": "Originator code",
                "maxLength": 14
              },
              "SITPAL": {
                "type": "string",
                "description": "Updated pallet origin site",
                "maxLength": 3
              },
              "CLIVIA": {
                "type": "string",
                "description": "Intermediate delivery point / Relay point",
                "maxLength": 14
              },
              "DATEXC": {
                "type": "string",
                "description": "Negotiation date",
                "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
              },
              "HEUEXC": {
                "type": "string",
                "description": "Exchange time",
                "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
              },
              "CODCLV": {
                "type": "string",
                "description": "Delivery requirement code",
                "maxLength": 3
              },
              "CODOWN": {
                "type": "string",
                "description": "Holder code",
                "maxLength": 14
              },
              "CODOFT": {
                "type": "string",
                "description": "Operator offer code",
                "maxLength": 14
              },
              "SITRCT": {
                "type": "string",
                "description": "Reception site code (recipient's warehouse)",
                "maxLength": 3
              },
              "TOPVIA": {
                "type": "string",
                "description": "Supplier type indicator",
                "maxLength": 1
              },
              "CODGLN": {
                "type": "string",
                "description": "Global logistics number",
                "maxLength": 14
              },
              "REFEXT": {
                "type": "string",
                "description": "External reference",
                "maxLength": 30
              },
              "HLIMIN": {
                "type": "string",
                "description": "Minimum delivery time",
                "pattern": "^[0-9]{1,4}$"
              },
              "HLIMAX": {
                "type": "string",
                "description": "Maximum delivery time",
                "pattern": "^[0-9]{1,4}$"
              },
              "CODACL": {
                "type": "string",
                "description": "Code to cancel an order to be delivered",
                "maxLength": 3
              },
              "CODTTO": {
                "type": "string",
                "description": "Route type code",
                "maxLength": 3
              },
              "DATLIV": {
                "type": "string",
                "description": "Order delivery date",
                "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
              }
            }
          },
          "GEEX5005": {
            "type": "array",
            "description": "Delivery Orders attributes header",
            "minItems": 0,
            "maxItems": 99,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "CODRUB": {
                  "type": "string",
                  "description": "Section code array",
                  "maxLength": 4
                },
                "VALRUB": {
                  "type": "string",
                  "description": "Traceability element value array",
                  "maxLength": 35
                }
              },
              "required": ["CODRUB", "VALRUB"]
            }
          },
          "GEEX5010": {
            "type": "object",
            "description": "Customer VPC Address Information",
            "additionalProperties": false,
            "properties": {
              "NOMCLI": {
                "type": "string",
                "description": "Customer name",
                "minLength": 1,
                "maxLength": 30
              },
              "AD1CLI": {
                "type": "string",
                "description": "Customer address line 1",
                "minLength": 1,
                "maxLength": 38
              },
              "AD2CLI": {
                "type": "string",
                "description": "Customer address line 2",
                "maxLength": 38
              },
              "AD3CLI": {
                "type": "string",
                "description": "Customer address line 3",
                "maxLength": 38
              },
              "CPOCLI": {
                "type": "string",
                "description": "Customer postal code",
                "pattern": "^[0-9]{1,5}$"
              },
              "VILCLI": {
                "type": "string",
                "description": "Customer city",
                "minLength": 1,
                "maxLength": 26
              },
              "TELCLI": {
                "type": "string",
                "description": "Customer phone number",
                "maxLength": 20
              },
