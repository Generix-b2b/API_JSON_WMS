{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/blob/main/SchemaGECOM08.json",
  "title": "GECOM08 - Initial Table Load",
  "type": "object",
  "description": "JSON schema generated by GENERIX GROUP SP",
  "properties": {
    "InitialTableLoad": {
      "type": "array",
      "description": "Initial Table declaration",
      "minItems": 1,
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Código de procesamiento de movimiento / 1 = Alta, 2 = Modificación o Alta, 7 = Modificación Cabecera, 9 = Anulación",
            "enum": ["1", "2", "7", "9"],
            "default": "2"
          },
          "FAMPAR": {
            "type": "string",
            "description": "Familia de parámetros",
            "minLength": 3,
            "maxLength": 3
          },
          "CLEPAR": {
            "type": "string",
            "description": "Clave de parámetro",
            "minLength": 1,
            "maxLength": 10
          },
          "LIBPAR": {
            "type": "string",
            "description": "Etiqueta de parámetro",
            "minLength": 1,
            "maxLength": 48
          },
          "LIBPAR2": {
            "type": "string",
            "description": "Etiqueta de parámetro 2",
            "maxLength": 48
          },
          "CLEPAR2": {
            "type": "string",
            "description": "Clave de parámetro 2",
            "maxLength": 10
          }
        },
        "required": ["TRTEXC", "FAMPAR", "CLEPAR", "LIBPAR"]
      }
    }
  },
  "required": ["InitialTableLoad"]
}
