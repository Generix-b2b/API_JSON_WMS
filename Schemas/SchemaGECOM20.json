                "type": "string",
                "description": "Email address",
                "minLength": 1,
                "maxLength":50,
                "format": "email"
              }
            }
          },
          "GEEX2003": {
            "type": "object",
            "description": "Customer Additional 03 declaration",
            "additionalProperties": false,
            "properties": {
              "CODRST": {
                "type": "string",
                "description": "In-transit inventory rule code",
                "maxLength": 3
              },
              "LIBCPL": {
                "type": "string",
                "description": "Additional name",
                "maxLength": 38
              },
              "LIBCP2": {
                "type": "string",
                "description": "Additional name 2",
                "maxLength": 38
              },
              "EXLGRP": {
                "type": "boolean",
                "description": "Out of group / false = no, true = Yes",
                "default": false
              },
              "TYPDSV": {
                "type": "string",
                "description": "DESADV type",
                "maxLength": 1
              },
              "PTYSND": {
                "type": "string",
                "description": "Shipping priority",
                "maxLength": 1
              },
              "IDEEXT": {
                "type": "string",
                "description": "External identifier",
                "maxLength": 35
              },
              "ARDPEN": {
                "type": "string",
                "description": "Shortage rounding indicator",
                "maxLength": 1
              }
            }
          },
          "GEEX2050": {
            "type": "array",
            "description": "Customer rubriques declaration",
            "maxItems": 500,
            "items":
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "TYPRUB": {
                    "type": "string",
                    "description": "Heading type / 1 = EDIFACT Standard, 2 = Internal Coding",
                    "enum": ["1", "2"],
                    "default": "2"
                  },
                  "CODRUB": {
                    "type": "string",
                    "description": "Section code",
                    "maxLength":4
                  },
                  "VALRUB": {
                    "type": "string",
                    "description": "Item value",
                    "maxLength": 35
                  }
                },
                "required": ["TYPRUB", "CODRUB", "VALRUB"]
              }
          }
        },
        "required": ["TRTEXC", "CODACT", "CODCLI", "NOMCLI", "AD1CLI", "VILCLI", "PAYCLI"]
      }
