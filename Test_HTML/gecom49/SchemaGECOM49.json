                      "type": "string",
                      "description": "Reception reference",
                      "minLength": 1,
                      "maxLength": 30
                    },
                    "NLIREC": {
                      "type": "string",
                      "description": "Line number for reception interface",
                      "pattern": "^[0-9]{1,5}$"
                    },
                    "TYPREF": {
                      "type": "string",
