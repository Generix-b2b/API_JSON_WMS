{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom90/SchemaGECOM90.json",
  "title": "GECOM90 - Stock Photo",
  "x-wms-icon": "GECOM90",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client]/endpoint",
    "category": "Outbound",
    "version": "v1.1-Beta",
    "releaseDate": "2026-06-25"
  },
  "description": "JSON for stock snapshot (stock photo) feedback from the WMS",
  "type": "object",
  "properties": {
    "stockPhoto": {
      "description": "Stock Photo",
      "type": "object",
      "properties": {
        "stockByProductLot": {
          "description": "Stock feedback by product and lot",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9000"
          }
        },
        "stockByProductExpiryImmobilization": {
          "description": "Stock feedback by CODPRO / DATFVI / MOTIMM",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9008"
          }
        },
        "stockByProductImmobilization": {
          "description": "Stock feedback by CODPRO / MOTIMM",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9009"
          }
        },
        "stockByProductLocation": {
          "description": "Stock feedback by CODPRO / location",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9020"
          }
        },
        "stockBySerialNumber": {
          "description": "Serial number feedback",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9040"
          }
        },
        "stockBySSCC": {
          "description": "Stock feedback at SSCC level",
          "type": "array",
          "maxItems": 9999,
          "items": {
            "$ref": "#/$defs/GEEX9070"
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "stockByProductLot"
          ]
        },
        {
          "required": [
            "stockByProductExpiryImmobilization"
          ]
        },
        {
          "required": [
            "stockByProductImmobilization"
          ]
        },
        {
          "required": [
            "stockByProductLocation"
          ]
        },
        {
          "required": [
            "stockBySerialNumber"
          ]
        },
        {
          "required": [
            "stockBySSCC"
          ]
        }
      ]
    }
  },
  "required": [
    "stockPhoto"
  ],
  "$defs": {
    "GEEX9000": {
      "description": "Stock feedback by product and lot",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXCEmpty",
          "$ref": "#/$defs/Enums/EnumTRTEXCEmpty"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "type": "string",
          "maxLength": 14
        },
        "CODPRO": {
          "description": "Product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODLOT": {
          "description": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "NUMLOT": {
          "description": "Internal goods batch number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "TOTUVC": {
          "description": "Total CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "TOTCOL": {
          "description": "Total packages",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "TOTPAL": {
          "description": "Total pallets",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "ENCUVC": {
          "description": "CSUs being stored",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "ENCCOL": {
          "description": "Packages being stored",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "ENCPAL": {
          "description": "Pallets being stored",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "PRPUVC": {
          "description": "CSUs reserved for a preparation",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "PRPCOL": {
          "description": "Packages reserved for a preparation",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "PRPPAL": {
          "description": "Pallets reserved for a preparation",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "IMOUVC": {
          "description": "Immobilized CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "IMOCOL": {
          "description": "Immobilized packages",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "IMOPAL": {
          "description": "Immobilized pallets",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "COMUVC": {
          "description": "Of which: marketable immobilized CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "COMCOL": {
          "description": "Marketable immobilized packages",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "COMPAL": {
          "description": "Marketable immobilized pallets",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "MINREC": {
          "description": "Oldest reception date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "MAXREC": {
          "description": "Most recent reception date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "MINFVI": {
          "description": "Oldest expiry date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "MAXFVI": {
          "description": "Most recent expiry date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "TOTPOI": {
          "description": "Total CSU weight (variable weight)",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "EXSPIC": {
          "description": "Picking existence - see EnumEXSPIC",
          "$ref": "#/$defs/Enums/EnumEXSPIC"
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "INDSTK": {
          "description": "Stock update processing indicator (RC) - see EnumINDSTK",
          "$ref": "#/$defs/Enums/EnumINDSTK"
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        }
      },
      "required": [
        "CODACT",
        "CODPRO"
      ],
      "additionalProperties": false
    },
    "GEEX9008": {
      "description": "Stock feedback by Product / DATFVI / MOTIMM",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "type": "string",
          "maxLength": 14
        },
