{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Schemas/SchemaGECOM49.json",
  "title": "GECOM49 - Dispatch Advice",
  "x-wms-icon": "GECOM49",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m49_dispatchAdvice",
    "category": "Inbound",
    "version": "v1.0",
    "releaseDate": "2026-06-17"
  },
  "type": "object",
  "description": "JSON for creating a Dispatch Advice",
  "properties": {
    "dispatchAdvices": {
      "type": "array",
      "description": "Dispatch Advice Header",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"description": "Datos del documento de factura.",
				"$ref": "#/definitions/GEEX4900"
			}
    }
  },
  "required": [
		"dispatchAdvices"
	],
	"definitions": {
    "GEEX4900": {
      "description": "Dispatch Advice Header",
			"type": "object",
			"properties": {
        "TRTEXC": {
          "description": "Movement processing code / 1 = Create, 2 = Modification, 9 = Cancellation",
          "$ref": "#/definitions/Enums/TRTEXCEnum"
        },
        "CODFOU": {
          "type": "string",
          "description": "Supplier code",
          "minLength": 1,
          "maxLength": 14
        },
        "AVIREF": {
          "type": "string",
          "description": "Dispatch advice reference",
          "minLength": 1,
          "maxLength": 35
        },
        "CODACT": {
          "type": "string",
          "description": "Logistics activity code",
          "minLength": 3,
          "maxLength": 3
        },
        "REFLET": {
          "type": "string",
          "description": "Waybill number",
          "maxLength": 10
        },
        "EDIFOU": {
          "type": "string",
          "description": "Supplier code for EDI",
          "maxLength": 14
        },
        "EDIACT": {
          "type": "string",
          "description": "Warehouse code for EDI",
          "maxLength": 14
        },
        "EDITRA": {
          "type": "string",
          "description": "Carrier code for EDI",
          "maxLength": 14
        },
        "CODTRA": {
          "type": "string",
          "description": "Carrier code",
          "maxLength": 14
        },
        "DATEXP": {
          "type": "string",
          "description": "Goods dispatch date / format YYYYMMDD",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXP": {
          "type": "string",
          "description": "Goods dispatch time / format HHMMSS",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "DATLIV": {
          "type": "string",
          "description": "Order delivery date / format YYYYMMDD",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEULIV": {
          "type": "string",
          "description": "Order delivery time / format HHMMSS",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "TYPTPT": {
          "type": "string",
          "description": "Transport type",
          "maxLength": 3
        },
        "TYPCHT": {
          "type": "string",
          "description": "Loading type",
          "maxLength": 3
        },
        "REFPLB": {
          "type": "string",
          "description": "Seal number",
          "maxLength": 10
        },
        "CAMCOD": {
          "type": "string",
          "description": "Truck number",
          "maxLength": 20
        },
        "DIPAVI": {
          "type": "string",
          "description": "Data transit area between software",
          "maxLength": 50
        },
        "SITRCT": {
          "type": "string",
          "description": "Reception site code (recipient's warehouse)",
          "maxLength": 3
        },
        "CRERCP": {
          "type": "boolean",
          "description": "Reception creation / false = No, true = Yes",
          "default": false
        },
        "NUMTOU": {
          "type": "string",
          "description": "Tour record number",
          "pattern": "^[0-9]{1,8}$"
        },
        "INDSBY": {
          "description": "Indicator for putting DESADV on hold / 0 = No hold, 1 = On hold, 2 = On hold and last",
          "$ref": "#/definitions/Enums/INDSBYEnum"
        },
        "CODTRE": {
          "type": "string",
          "description": "Reception type code",
          "maxLength": 3
        },
        "TYPRMT": {
          "description": "Feedback type / C = Package put in stock / R = Reception put in stock / U = Unloading",
          "$ref": "#/definitions/Enums/TYPRMTEnum"
        },
        "CUMLIG": {
          "type": "string",
          "description": "Total number of lines in the order",
          "pattern": "^[0-9]{1,4}$"
        },
        "GEEX4905": {
          "type": "array",
          "description": "Dispatch advice associated attributes",
          "maxItems": 99,
          "items": {
            "$ref": "#/definitions/GEEX4905Wrapper"
          }
        },
        "GEEX4910": {
          "type": "array",
          "description": "Logistics object header",
          "minItems": 1,
          "maxItems": 99,
          "items": {
            "$ref": "#/definitions/GEEX4910Wrapper"
          }
        }
      },
      "required": ["TRTEXC","CODFOU","AVIREF","CODACT","DATEXP","CUMLIG"],
      "if": {
        "properties": {
          "TRTEXC": { "enum": ["1", "2"] }
        },
        "required": ["TRTEXC"]
      },
      "then": {
        "required": ["GEEX4910"]
      }
    },
    "GEEX4905Wrapper": {
      "type": "object",
      "properties": {
        "CODRUB": {
          "type": "string",
          "description": "Section code",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "type": "string",
          "description": "Traceability element value",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["CODRUB","VALRUB"],
      "additionalProperties": false
      
    },
    "GEEX4910Wrapper": {
      "type": "object",
      "properties": {
        "CODOBL": {
          "type": "string",
          "description": "Logistics object code",
          "minLength": 1,
          "maxLength": 35
        },
        "AVINLI": {
          "type": "string",
          "description": "Dispatch advice line number",
          "pattern": "^[0-9]{1,12}$"
        },
        "CUMCOL": {
          "type": "string",
          "description": "Total number of packages",
          "pattern": "^[0-9]{1,7}$"
        },
        "TYPMQG": {
          "type": "string",
          "description": "Marking type",
          "maxLength": 3
        },
        "CODEB1": {
          "type": "string",
          "description": "Handling packaging code",
          "maxLength": 3
        },
        "CODEB2": {
          "type": "string",
          "description": "Packaging code associated with packing",
          "maxLength": 3
        },
        "PDBOBL": {
          "type": "number",
          "description": "Weight of the logistics object",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "UNIPDB": {
          "type": "string",
          "description": "Weight measurement unit",
          "maxLength": 3
        },
        "LNGOBL": {
          "type": "string",
          "description": "Length of the logistics object",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]
        },
        "LRGOBL": {
          "type": "string",
          "description": "Width of the logistics object",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]
        },
        "HAUOBL": {
          "type": "string",
          "description": "Height of the logistics object",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]
        },
        "UNIDIM": {
          "type": "string",
          "description": "Dimensions measurement unit",
          "maxLength": 3
        },
        "DATCRE": {
          "type": "string",
          "description": "Creation date / format YYYYMMDD",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUCRE": {
          "type": "string",
          "description": "Creation time / format HHMMSS",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "PROEMB": {
          "type": "array",
          "description": "Packaging product code for interfacing",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "string",
            "description": "Packaging product code for interfacing",
            "maxLength": 17
          }
        },
        "CODTOB": {
          "type": "string",
          "description": "Object processing code",
          "maxLength": 3
        },
        "DATSUP": {
          "type": "array",
          "description": "Support validation start and end dates",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "description": "Support validation start and end dates / format YYYYMMDD",
            "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          }
        },
        "HEUSUP": {
          "type": "array",
          "description": "Support validation start and end times",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "description": "Support validation start and end times / format HHMMSS",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
            "examples": ["143023"]
          }
        },
        "COEUOT": {
          "type": "string",
          "description": "UOT calculation coefficient",
          "pattern": "^[0-9]{1,2}\\.[0-9]{2}$",
          "examples": ["1.00"]
        },
        "TRAFUT": {
          "type": "string",
          "description": "Future carrier",
          "maxLength": 14
        },
        "MSGOBJ": {
          "type": "string",
          "description": "Message related to the object",
          "maxLength": 30
        },
        "GEEX4920": {
          "description": "Logistics object details",
          "$ref": "#/definitions/GEEX4920Wrapper"
        },
        "GEEX4921": {
          "description": "Logistics object details",
          "$ref": "#/definitions/GEEX4921Wrapper"
        },
        "GEEX4922": {
          "description": "Logistics object details",
          "$ref": "#/definitions/GEEX4922Wrapper"
        },
        "GEEX4923": {
          "description": "Logistics object details",
          "$ref": "#/definitions/GEEX4923Wrapper"
        },
        "GEEX4925": {
          "type": "array",
          "description": "Rubriques Declaration Line",
          "maxItems": 99,
          "items": {
            "$ref": "#/definitions/GEEX4925Wrapper"
          }
        }
      },
      "required": ["CODOBL", "AVINLI", "GEEX4920"],
      "additionalProperties": false
    },
    "GEEX4920Wrapper": {
      "type": "object",
      "properties": {
        "NLIOBL": {
          "type": "string",
          "description": "Line number of the higher logistics object",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODOBI": {
          "type": "string",
          "description": "Lower object code",
          "maxLength": 35
        },
        "EDIPRO": {
          "type": "string",
          "description": "Product code for EDI",
          "maxLength": 17
        },
        "CODPRO": {
          "type": "string",
          "description": "Internal product code",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "type": "string",
          "description": "Logistics variant (Gencod)",
          "pattern": "^[0-9]{1,2}$"
        },
        "EDICLI": {
          "type": "string",
          "description": "EDI code of the delivering customer (CLILIV)",
          "maxLength": 14
        },
        "CODCLI": {
          "type": "string",
          "description": "Internal code of the delivering customer (CLILIV)",
          "maxLength": 14
        },
        "CODPAY": {
          "type": "string",
          "description": "Symbolic country code",
          "maxLength": 3
        },
        "NATSTK": {
          "type": "string",
          "description": "Stock nature",
          "maxLength": 3
        },
        "CODLOT": {
          "type": "string",
          "description": "Stored batch code",
          "maxLength": 20
        },
        "PDNLIV": {
          "type": "number",
          "description": "Net weight delivered",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "PCBPRO": {
          "type": "integer",
          "description": "Product quantity",
          "minimum": 0,
          "maximum": 99999
        }
      },
      "required": ["NLIOBL", "CODPRO"],
      "additionalProperties": false
    },
    "GEEX4921Wrapper": {
      "type": "object",
      "properties": {
        "DATFAB": {
          "type": "string",
          "description": "Manufacturing date / format YYYYMMDD",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "UVCOBI": {
          "type": "integer",
          "description": "Number of CSUs of the lower logistics object",
          "minimum": 0,
          "maximum": 999999999
        },
        "UNIUVC": {
          "type": "string",
          "description": "Consumer Sales Unit measurement unit",
          "maxLength": 3
        },
        "NUOOBI": {
          "type": "string",
          "description": "Object quantity in OU",
          "pattern": "^[0-9]{1,9}$"
        },
        "UNIUOA": {
          "type": "string",
          "description": "Object unit",
          "maxLength": 3
        },
        "MOTIMM": {
          "type": "string",
          "description": "Immobilization reason",
          "maxLength": 3
        },
        "EDICLF": {
          "type": "string",
          "description": "Final customer code for EDI",
          "maxLength": 14
        },
        "CLILIV": {
          "type": "string",
          "description": "Internal code of the final customer (CODCLI)",
          "maxLength": 14
        },
        "REFREC": {
          "type": "string",
          "description": "Reception reference",
          "minLength": 1,
          "maxLength": 30
        },
        "NLIREC": {
          "type": "string",
          "description": "Line number for reception interface",
          "pattern": "^[0-9]{1,5}$"
        },
        "TYPREF": {
          "description": "DAE reference type / 0 = Gamm@ reference, 1 = GPS reference, 2 = GPS reference return, 3 = DAE draft",
					"$ref": "#/definitions/Enums/TYPREFEnum"
        }
      },
      "required": ["REFREC", "NLIREC"],
      "additionalProperties": false
    },
    "GEEX4922Wrapper": {
      "type": "object",
      "properties": {
        "EANUVC": {
          "type": "string",
          "description": "EAN code associated with the CSU",
          "maxLength": 14
        },
        "PRXAVI": {
          "type": "string",
          "description": "Price of the delivered product",
          "pattern": "^[0-9]{1,6}\\.[0-9]{3}$",
          "examples": ["120.050"]
        },
        "PDNAVI": {
          "type": "number",
          "description": "Net weight of the product in the advice",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "REFLIV": {
          "type": "string",
          "description": "Delivery reference",
          "minLength": 1,
          "maxLength": 30
        },
        "NLILIV": {
          "type": "string",
          "description": "Line number for delivery interface",
          "pattern": "^[0-9]{1,5}$"
        },
        "DS1PRO": {
          "type": "string",
          "description": "Product designation line 1",
          "maxLength": 30
        },
        "DS2PRO": {
          "type": "string",
          "description": "Product designation line 2",
          "maxLength": 30
        },
        "TOPLIV": {
          "type": "array",
          "description": "Indicators for specific users",
          "maxItems": 5,
          "items": {
            "type": "string",
            "description": "Indicators for specific users",
            "maxLength": 1
          }
        },
        "PDBLIV": {
          "type": "number",
          "description": "Gross weight delivered",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "VOLCOL": {
          "type": "string",
          "description": "Package volume expressed in dm3",
          "pattern": "^[0-9]{1,4}\\.[0-9]{3}$",
          "examples": ["0.780"]
        },
        "CODTLI": {
          "type": "string",
          "description": "Delivery type code",
          "maxLength": 3
        }
      },
      "required": ["REFLIV", "NLILIV"],
      "additionalProperties": false
    },
    "GEEX4923Wrapper": {
      "type": "object",
      "properties": {
        "CODOPE": {
          "type": "string",
          "description": "Operation code (Promo or reservation)",
          "maxLength": 14
        },
        "NUMOPE": {
          "type": "string",
          "description": "Operation number (Promo or reservation)",
          "pattern": "^[0-9]{1,6}$"
        },
        "TYPOPE": {
          "description": "Operation type (e.g.: Promotion, reservation) / 0 = Normal, 1 = Promotion, 2 = Reservation, 3 = Operation code, 4 = Promo Circuit",
					"$ref": "#/definitions/Enums/TYPOPEEnum"
        },
        "HEUFAB": {
          "type": "string",
          "description": "Manufacturing time / format HHMMSS",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "DATIMM": {
          "type": "array",
          "description": "Immobilization start and end dates",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "description": "Immobilization start and end dates / format YYYYMMDD",
            "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          }
        },
        "HEUIMM": {
          "type": "array",
          "description": "Immobilization start and end times",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "description": "Immobilization start and end times / format HHMMSS",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
            "examples": ["143023"]
          }
        },
        "FOUINI": {
          "type": "string",
          "description": "Original supplier code",
          "maxLength": 14
        }
      },
      "additionalProperties": false
    },
    "GEEX4925Wrapper": {
      "type": "object",
      "properties": {
        "TYPRUB": {
          "description": "Section type / 1 = EDIFACT standard / 2 = Internal coding",
					"$ref": "#/definitions/Enums/TYPRUBEnum"
        },
        "CODRUB": {
          "type": "string",
          "description": "Section code",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "type": "string",
          "description": "Section value",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["TYPRUB","CODRUB","VALRUB"],
      "additionalProperties": false
    },
    "Enums": {
      "TRTEXCEnum": {
        "type": "string",
        "enum": ["1","2","9"],
        "default": "2"
      },
      "INDSBYEnum": {
          "type": "string",
          "enum": ["0","1","2"],
          "default": "0"
      },
      "TYPRMTEnum": {
        "type": "string",
        "enum": ["C","R","U"]
      },
      "TYPREFEnum": {
        "type": "string",
        "enum": ["0","1","2","3"]
      },
      "TYPOPEEnum": {
        "type": "string",
        "enum": ["0","1","2","3","4"],
        "default": "0"
      },
      "TYPRUBEnum": {
        "type": "string",
        "enum": ["1","2"],
        "default": "2"
      }
    }   
  }
}
