{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom20/SchemaGECOM20.json",
  "title": "GECOM20 - Customer Master Data",
  "title_es": "GECOM20 - Datos maestros de clientes",
  "title_en": "GECOM20 - Customer Master Data",
  "x-wms-icon": "GECOM20",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m20_client?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.2",
    "releaseDate": "2026-07-03"
  },
  "description": "JSON for customer master data load",
  "description_es": "JSON para la carga de datos maestros de clientes",
  "description_en": "JSON for customer master data load",
  "type": "object",
  "properties": {
    "customerMasterData": {
      "description": "Customer declaration",
      "description_es": "Declaración del cliente",
      "description_en": "Customer declaration",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX2000"
      }
    }
  },
  "required": ["customerMasterData"],
  "additionalProperties": false,
  "$defs": {
    "GEEX2000": {
      "description": "Customer declaration",
      "description_es": "Declaración del cliente",
      "description_en": "Customer declaration",
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "description_es": "Código de cliente propietario del stock",
          "description_en": "Stock owner customer code",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "TYPCLI": {
          "description": "Customer type - see EnumTYPCLI",
          "description_es": "Tipo de cliente - ver EnumTYPCLI",
          "description_en": "Customer type - see EnumTYPCLI",
          "$ref": "#/$defs/Enums/EnumTYPCLI"
        },
        "CATCLI": {
          "description": "Customer category (e.g.: network)",
          "description_es": "Categoría de cliente (p. ej.: red)",
          "description_en": "Customer category (e.g.: network)",
          "type": "string",
          "maxLength": 3
        },
        "CLILIV": {
          "description": "Customer code to be delivered to",
          "description_es": "Código de cliente a entregar",
          "description_en": "Customer code to be delivered to",
          "type": "string",
          "maxLength": 14
        },
        "EDICLI": {
          "description": "Customer code for EDI",
          "description_es": "Código de cliente para EDI",
          "description_en": "Customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "NOMCLI": {
          "description": "Customer name",
          "description_es": "Nombre del cliente",
          "description_en": "Customer name",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD1CLI": {
          "description": "Customer address line 1",
          "description_es": "Dirección del cliente línea 1",
          "description_en": "Customer address line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2CLI": {
          "description": "Customer address line 2",
          "description_es": "Dirección del cliente línea 2",
          "description_en": "Customer address line 2",
          "type": "string",
          "maxLength": 38
        },
        "AD3CLI": {
          "description": "Customer address line 3",
          "description_es": "Dirección del cliente línea 3",
          "description_en": "Customer address line 3",
          "type": "string",
          "maxLength": 38
        },
        "CPICLI": {
          "description": "Customer postal code (international format)",
          "description_es": "Código postal del cliente (formato internacional)",
          "description_en": "Customer postal code (international format)",
          "type": "string",
          "minLength": 1,
          "maxLength": 10
        },
        "VILCLI": {
          "description": "Customer city",
          "description_es": "Ciudad del cliente",
          "description_en": "Customer city",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "PAYCLI": {
          "description": "Customer country code",
          "description_es": "Código de país del cliente",
          "description_en": "Customer country code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "TELCLI": {
          "description": "Customer phone number",
          "description_es": "Número de teléfono del cliente",
          "description_en": "Customer phone number",
          "type": "string",
          "maxLength": 20
        },
        "FAXCLI": {
          "description": "Customer fax number",
          "description_es": "Número de fax del cliente",
          "description_en": "Customer fax number",
          "type": "string",
          "maxLength": 20
        },
        "TLXCLI": {
          "description": "Customer telex number",
          "description_es": "Número de télex del cliente",
          "description_en": "Customer telex number",
          "type": "string",
          "maxLength": 15
        },
        "CODLGE": {
          "description": "Language code",
          "description_es": "Código de idioma",
          "description_en": "Language code",
          "type": "string",
          "maxLength": 3
        },
        "CODDEV": {
          "description": "Currency code",
          "description_es": "Código de moneda",
          "description_en": "Currency code",
          "type": "string",
          "maxLength": 3
        },
        "IGLSIT": {
          "description": "Site identifier for Infolog GL",
          "description_es": "Identificador de sitio para Infolog GL",
          "description_en": "Site identifier for Infolog GL",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "PTYCLI": {
          "description": "Store service priority",
          "description_es": "Prioridad de servicio de la tienda",
          "description_en": "Store service priority",
          "type": "string",
          "maxLength": 3
        },
        "ETACLI": {
          "description": "Customer status code - see EnumETACLI",
          "description_es": "Código de estado del cliente - ver EnumETACLI",
          "description_en": "Customer status code - see EnumETACLI",
          "$ref": "#/$defs/Enums/EnumETACLI"
        },
        "INDADR": {
          "description": "Address indicator",
          "description_es": "Indicador de dirección",
          "description_en": "Address indicator",
          "type": "string",
          "maxLength": 1
        },
        "CODCLV": {
          "description": "Delivery requirement",
          "description_es": "Requisito de entrega",
          "description_en": "Delivery requirement",
          "type": "string",
          "maxLength": 3
        },
        "GEEX2001": {
          "description": "Customer Additional Declaration",
          "description_es": "Declaración adicional del cliente",
          "description_en": "Customer Additional Declaration",
          "$ref": "#/$defs/GEEX2001Wrapper"
        },
        "GEEX2050": {
          "description": "Customer rubriques declaration",
          "description_es": "Declaración de rúbricas del cliente",
          "description_en": "Customer rubriques declaration",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX2050Wrapper"
          }
        }
      },
      "required": ["RCTEXC", "TRTEXC", "CODACT", "CODCLI", "NOMCLI", "AD1CLI", "CPICLI", "VILCLI", "PAYCLI"],
      "additionalProperties": false
    },
    "GEEX2001Wrapper": {
      "description": "Customer Additional Declaration",
      "description_es": "Declaración adicional del cliente",
      "description_en": "Customer Additional Declaration",
      "type": "object",
      "properties": {
        "RSPCLI": {
          "description": "Name of the person in charge at the customer",
          "description_es": "Nombre de la persona responsable en el cliente",
          "description_en": "Name of the person in charge at the customer",
          "type": "string",
          "maxLength": 30
        },
        "CODMOP": {
          "description": "Preparation mode code for a customer",
          "description_es": "Código de modo de preparación para un cliente",
          "description_en": "Preparation mode code for a customer",
          "type": "string",
          "maxLength": 3
        },
        "CODRGT": {
          "description": "Area code for transport",
          "description_es": "Código de zona para transporte",
          "description_en": "Area code for transport",
          "type": "string",
          "maxLength": 3
        },
        "CODTRA": {
          "description": "Carrier code",
          "description_es": "Código de transportista",
          "description_en": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "TOULIV": {
          "description": "Goods delivery round",
          "description_es": "Ruta de entrega de mercancías",
          "description_en": "Goods delivery round",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Goods delivery round",
            "description_es": "Ruta de entrega de mercancías",
            "description_en": "Goods delivery round",
            "type": "string",
            "pattern": "^[0-9]{1,4}$"
          }
        },
        "ORDLIV": {
          "description": "Delivery order in the round",
          "description_es": "Orden de entrega en la ruta",
          "description_en": "Delivery order in the round",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Delivery order in the round",
            "description_es": "Orden de entrega en la ruta",
            "description_en": "Delivery order in the round",
            "type": "string",
            "pattern": "^[0-9]{1,4}$"
          }
        },
        "KAILIV": {
          "description": "Freight transport docks",
          "description_es": "Muelles de transporte de mercancías",
          "description_en": "Freight transport docks",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Freight transport docks",
            "description_es": "Muelles de transporte de mercancías",
            "description_en": "Freight transport docks",
            "type": "string",
            "pattern": "^[0-9]{1,3}$"
          }
        },
        "GSTALC": {
          "description": "Liquor management mode - see EnumGSTALC",
          "description_es": "Modo de gestión de licores - ver EnumGSTALC",
          "description_en": "Liquor management mode - see EnumGSTALC",
          "$ref": "#/$defs/Enums/EnumGSTALC"
        },
        "PTYDES": {
          "description": "Pallet retrieval priority - see EnumPTYDES",
          "description_es": "Prioridad de extracción de palés - ver EnumPTYDES",
          "description_en": "Pallet retrieval priority - see EnumPTYDES",
          "$ref": "#/$defs/Enums/EnumPTYDES"
        },
        "NUMACS": {
          "description": "Excise duty number (Alcohol)",
          "description_es": "Número de impuestos especiales (Alcohol)",
          "description_en": "Excise duty number (Alcohol)",
          "type": "string",
          "maxLength": 20
        },
        "TVACCE": {
          "description": "Intra-community VAT",
          "description_es": "IVA intracomunitario",
          "description_en": "Intra-community VAT",
          "type": "string",
          "maxLength": 20
        },
        "IDEALC": {
          "description": "Alcohol identifier",
          "description_es": "Identificador de alcohol",
          "description_en": "Alcohol identifier",
          "type": "string",
          "maxLength": 20
        },
        "CTRPRP": {
          "description": "Quantity control during preparation / false = Non-systematic, true = Systematic",
          "description_es": "Control de cantidad durante la preparación / false = No sistemático, true = Sistemático",
          "description_en": "Quantity control during preparation / false = Non-systematic, true = Systematic",
          "type": "boolean",
          "default": false
        },
        "CLIDAE": {
          "description": "DEA management mode",
          "description_es": "Modo de gestión DEA",
          "description_en": "DEA management mode",
          "type": "string",
          "maxLength": 1
        },
        "TYPDES": {
          "description": "GAMM@ destination type",
          "description_es": "Tipo de destino GAMM@",
          "description_en": "GAMM@ destination type",
          "type": "string",
          "maxLength": 1
        },
        "BUREXP": {
          "description": "Ref. GAMM@ Export Office",
          "description_es": "Ref. oficina de exportación GAMM@",
          "description_en": "Ref. GAMM@ Export Office",
          "type": "string",
          "maxLength": 8
        },
        "PTYPRP": {
          "description": "Priority of heterogeneous supports in ML preparation - see EnumPTYPRP",
          "description_es": "Prioridad de soportes heterogéneos en preparación ML - ver EnumPTYPRP",
          "description_en": "Priority of heterogeneous supports in ML preparation - see EnumPTYPRP",
          "$ref": "#/$defs/Enums/EnumPTYPRP"
        },
        "GENAVI": {
          "description": "Shipping notice generation",
          "description_es": "Generación del aviso de expedición",
          "description_en": "Shipping notice generation",
          "type": "string",
          "maxLength": 1
        },
        "HEUCHV": {
          "description": "Riding Time /  false = No, true = Yes",
          "description_es": "Tiempo de conducción / false = No, true = Sí",
          "description_en": "Riding Time /  false = No, true = Yes",
          "type": "boolean",
          "default": false
        },
        "TYPDES2": {
          "description": "GAMM@ destination type",
          "description_es": "Tipo de destino GAMM@",
          "description_en": "GAMM@ destination type",
          "type": "string",
          "maxLength": 2
        },
        "CODFCQ": {
          "description": "Quality control sheet code",
          "description_es": "Código de ficha de control de calidad",
          "description_en": "Quality control sheet code",
          "type": "string",
          "maxLength": 3
        },
        "CM1CLI": {
          "description": "Customer comment (line 1)",
          "description_es": "Comentario del cliente (línea 1)",
          "description_en": "Customer comment (line 1)",
          "type": "string",
          "maxLength": 45
        },
        "CM2CLI": {
          "description": "Customer comment (line 2)",
          "description_es": "Comentario del cliente (línea 2)",
          "description_en": "Customer comment (line 2)",
          "type": "string",
          "maxLength": 45
        },
        "CM3CLI": {
          "description": "Customer comment (line 3)",
          "description_es": "Comentario del cliente (línea 3)",
          "description_en": "Customer comment (line 3)",
          "type": "string",
          "maxLength": 45
        },
        "EMLADR": {
          "description": "Email address",
          "description_es": "Dirección de correo electrónico",
          "description_en": "Email address",
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "format": "email"
        },
        "CODRST": {
          "description": "In-transit inventory rule code",
          "description_es": "Código de regla de inventario en tránsito",
          "description_en": "In-transit inventory rule code",
          "type": "string",
          "maxLength": 3
        },
        "LIBCPL": {
          "description": "Additional name",
          "description_es": "Nombre adicional",
          "description_en": "Additional name",
          "type": "string",
          "maxLength": 38
        },
        "LIBCP2": {
          "description": "Additional name 2",
          "description_es": "Nombre adicional 2",
          "description_en": "Additional name 2",
          "type": "string",
          "maxLength": 38
        },
        "EXLGRP": {
          "description": "Out of group / false = no, true = Yes",
          "description_es": "Fuera de grupo / false = No, true = Sí",
          "description_en": "Out of group / false = no, true = Yes",
          "type": "boolean",
          "default": false
        },
        "TYPDSV": {
          "description": "DESADV type",
          "description_es": "Tipo DESADV",
          "description_en": "DESADV type",
          "type": "string",
          "maxLength": 1
        },
        "PTYSND": {
          "description": "Shipping priority",
          "description_es": "Prioridad de expedición",
          "description_en": "Shipping priority",
          "type": "string",
          "maxLength": 1
        },
        "IDEEXT": {
          "description": "External identifier",
          "description_es": "Identificador externo",
          "description_en": "External identifier",
          "type": "string",
          "maxLength": 35
        },
        "ARDPEN": {
          "description": "Shortage rounding indicator",
          "description_es": "Indicador de redondeo por faltante",
          "description_en": "Shortage rounding indicator",
          "type": "string",
          "maxLength": 1
        }
      },
      "additionalProperties": false
    },
    "GEEX2050Wrapper": {
      "description": "Customer rubriques declaration",
      "description_es": "Declaración de rúbricas del cliente",
      "description_en": "Customer rubriques declaration",
      "type": "object",
      "properties": {
        "TYPRUB": {
          "description": "Heading type - see EnumTYPRUB",
          "description_es": "Tipo de rúbrica - ver EnumTYPRUB",
          "description_en": "Heading type - see EnumTYPRUB",
          "$ref": "#/$defs/Enums/EnumTYPRUB"
        },
        "CODRUB": {
          "description": "Section code",
          "description_es": "Código de sección",
          "description_en": "Section code",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Item value",
          "description_es": "Valor del elemento",
          "description_en": "Item value",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["TYPRUB", "CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "description_es": "Código de procesamiento del movimiento / 1 = Crear, 2 = Modificar o crear, 9 = Cancelación",
        "description_en": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "9"],
        "default": "2"
      },
      "EnumTYPCLI": {
        "description": "Customer type / 1 = Final Delivery Point, 2 = Grouping Customer, 3 = Platform, 4 = Workshop",
        "description_es": "Tipo de cliente / 1 = Punto de entrega final, 2 = Cliente de agrupación, 3 = Plataforma, 4 = Taller",
        "description_en": "Customer type / 1 = Final Delivery Point, 2 = Grouping Customer, 3 = Platform, 4 = Workshop",
        "type": "string",
        "enum": ["1", "2", "3", "4"]
      },
      "EnumETACLI": {
        "description": "Customer status code / 20 = Not considered, 30 = Customer record, 40 = M50 Interface",
        "description_es": "Código de estado del cliente / 20 = No considerado, 30 = Ficha de cliente, 40 = Interfaz M50",
        "description_en": "Customer status code / 20 = Not considered, 30 = Customer record, 40 = M50 Interface",
        "type": "string",
        "enum": ["20", "30", "40"]
      },
      "EnumGSTALC": {
        "description": "Liquor management mode / 0 = No alcohol management, 1 = Delivery with suspended duty, 2 = Delivery under voucher, 3 = Out of customs, no taxes",
        "description_es": "Modo de gestión de licores / 0 = Sin gestión de alcohol, 1 = Entrega con impuesto suspendido, 2 = Entrega bajo comprobante, 3 = Fuera de aduana, sin impuestos",
        "description_en": "Liquor management mode / 0 = No alcohol management, 1 = Delivery with suspended duty, 2 = Delivery under voucher, 3 = Out of customs, no taxes",
        "type": "string",
        "enum": ["0", "1", "2", "3"]
      },
      "EnumPTYDES": {
        "description": "Pallet retrieval priority / 10 = S.O.S., 20 = S.O.S., 30 = Urgent, 40 = Urgent, 50 = Normal, 60 = Normal, 70= Normal, 80 = Normal, 90 = Blocking, 95 = Interceptable",
        "description_es": "Prioridad de extracción de palés / 10 = S.O.S., 20 = S.O.S., 30 = Urgente, 40 = Urgente, 50 = Normal, 60 = Normal, 70 = Normal, 80 = Normal, 90 = Bloqueante, 95 = Interceptable",
        "description_en": "Pallet retrieval priority / 10 = S.O.S., 20 = S.O.S., 30 = Urgent, 40 = Urgent, 50 = Normal, 60 = Normal, 70= Normal, 80 = Normal, 90 = Blocking, 95 = Interceptable",
        "type": "string",
        "enum": ["10", "20", "30", "40", "50", "60", "70", "80", "90", "95"]
      },
      "EnumPTYPRP": {
        "description": "Priority of heterogeneous supports in ML preparation / 10 = S.O.S., 20 = S.O.S., 30 = Urgent, 40 = Urgent, 50 = Normal, 60 = Normal, 70= Normal, 80 = Normal, 90 = Blocking",
        "description_es": "Prioridad de soportes heterogéneos en preparación ML / 10 = S.O.S., 20 = S.O.S., 30 = Urgente, 40 = Urgente, 50 = Normal, 60 = Normal, 70 = Normal, 80 = Normal, 90 = Bloqueante",
        "description_en": "Priority of heterogeneous supports in ML preparation / 10 = S.O.S., 20 = S.O.S., 30 = Urgent, 40 = Urgent, 50 = Normal, 60 = Normal, 70= Normal, 80 = Normal, 90 = Blocking",
        "type": "string",
        "enum": ["10", "20", "30", "40", "50", "60", "70", "80", "90"]
      },
      "EnumTYPRUB": {
        "description": "Section type / 1 = EDIFACT standard, 2 = Internal coding",
        "description_es": "Tipo de rúbrica / 1 = Estándar EDIFACT, 2 = Codificación interna",
        "description_en": "Section type / 1 = EDIFACT standard, 2 = Internal coding",
        "type": "string",
        "enum": ["1", "2"],
        "default": "2"
      }
    }
  }
}
