                      "maxLength": 30
                    },
                    "DS2PRO": {
                      "type": "string",
                      "description": "Product designation line 2",
                      "maxLength": 30
                    },
                    "DS3PRO": {
                      "type": "string",
                      "description": "Product designation line 3",
                      "maxLength": 35
                    },
                    "REFREC": {
                      "type": "string",
                      "description": "Receipt reference",
                      "maxLength": 30
                    },
