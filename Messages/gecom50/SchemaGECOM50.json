{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom50/SchemaGECOM50.json",
  "title": "GECOM50 - Delivery Orders",
  "title_es": "GECOM50 - Órdenes de entrega",
  "title_en": "GECOM50 - Delivery Orders",
  "x-wms-icon": "GECOM50",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m50_expedition?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.2",
    "releaseDate": "2026-07-03"
  },
  "description": "JSON for creating a Delivery Orders",
  "description_es": "JSON para la creación de órdenes de entrega",
  "description_en": "JSON for creating a Delivery Orders",
  "type": "object",
  "properties": {
    "deliveryOrders": {
      "description": "Delivery Orders Header",
      "description_es": "Cabecera de órdenes de entrega",
      "description_en": "Delivery Orders Header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX5000"
      }
    }
  },
  "required": ["deliveryOrders"],
  "additionalProperties": false,
  "$defs": {
    "GEEX5000": {
      "description": "Delivery Orders Header",
      "description_es": "Cabecera de órdenes de entrega",
      "description_en": "Delivery Orders Header",
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "NUMLIV": {
          "description": "Order number to be delivered",
          "description_es": "Número de orden a entregar",
          "description_en": "Order number to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNULIV": {
          "description": "Sub-number of the order to be delivered",
          "description_es": "Subnúmero de la orden a entregar",
          "description_en": "Sub-number of the order to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Customer code of the stock owner",
          "description_es": "Código de cliente del propietario del stock",
          "description_en": "Customer code of the stock owner",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "REFLIV": {
          "description": "Delivery reference",
          "description_es": "Referencia de entrega",
          "description_en": "Delivery reference",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "CODTLI": {
          "description": "Delivery type code",
          "description_es": "Código de tipo de entrega",
          "description_en": "Delivery type code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "DTILIV": {
          "description": "Initially scheduled delivery date (format YYYYMMDD)",
          "description_es": "Fecha de entrega inicialmente programada (formato AAAAMMDD)",
          "description_en": "Initially scheduled delivery date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEILIV": {
          "description": "Originally scheduled delivery time (format HHMM)",
          "description_es": "Hora de entrega originalmente programada (formato HHMM)",
          "description_en": "Originally scheduled delivery time (format HHMM)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])$",
          "examples": ["1430"]
        },
        "CLILIV": {
          "description": "Customer code to deliver",
          "description_es": "Código de cliente a entregar",
          "description_en": "Customer code to deliver",
          "type": "string",
          "maxLength": 14
        },
        "TYPLIV": {
          "description": "Delivery type (notion of collected/delivered) - see EnumTYPLIV",
          "description_es": "Tipo de entrega (noción de recogido/entregado) - ver EnumTYPLIV",
          "description_en": "Delivery type (notion of collected/delivered) - see EnumTYPLIV",
          "$ref": "#/$defs/Enums/EnumTYPLIV"
        },
        "CODMOP": {
          "description": "Preparation mode code for a customer",
          "description_es": "Código de modo de preparación para un cliente",
          "description_en": "Preparation mode code for a customer",
          "type": "string",
          "maxLength": 3
        },
        "CODTRA": {
          "description": "Carrier code",
          "description_es": "Código de transportista",
          "description_en": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "CODRGT": {
          "description": "Area code for transport",
          "description_es": "Código de zona para transporte",
          "description_en": "Area code for transport",
          "type": "string",
          "maxLength": 3
        },
        "TOULIV": {
          "description": "Goods delivery round",
          "description_es": "Ruta de entrega de mercancías",
          "description_en": "Goods delivery round",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "ORDLIV": {
          "description": "Delivery order in the tour",
          "description_es": "Orden de entrega en la ruta",
          "description_en": "Delivery order in the tour",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "KAILIV": {
          "description": "Cargo shipping dock",
          "description_es": "Muelle de expedición de carga",
          "description_en": "Cargo shipping dock",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "MSGPRP": {
          "description": "Message to edit on the packing slip",
          "description_es": "Mensaje a editar en el albarán de preparación",
          "description_en": "Message to edit on the packing slip",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Message to edit on the packing slip",
            "description_es": "Mensaje a editar en el albarán de preparación",
            "description_en": "Message to edit on the packing slip",
            "type": "string",
            "maxLength": 30
          }
        },
        "MSGLIV": {
          "description": "Message to edit on the delivery note",
          "description_es": "Mensaje a editar en el albarán de entrega",
          "description_en": "Message to edit on the delivery note",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Message to edit on the delivery note",
            "description_es": "Mensaje a editar en el albarán de entrega",
            "description_en": "Message to edit on the delivery note",
            "type": "string",
            "maxLength": 30
          }
        },
        "GSTALC": {
          "description": "Alcohol management mode - see EnumGSTALC",
          "description_es": "Modo de gestión de alcohol - ver EnumGSTALC",
          "description_en": "Alcohol management mode - see EnumGSTALC",
          "$ref": "#/$defs/Enums/EnumGSTALC"
        },
        "CODSIT": {
          "description": "Storage site code",
          "description_es": "Código del sitio de almacenamiento",
          "description_en": "Storage site code",
          "type": "string",
          "maxLength": 3
        },
        "IGLSIT": {
          "description": "GE site identifier for Infolog GL",
          "description_es": "Identificador de sitio GE para Infolog GL",
          "description_en": "GE site identifier for Infolog GL",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODBAS": {
          "description": "Database code",
          "description_es": "Código de base de datos",
          "description_en": "Database code",
          "type": "string",
          "maxLength": 3
        },
        "TYPCDE": {
          "description": "Order type (provisional or firm) / false = Firm order, true = Provisional order",
          "description_es": "Tipo de orden (provisional o firme) / false = Orden firme, true = Orden provisional",
          "description_en": "Order type (provisional or firm) / false = Firm order, true = Provisional order",
          "type": "boolean",
          "default": false
        },
        "CUMLIG": {
          "description": "Total number of lines in the order",
          "description_es": "Número total de líneas de la orden",
          "description_en": "Total number of lines in the order",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "CUMPOI": {
          "description": "Cumulated gross weight of the order in Kg",
          "description_es": "Peso bruto acumulado de la orden en kg",
          "description_en": "Cumulated gross weight of the order in Kg",
          "type": "string",
          "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
        },
        "CUMVOL": {
          "description": "Cumulated order volumes in Dm3",
          "description_es": "Volúmenes acumulados de la orden en dm3",
          "description_en": "Cumulated order volumes in Dm3",
          "type": "string",
          "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
        },
        "CUMCOL": {
          "description": "Total number of packages",
          "description_es": "Número total de paquetes",
          "description_en": "Total number of packages",
          "type": "string",
          "pattern": "^[0-9]{1,7}$"
        },
        "GEEX5001": {
          "description": "Delivery Order Additional Header Information",
          "description_es": "Información adicional de cabecera de la orden de entrega",
          "description_en": "Delivery Order Additional Header Information",
          "$ref": "#/$defs/GEEX5001Wrapper"
        },
        "GEEX5005": {
          "description": "Delivery Orders Rubriques Declaration header",
          "description_es": "Cabecera de declaración de rúbricas de órdenes de entrega",
          "description_en": "Delivery Orders Rubriques Declaration header",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5005Wrapper"
          }
        },
        "GEEX5010": {
          "description": "Customer VPC Address Information",
          "description_es": "Información de dirección VPC del cliente",
          "description_en": "Customer VPC Address Information",
          "$ref": "#/$defs/GEEX5010Wrapper"
        },
        "GEEX5020": {
          "description": "Delivery Order Lines",
          "description_es": "Líneas de la orden de entrega",
          "description_en": "Delivery Order Lines",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5020Wrapper"
          }
        },
        "GEEX5080": {
          "description": "Free text on delivery note",
          "description_es": "Texto libre en el albarán de entrega",
          "description_en": "Free text on delivery note",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5080Wrapper"
          }
        }
      },
      "required": ["RCTEXC", "TRTEXC", "REFLIV", "CODTLI", "CODACT", "CODCLI", "DTILIV", "HEILIV", "CUMLIG"],
      "if": {
        "properties": {
          "TRTEXC": { "enum": ["1", "2"] }
        },
        "required": ["TRTEXC"]
      },
      "then": {
        "required": ["GEEX5020"]
      },
      "additionalProperties": false
    },
    "GEEX5001Wrapper": {
      "description": "Delivery Order Additional Header Information",
      "description_es": "Información adicional de cabecera de la orden de entrega",
      "description_en": "Delivery Order Additional Header Information",
      "type": "object",
      "properties": {
        "TOPLIV": {
          "description": "Indicators for specific users",
          "description_es": "Indicadores para usuarios específicos",
          "description_en": "Indicators for specific users",
          "type": "array",
          "maxItems": 5,
          "items": {
            "description": "Indicators for specific users",
            "description_es": "Indicadores para usuarios específicos",
            "description_en": "Indicators for specific users",
            "type": "string",
            "maxLength": 1
          }
        },
        "DIPLIV": {
          "description": "Data transit area between software",
          "description_es": "Zona de tránsito de datos entre software",
          "description_en": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "DATEXP": {
          "description": "Goods dispatch date (format YYYYMMDD)",
          "description_es": "Fecha de expedición de mercancías (formato AAAAMMDD)",
          "description_en": "Goods dispatch date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXP": {
          "description": "Goods dispatch time (format HHMM)",
          "description_es": "Hora de expedición de mercancías (formato HHMM)",
          "description_en": "Goods dispatch time (format HHMM)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])$",
          "examples": ["1430"]
        },
        "MNTCRB": {
          "description": "Cash on delivery amount",
          "description_es": "Importe del contra reembolso",
          "description_en": "Cash on delivery amount",
          "type": "string",
          "pattern": "^[0-9]{1,11}\\.[0-9]{3}$",
          "examples": ["100.780"]
        },
        "REFCLI": {
          "description": "Recipient's order reference",
          "description_es": "Referencia de la orden del destinatario",
          "description_en": "Recipient's order reference",
          "type": "string",
          "maxLength": 30
        },
        "CRILIV": {
          "description": "Order extraction criteria",
          "description_es": "Criterios de extracción de la orden",
          "description_en": "Order extraction criteria",
          "type": "string",
          "maxLength": 20
        },
        "PTYCLI": {
          "description": "Store service priority",
          "description_es": "Prioridad de servicio de la tienda",
          "description_en": "Store service priority",
          "type": "string",
          "maxLength": 3
        },
        "CODLDP": {
          "description": "Preparation location code",
          "description_es": "Código de ubicación de preparación",
          "description_en": "Preparation location code",
          "type": "string",
          "maxLength": 3
        },
        "EDICLF": {
          "description": "Final customer code for EDI",
          "description_es": "Código de cliente final para EDI",
          "description_en": "Final customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDICLI": {
          "description": "Customer code for EDI",
          "description_es": "Código de cliente para EDI",
          "description_en": "Customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDITRA": {
          "description": "Carrier code for EDI",
          "description_es": "Código de transportista para EDI",
          "description_en": "Carrier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "DATCHT": {
          "description": "Goods loading date (format YYYYMMDD)",
          "description_es": "Fecha de carga de mercancías (formato AAAAMMDD)",
          "description_en": "Goods loading date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUCHT": {
          "description": "Goods loading time (format HHMM)",
          "description_es": "Hora de carga de mercancías (formato HHMM)",
          "description_en": "Goods loading time (format HHMM)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])$",
          "examples": ["1430"]
        },
        "NUMTOU": {
          "description": "Return record number",
          "description_es": "Número de registro de devolución",
          "description_en": "Return record number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "DATPTD": {
          "description": "Last preparation date (format YYYYMMDD)",
          "description_es": "Última fecha de preparación (formato AAAAMMDD)",
          "description_en": "Last preparation date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUPTD": {
          "description": "Last preparation time (format HHMMSS)",
          "description_es": "Última hora de preparación (formato HHMMSS)",
          "description_en": "Last preparation time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "CODAFI": {
          "description": "Affiliation code",
          "description_es": "Código de afiliación",
          "description_en": "Affiliation code",
          "type": "string",
          "maxLength": 10
        },
        "CODDDO": {
          "description": "Originator code",
          "description_es": "Código del originador",
          "description_en": "Originator code",
          "type": "string",
          "maxLength": 14
        },
        "SITPAL": {
          "description": "Updated pallet origin site",
          "description_es": "Sitio de origen del palé actualizado",
          "description_en": "Updated pallet origin site",
          "type": "string",
          "maxLength": 3
        },
        "CLIVIA": {
          "description": "Intermediate delivery point / Relay point",
          "description_es": "Punto de entrega intermedio / Punto de relevo",
          "description_en": "Intermediate delivery point / Relay point",
          "type": "string",
          "maxLength": 14
        },
        "DATEXC": {
          "description": "Negotiation date (format YYYYMMDD)",
          "description_es": "Fecha de negociación (formato AAAAMMDD)",
          "description_en": "Negotiation date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXC": {
          "description": "Exchange time (format HHMMSS)",
          "description_es": "Hora del intercambio (formato HHMMSS)",
          "description_en": "Exchange time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "CODCLV": {
          "description": "Delivery requirement code",
          "description_es": "Código de requisito de entrega",
          "description_en": "Delivery requirement code",
          "type": "string",
          "maxLength": 3
        },
        "CODOWN": {
          "description": "Holder code",
          "description_es": "Código del titular",
          "description_en": "Holder code",
          "type": "string",
          "maxLength": 14
        },
        "CODOFT": {
          "description": "Operator offer code",
          "description_es": "Código de oferta del operador",
          "description_en": "Operator offer code",
          "type": "string",
          "maxLength": 14
        },
        "SITRCT": {
          "description": "Reception site code (recipient's warehouse)",
          "description_es": "Código de sitio de recepción (almacén del destinatario)",
          "description_en": "Reception site code (recipient's warehouse)",
          "type": "string",
          "maxLength": 3
        },
        "TOPVIA": {
          "description": "Supplier type indicator",
          "description_es": "Indicador de tipo de proveedor",
          "description_en": "Supplier type indicator",
          "type": "string",
          "maxLength": 1
        },
        "CODGLN": {
          "description": "Global logistics number",
          "description_es": "Número logístico global",
          "description_en": "Global logistics number",
          "type": "string",
          "maxLength": 14
        },
        "REFEXT": {
          "description": "External reference",
          "description_es": "Referencia externa",
          "description_en": "External reference",
          "type": "string",
          "maxLength": 30
        },
        "HLIMIN": {
          "description": "Minimum delivery time",
          "description_es": "Tiempo de entrega mínimo",
          "description_en": "Minimum delivery time",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "HLIMAX": {
          "description": "Maximum delivery time",
          "description_es": "Tiempo de entrega máximo",
          "description_en": "Maximum delivery time",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "CODACL": {
          "description": "Code to cancel an order to be delivered",
          "description_es": "Código para cancelar una orden a entregar",
          "description_en": "Code to cancel an order to be delivered",
          "type": "string",
          "maxLength": 3
        },
        "CODTTO": {
          "description": "Route type code",
          "description_es": "Código de tipo de ruta",
          "description_en": "Route type code",
          "type": "string",
          "maxLength": 3
        },
        "DATLIV": {
          "description": "Order delivery date (format YYYYMMDD)",
          "description_es": "Fecha de entrega de la orden (formato AAAAMMDD)",
          "description_en": "Order delivery date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        }
      },
      "additionalProperties": false
    },
    "GEEX5005Wrapper": {
      "description": "Delivery Orders Rubriques Declaration header",
      "description_es": "Cabecera de declaración de rúbricas de órdenes de entrega",
      "description_en": "Delivery Orders Rubriques Declaration header",
      "type": "object",
      "properties": {
        "CODRUB": {
          "description": "Section code array",
          "description_es": "Matriz de códigos de sección",
          "description_en": "Section code array",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value array",
          "description_es": "Matriz de valores del elemento de trazabilidad",
          "description_en": "Traceability element value array",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "GEEX5010Wrapper": {
      "description": "Customer VPC Address Information",
      "description_es": "Información de dirección VPC del cliente",
      "description_en": "Customer VPC Address Information",
      "type": "object",
      "properties": {
        "NOMCLI": {
          "description": "Customer name",
          "description_es": "Nombre del cliente",
          "description_en": "Customer name",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "AD1CLI": {
          "description": "Customer address line 1",
          "description_es": "Dirección del cliente línea 1",
          "description_en": "Customer address line 1",
