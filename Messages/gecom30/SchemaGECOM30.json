                "maxLength": 2
              },
              "CODFCQ": {
                "type": "string",
                "description": "Quality control sheet code",
                "maxLength": 3
              }
            }
          },
          "GEEX3004": {
            "type": "object",
            "description": "Product Additional 04 declaration",
            "additionalProperties": false,
            "properties": {
              "CODCMM": {
                "type": "array",
                "description": "Material account code (multi-material)",
