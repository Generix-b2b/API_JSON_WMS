{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Schemas/SchemaGECOM30.json",
  "title": "GECOM30 - Product Master Data",
  "x-wms-icon": "GECOM30",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m30_product",
    "category": "Inbound",
    "version": "v1.0",
    "releaseDate": "2026-06-17"
  },
  "type": "object",
  "description": "JSON for product master data load",
  "properties": {
    "productMasterData": {
      "type": "array",
      "description": "Master Data declaration",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
            "enum": ["1", "2", "9"],
            "default": "2"
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "CODPRO": {
            "type": "string",
            "description": "Internal product code",
            "minLength": 1,
            "maxLength": 17
          },
          "VALPRO": {
            "type": "string",
            "description": "Logistics variant (Gencod)",
            "pattern": "^[0-9]{1,2}$"
          },
          "DS1PRO": {
            "type": "string",
            "description": "Product designation line 1",
            "minLength": 1,
            "maxLength": 30
          },
          "DS2PRO": {
            "type": "string",
            "description": "Product designation line 2",
            "maxLength": 30
          },
          "FOUPRO": {
            "type": "string",
            "description": "Product supplier code",
            "maxLength": 14
          },
          "VAPPRO": {
            "type": "string",
            "description": "Supply variant (Gencod)",
            "pattern": "^[0-9]{1,2}$"
          },
          "FAMPRO": {
            "type": "string",
            "description": "Product classification family",
            "maxLength": 10
          },
          "ANAPRO": {
            "type": "string",
            "description": "Product analysis code",
            "maxLength": 15
          },
          "EDIPRO": {
            "type": "string",
            "description": "Product code for EDI",
            "maxLength": 17
          },
          "SPCPRO": {
            "type": "integer",
            "description": "Product sub-pack quantity",
            "minimum": 0,
            "maximum": 9999
          },
          "PCBPRO": {
            "type": "integer",
            "description": "Product pack quantity",
            "minimum": 0,
            "maximum": 99999
          },
          "UNIPRO": {
            "type": "string",
            "description": "Product unit of measure",
            "maxLength": 3
          },
          "MESPRO": {
            "type": "string",
            "description": "Product measurement method / 1 = Fixed Weight, 2 = Variable Weight, 3 = Regulated Measurement",
            "enum": ["1", "2", "3"],
            "default": "1"
          },
          "PDBUVC": {
            "type": "number",
            "description": "CSU gross weight in kg",
            "minimum": 0,
            "maximum": 9999.999,
            "multipleOf": 0.001
          },
          "PDNUVC": {
            "type": "number",
            "description": "CSU net weight in kg",
            "minimum": 0,
            "maximum": 9999.999,
            "multipleOf": 0.001
          },
          "HAUUVC": {
            "type": "integer",
            "description": "CSU height expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "LNGUVC": {
            "type": "integer",
            "description": "CSU length expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "LRGUVC": {
            "type": "integer",
            "description": "CSU width expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "PDBCOL": {
            "type": "number",
            "description": "Package gross weight in kg",
            "minimum": 0,
            "maximum": 9999.999,
            "multipleOf": 0.001
          },
          "HAUCOL": {
            "type": "integer",
            "description": "Package height expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "LNGCOL": {
            "type": "integer",
            "description": "Package length expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "LRGCOL": {
            "type": "integer",
            "description": "Package width expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "COLCOU": {
            "type": "integer",
            "description": "Number of packages per layer",
            "minimum": 1,
            "maximum": 9999
          },
          "COUPAL": {
            "type": "integer",
            "description": "Number of layers per pallet",
            "minimum": 1,
            "maximum": 9999
          },
          "GERPAL": {
            "type": "string",
            "description": "Number of pallet stacks in storage",
            "pattern": "^[0-9]{1,2}$"
          },
          "GERHAU": {
            "type": "string",
            "description": "Number of pallets stacked high",
            "pattern": "^[0-9]{1,2}$"
          },
          "HAUCOU": {
            "type": "integer",
            "description": "Layer height expressed in cm",
            "minimum": 0,
            "maximum": 999
          },
          "CODEMB": {
            "type": "string",
            "description": "Package code handling",
            "maxLength": 3
          },
          "ABCPRO": {
            "type": "string",
            "description": "ABC product rotation class",
            "maxLength": 1
          },
          "CODMDR": {
            "type": "string",
            "description": "Goods receipt method",
            "maxLength": 3
          },
          "MODREC": {
            "type": "string",
            "description": "Receiving mode / 1 = Full Pallet, 2 = Unit",
            "enum": ["1", "2"],
            "default": "1"
          },
          "NBJDLV": {
            "type": "string",
            "description": "Number of DLV days",
            "maxLength": 3
          },
          "MOTIMM": {
            "type": "string",
            "description": "Immobilization reason",
            "maxLength": 3
          },
          "CODMDS": {
            "type": "string",
            "description": "Storage method code",
            "maxLength": 3
          },
          "ZONPRF": {
            "type": "string",
            "description": "Preferred storage area",
            "maxLength": 1
          },
          "ALLPRF": {
            "type": "string",
            "description": "Preferred storage aisle",
            "pattern": "^[0-9]{1,3}$"
          },
          "ABCSTS": {
            "type": "string",
            "description": "Storage class",
            "maxLength": 1
          },
          "CODADM": {
            "type": "string",
            "description": "Sheaf storage method",
            "maxLength": 3
          },
          "HOMGRB": {
            "type": "string",
            "description": "Type of sheaf homogeneity (rack or bulk) / 0 = No date uniformity, 1 = Variable per day, 2 = Variable per week, 3 = Variable per decade, 4 = Variable per month, 5 = Single batch",
            "enum": ["0", "1", "2", "3", "4", "5"],
            "default": "0"
          },
          "PERGRB": {
            "type": "string",
            "description": "Pattern homogeneity period (rack/bulk)",
            "maxLength": 3
          },
          "CODMDP": {
            "type": "string",
            "description": "Preparation process method",
            "maxLength": 3
          },
          "TOPPRN": {
            "type": "string",
            "description": "Indicator for composite or unit product / 0 = Unit Product, 1 = Bill of Materials",
            "enum": ["0", "1"],
            "default": "0"
          },
          "ORIMAJ": {
            "type": "string",
            "description": "Update origin",
            "maxLength": 1
          },
          "TOPPRO": {
            "type": "string",
            "description": "Product indicator",
            "maxLength": 1
          },
          "GEEX3001": {
            "type": "object",
            "description": "Product Additional 01 declaration",
            "additionalProperties": false,
            "properties": {
              "INDPRO": {
                "type": "array",
                "description": "Configurable product indicators",
                "maxItems": 10,
                "items": {
                  "type": "string",
                  "description": "Configurable product indicators",
                  "maxLength": 1
                }
              },
              "CODMRQ": {
                "type": "string",
                "description": "Manufacturer brand code",
                "maxLength": 8
              },
              "DESFOU": {
                "type": "string",
                "description": "Product designation at the supplier",
                "maxLength": 30
              },
              "CIRDET": {
                "type": "string",
                "description": "Detail picking preparation circuit",
                "maxLength": 3
              },
              "CIRPAL": {
                "type": "string",
                "description": "Full pallet preparation circuit",
                "maxLength": 3
              },
              "METRPL": {
                "type": "string",
                "description": "Product replacement method / 0 = No substitute, 1 = Substituted by..., 2 = Replaced by...",
                "enum": ["0", "1", "2"],
                "default": "0"
              },
              "CODRPL": {
                "type": "string",
                "description": "Replacement product code",
                "maxLength": 17
              },
              "VALRPL": {
                "type": "string",
                "description": "Logistics variant of the substitute product",
                "maxLength": 2
              },
              "CODALC": {
                "type": "string",
                "description": "Liquor seal code",
                "maxLength": 4
              },
              "DEGALC": {
                "type": "string",
                "description": "Pure alcohol degree",
                "pattern": "^[0-9]{1,3}\\.[0-9]{2}$",
                "examples": ["12.50"]
              },
              "VOLALC": {
                "type": "string",
                "description": "Beverage volume for liquor management",
                "pattern": "^[0-9]{1,3}\\.[0-9]{3}$",
                "examples": ["0.750"]
              },
              "CODMDG": {
                "type": "string",
                "description": "Service management method code",
                "maxLength": 3
              },
              "TAUPST": {
                "type": "array",
                "description": "Profit rate",
                "maxItems": 4,
                "items": {
                  "type": "string",
                  "description": "Profit rate",
                  "pattern": "^[0-9]{1,3}\\.[0-9]{2}$",
                  "examples": ["15.00"]
                }
              },
              "COELOG": {
                "type": "string",
                "description": "Logistics coefficient",
                "pattern": "^[0-9]{1,2}\\.[0-9]{3}$",
                "examples": ["1.000"]
              },
              "PRXPRO": {
                "type": "array",
                "description": "Product price",
                "maxItems": 4,
                "items": {
                  "type": "string",
                  "description": "Product price",
                  "pattern": "^[0-9]{1,6}\\.[0-9]{3}$",
                  "examples": ["10.500"]
                }
              },
              "CODMDI": {
                "type": "string",
                "description": "Cycle counting method",
                "maxLength": 3
              },
              "NXTIVT": {
                "type": "string",
                "description": "Date of next product inventory / format YYYYMMDD",
                "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
                "examples": ["20250125"]
              },
              "SECSTK": {
                "type": "string",
                "description": "Safety stock in CSU",
                "maxLength": 9
              },
              "CODMDF": {
                "type": "string",
                "description": "Manufacturing process method",
                "maxLength": 3
              },
              "FMTFAB": {
                "type": "string",
                "description": "Product manufacturing format",
                "maxLength": 5
              },
              "ACTFAB": {
                "type": "string",
                "description": "Activity after manufacturing process",
                "maxLength": 3
              },
              "CODFAB": {
                "type": "string",
                "description": "Product code after manufacturing",
                "maxLength": 17
              },
              "VRAFAB": {
                "type": "string",
                "description": "Manufactured product code (For statistics)",
                "maxLength": 17
              },
              "VALFAB": {
                "type": "string",
                "description": "Logistics variant (Gencod) of manufacturing",
                "maxLength": 2
              },
              "CODZVI": {
                "type": "string",
                "description": "Wine production area code",
                "maxLength": 4
              },
              "CODEAP": {
                "type": "string",
                "description": "Packaging code associated with the product",
                "maxLength": 3
              },
              "TOPCNA": {
                "type": "boolean",
                "description": "Products with alcohol rate for the CNAMTS",
                "default": false
              }
            }
          },
          "GEEX3002": {
            "type": "object",
            "description": "Product Additional 02 declaration",
            "additionalProperties": false,
            "properties": {
              "CODTMD": {
                "type": "string",
                "description": "Dangerous goods transport code",
                "maxLength": 4
              },
              "CODSEC": {
                "type": "string",
                "description": "Safety code (Hazardous Materials)",
                "maxLength": 4
              },
              "CODSPE": {
                "type": "boolean",
                "description": "Returnable product",
                "default": false
              },
              "UNIFAC": {
                "type": "string",
                "description": "Billing unit",
                "maxLength": 3
              },
              "COEFAC": {
                "type": "string",
                "description": "Billing coefficient",
                "pattern": "^[0-9]{1,7}\\.[0-9]{3}$",
                "examples": ["1.000"]
              },
              "SECDLV": {
                "type": "string",
                "description": "Number of safety days in addition to DLV",
                "maxLength": 3
              },
              "CODRGP": {
                "type": "string",
                "description": "Product grouping code",
                "maxLength": 17
              },
              "CODRSC": {
                "type": "string",
                "description": "Product hazard type code",
                "maxLength": 3
              },
              "PROEAP": {
                "type": "string",
                "description": "Associated packaging code for the interface",
                "maxLength": 17
              },
              "VTLPRO": {
                "type": "string",
                "description": "Indicator for product to be broken down",
                "maxLength": 1
              },
              "CIRVTL": {
                "type": "string",
                "description": "Breakdown circuit code",
                "maxLength": 3
              },
              "INFEXP": {
                "type": "string",
                "description": "Inventory number (Alcohol Customs)",
                "maxLength": 16
              },
              "CODMTR": {
                "type": "string",
                "description": "Materials accounting",
                "maxLength": 5
              },
              "TEMPRE": {
                "type": "string",
                "description": "Recommended temperature for the product",
                "maxLength": 3
              },
              "QTELOT": {
                "type": "string",
                "description": "Quantity for batch size management",
                "maxLength": 9
              },
              "UNILOT": {
                "type": "string",
                "description": "Unit for batch size management",
                "maxLength": 3
              },
              "UNIARR": {
                "type": "string",
                "description": "Upper rounding unit / 1 = Pallet, 2 = Layer, 3 = PCB, 4 = SPCB, 5 = CSU",
                "enum": ["1", "2", "3", "4", "5"]
              },
              "UNICAL": {
                "type": "string",
                "description": "Hazardous materials quantity calculation unit / 1 = Net weight, 2 = Gross weight, 3 = Volume",
                "enum": ["1", "2", "3"]
              },
              "TEMMIN": {
                "type": "string",
                "description": "Minimum temperature",
                "maxLength": 3
              },
              "TEMMAX": {
                "type": "string",
                "description": "Maximum temperature",
                "maxLength": 3
              },
              "TOLPOI": {
                "type": "string",
                "description": "Package weight deviation tolerance",
                "maxLength": 3
              },
              "COECOL": {
                "type": "string",
                "description": "Package expansion coefficient",
                "pattern": "^[0-9]{1}\\.[0-9]{3}$",
                "examples": ["1.000"]
              },
              "COESPC": {
                "type": "string",
                "description": "SPCB expansion coefficient",
                "pattern": "^[0-9]{1}\\.[0-9]{3}$",
                "examples": ["1.000"]
              },
              "COEUVC": {
                "type": "string",
                "description": "CSU expansion coefficient",
                "pattern": "^[0-9]{1}\\.[0-9]{3}$",
                "examples": ["1.000"]
              },
              "INDTOL": {
                "type": "boolean",
                "description": "Weight tolerance indicator",
                "default": false
              },
              "HAUSPC": {
                "type": "integer",
                "description": "SPCB height",
                "minimum": 0,
                "maximum": 999
              },
              "LNGSPC": {
                "type": "integer",
                "description": "SPCB length expressed in cm",
                "minimum": 0,
                "maximum": 999
              },
              "LRGSPC": {
                "type": "integer",
                "description": "SPCB width expressed in cm",
                "minimum": 0,
                "maximum": 999
              },
              "PDBSPC": {
                "type": "number",
                "description": "SPCB gross weight in kg",
                "minimum": 0,
                "maximum": 9999.999,
                "multipleOf": 0.001
              },
              "CODMDT": {
                "type": "string",
                "description": "Traceability method code",
                "maxLength": 3
              },
              "ETIMTR": {
                "type": "string",
                "description": "Materials labeling code",
                "maxLength": 3
              },
              "CODPHR": {
                "type": "string",
                "description": "Risk phrase code",
                "maxLength": 3
              },
              "NBJFVI": {
                "type": "string",
                "description": "Product shelf life",
                "maxLength": 4
              },
              "CODGAM": {
                "type": "string",
                "description": "Operation range code",
                "maxLength": 10
              },
              "CODQLP": {
                "type": "string",
                "description": "Product qualifier code",
                "maxLength": 3
              },
              "EMBCLQ": {
                "type": "string",
                "description": "LQ packaging type",
                "enum": ["1", "2"]
              },
              "CTRPRP": {
                "type": "boolean",
                "description": "Quantity control during preparation / false = Non-systematic, true = Systematic",
                "default": false
              },
              "CODRDS": {
                "type": "string",
                "description": "Storage restriction code",
                "maxLength": 3
              },
              "HAUCOL2": {
                "type": "number",
                "description": "Package height expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "HAUCOU2": {
                "type": "number",
                "description": "Layer height expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "HAUSPC2": {
                "type": "number",
                "description": "SPCB height in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "HAUUVC2": {
                "type": "number",
                "description": "CSU height expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LNGCOL2": {
                "type": "number",
                "description": "Package length expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LNGSPC2": {
                "type": "number",
                "description": "SPCB length expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LNGUVC2": {
                "type": "number",
                "description": "CSU length expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LRGCOL2": {
                "type": "number",
                "description": "Package width expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LRGSPC2": {
                "type": "number",
                "description": "SPCB width expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "LRGUVC2": {
                "type": "number",
                "description": "CSU width expressed in cm",
                "minimum": 0,
                "maximum": 999.99,
                "multipleOf": 0.01
              },
              "CODMNN": {
                "type": "string",
                "description": "Handling rule code",
                "maxLength": 3
              }
            }
          },
          "GEEX3003": {
            "type": "object",
            "description": "Product Additional 03 declaration",
            "additionalProperties": false,
            "properties": {
              "CODCVI": {
                "type": "string",
