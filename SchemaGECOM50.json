          "GEEX5020": {
            "type": "array",
            "description": "Delivery Order Lines (Mandatory)",
            "minItems": 1,
            "maxItems": 999,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "NLILIV": {
                  "type": "string",
                  "description": "Line number for the delivery interface",
                  "pattern": "^[0-9]{1,5}$"
                },
                "CODPRO": {
                  "type": "string",
                  "description": "Internal product code",
                  "minLength": 1,
                  "maxLength": 17
                },
                "VALPRO": {
                  "type": "string",
                  "description": "Logistics variant (Gencod)",
                  "pattern": "^[0-9]{1,2}$"
                },
                "METRPL": {
                  "type": "string",
                  "description": "Product replacement method / 0 = No replacement, 1 = Replaced by, 2 = Substituted by",
                  "enum": ["0", "1", "2"],
                  "default": "0"
                },
                "CODRPL": {
                  "type": "string",
                  "description": "Replacement product code",
                  "maxLength": 17
                },
                "VALRPL": {
                  "type": "string",
                  "description": "Replacement product NAV",
                  "pattern": "^[0-9]{1,2}$"
                },
                "CODPRN": {
                  "type": "string",
                  "description": "Bill of materials product code",
                  "maxLength": 17
                },
                "UVCCDE": {
                  "type": "integer",
                  "description": "Number of ordered CSUs",
                  "minimum": 0,
                  "maximum": 999999999
                },
                "UNICDE": {
                  "type": "string",
                  "description": "Order quantity input unit",
                  "maxLength": 3
                },
                "TYPSTK": {
                  "type": "string",
                  "description": "Stock type (tool or retention) / 1 = Tool stock, 2 = Retention stock",
                  "enum": ["1", "2"],
                  "default": "1"
                },
                "AIGPRI": {
                  "type": "boolean",
                  "description": "Switch for price marking control / false = Unmarked product, true = Marked product",
                  "default": false
                },
                "PRILIV": {
                  "type": "string",
                  "description": "Price marked on the product to be stamped",
                  "pattern": "^[0-9]{1,5}\\.[0-9]{3}$"
                },
                "TYPOPE": {
                  "type": "string",
                  "description": "Operation type (e.g.: Promotion, reservation) / 0 = Normal, 1 = Promotion, 2 = Reservation, 4 = Promo Circuit",
                  "enum": ["0", "1", "2", "4"],
                  "default": "0"
                },
                "NUMOPE": {
                  "type": "string",
                  "description": "Operation number (Promo or reservation)",
                  "pattern": "^[0-9]{1,6}$"
                },
                "SPCPRO": {
                  "type": "integer",
                  "description": "Product sub-quantity",
                  "minimum": 0,
                  "maximum": 9999
                },
                "PCBPRO": {
                  "type": "integer",
                  "description": "Product quantity",
                  "minimum": 0,
                  "maximum": 99999
                },
                "CODLOT": {
                  "type": "string",
                  "description": "Stored batch code",
                  "maxLength": 20
                },
                "MSGLIG": {
                  "type": "string",
                  "description": "Line-by-line message printed on the delivery note",
                  "maxLength": 30
                },
                "UVCINI": {
