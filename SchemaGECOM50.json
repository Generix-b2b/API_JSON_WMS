                  "description": "Number of initially ordered CSUs",
                  "minimum": 0,
                  "maximum": 999999999
                },
                "QTECDE": {
                  "type": "string",
                  "description": "Quantity ordered in the specified unit",
                  "pattern": "^[0-9]{1,9}$"
                },
                "DATFVI2": {
                  "type": "string",
                  "description": "Product end-of-useful-life date (until)",
                  "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
                },
                "IMMFRG": {
                  "type": "string",
                  "description": "Reason for forced immobilization",
                  "maxLength": 3
                },
