{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom06/SchemaGECOM06.json",
  "title": "GECOM06 - Goods Blocking/Unblocking Request",
  "title_es": "GECOM06 - Solicitud de bloqueo/desbloqueo de mercancía",
  "title_en": "GECOM06 - Goods Blocking/Unblocking Request",
  "x-wms-icon": "GECOM06",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m06_blockUnblock?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.1-BETA",
    "releaseDate": "2026-07-22"
  },
  "description": "JSON for Goods Blocking/Unblocking Request",
  "description_es": "JSON para Solicitud de bloqueo/desbloqueo de mercancía",
  "description_en": "JSON for Goods Blocking/Unblocking Request",
  "type": "object",
  "properties": {
    "blockingUnblockingRequest": {
      "description": "Goods Blocking/Unblocking Request",
      "description_es": "Solicitud de bloqueo/desbloqueo de mercancía",
      "description_en": "Goods Blocking/Unblocking Request",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX0600"
			}
    }
  },
  "required": ["blockingUnblockingRequest"],
  "additionalProperties": false,
  "$defs": {
    "GEEX0600": {
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODPAL": {
          "description": "Stored pallet code per EAN128 standards",
          "description_es": "Código de palé almacenado según estándares EAN128",
          "description_en": "Stored pallet code per EAN128 standards",
          "type": "string",
          "maxLength": 18
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "description_es": "Motivo de inmovilización",
          "description_en": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "CODTRT": {
          "description": "Processing Code - See EnumCODTRT",
          "description_es": "Código de tratamiento - Ver EnumCODTRT",
          "description_en": "Processing Code - See EnumCODTRT",
          "$ref": "#/$defs/Enums/EnumCODTRT"
        },
        "NUMPAL": {
          "description": "Stored pallet number",
          "description_es": "Número de palé almacenado",
          "description_en": "Stored pallet number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "CODLOT": {
          "description": "Stored batch code",
          "description_es": "Código de lote almacenado",
          "description_en": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "description_es": "Código de cliente propietario del stock",
          "description_en": "Stock owner customer code",
          "type": "string",
          "maxLength": 14
        },
        "CODPRO": {
          "description": "Product code",
          "description_es": "Código del producto",
          "description_en": "Product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant",
          "description_es": "Variante logística",
          "description_en": "Logistics variant",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "DATFVI": {
          "description": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "description_es": "Fecha de fin de vida del producto (obsolescencia) (formato AAAAMMDD)",
          "description_en": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "description_es": "Código de producto para EDI",
          "description_en": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "DATIMM2": {
          "description": "Immobilization end date (format YYYYMMDD)",
          "description_es": "Fecha de fin de inmovilización (formato AAAAMMDD)",
          "description_en": "Immobilization end date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUIMM2": {
          "description": "Immobilization end time (format HHMMSS)",
          "description_es": "Hora de fin de inmovilización (formato HHMMSS)",
          "description_en": "Immobilization end time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "description_es": "Cantidad de embalaje del producto",
          "description_en": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "CODDDO": {
          "description": "Originator code",
          "description_es": "Código del originador",
          "description_en": "Originator code",
          "type": "string",
          "maxLength": 14
        },
        "MLTSIT": {
          "description": "Message sent to all sites / false = no, true = yes",
          "description_es": "Intercambio enviado a todos los centros / false = no, true = si",
          "description_en": "Message sent to all sites / false = no, true = yes",
          "type": "boolean"
        },
        "REFBKL": {
          "description": "Blacklist Reference",
          "description_es": "Referencia de la Blacklist",
          "description_en": "Blacklist Reference",
          "type": "string",
          "maxLength": 30
        },
        "HEUTRT": {
          "description": "Processing Time (format HHMMSS)",
          "description_es": "Hora de procesamiento (formato HHMMSS)",
          "description_en": "Processing Time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "CODUTI": {
          "description": "Code of the User Responsible for the Movement",
          "description_es": "Código del usuario responsable del movimiento",
          "description_en": "Code of the User Responsible for the Movement",
          "type": "string",
          "maxLength": 10
        },
        "IDEMSG": {
          "description": "Message Identifier",
          "description_es": "Identificador del mensaje",
          "description_en": "Message Identifier",
          "type": "string",
          "maxLength": 30
        }
      },
      "required": ["RCTEXC", "TRTEXC", "CODPAL", "CODACT", "CODPRO"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "description_es": "Código de procesamiento del movimiento / 1 = Crear, 2 = Modificar o crear, 9 = Cancelación",
        "description_en": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "9"],
        "default": "2"
      },
      "EnumCODTRT": {
        "description": "Processing Code / 1 = Goods Blocking Request, 2 = Goods Unblocking Request, 3 = Lot Blocking, 4 = Lot Unblocking",
        "description_es": "Código de tratamiento / 1= Solicitud de bloqueo de mercancía, 2 = Solicitud de desbloqueo de mercancía, 3 = Bloqueo de un lote, 4 = Desbloqueo de un lote",
        "description_en": "Processing Code / 1 = Goods Blocking Request, 2 = Goods Unblocking Request, 3 = Lot Blocking, 4 = Lot Unblocking",
        "type": "string",
        "enum": ["1", "2", "3", "4"]
      }
    } 
  }
}