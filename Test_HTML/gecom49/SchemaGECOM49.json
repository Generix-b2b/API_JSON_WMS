                    "REFLIV": {
                      "type": "string",
                      "description": "Delivery reference",
                      "minLength": 1,
                      "maxLength": 30
                    },
                    "NLILIV": {
                      "type": "string",
                      "description": "Line number for delivery interface",
                      "pattern": "^[0-9]{1,5}$"
                    },
                    "DS1PRO": {
                      "type": "string",
                      "description": "Product designation line 1",
                      "maxLength": 30
                    },
                    "DS2PRO": {
                      "type": "string",
                      "description": "Product designation line 2",
                      "maxLength": 30
                    },
                    "TOPLIV": {
                      "type": "array",
                      "description": "Indicators for specific users",
                      "minItems": 0,
                      "maxItems": 5,
                      "items": {
                        "type": "string",
                        "description": "Indicators for specific users",
                        "maxLength": 1
                      }
                    },
                    "PDBLIV": {
                      "type": "number",
                      "description": "Gross weight delivered",
                      "minimum": 0,
                      "maximum": 99999999.999,
                      "multipleOf": 0.001
                    },
                    "VOLCOL": {
                      "type": "string",
                      "description": "Package volume expressed in dm3",
                      "pattern": "^[0-9]{1,4}\\.[0-9]{3}$"
                    },
                    "CODTLI": {
                      "type": "string",
                      "description": "Delivery type code",
                      "maxLength": 3
                    }
                  },
                  "required": ["REFLIV", "NLILIV"]
