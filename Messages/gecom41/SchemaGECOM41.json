          "pattern": "^[0-9]{1,3}$"
        },
        "NUMPAL": {
          "description": "Stored pallet number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "SNUPAL": {
          "description": "Stored pallet sub-number",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "NUMSER": {
          "description": "Serial number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
