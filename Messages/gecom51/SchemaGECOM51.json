{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom51/SchemaGECOM51.json",
  "title": "GECOM51 - Delivery Order Confirmation",
  "x-wms-icon": "GECOM51",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client]/endpoint",
    "category": "Outbound",
    "version": "v1.1-Beta",
    "releaseDate": "2026-06-22"
  },
  "description": "JSON for delivery order confirmation feedback from the WMS",
  "type": "object",
  "properties": {
    "confirmationDeliveryOrders": {
      "description": "Delivery order confirmation header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX5100"
      }
    }
  },
  "required": [
    "confirmationDeliveryOrders"
  ],
  "$defs": {
    "GEEX5100": {
      "description": "Delivery order confirmation header",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "NUMLIV": {
          "description": "Order number to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNULIV": {
          "description": "Sub-number of the order to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Customer code (Ordered by)",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "REFLIV": {
          "description": "Delivery reference",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "CODTLI": {
          "description": "Delivery type code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODACL": {
          "description": "Delivery order cancellation code",
          "type": "string",
          "maxLength": 3
        },
        "ORICDE": {
          "description": "Order origin - see EnumORICDE",
          "$ref": "#/$defs/Enums/EnumORICDE"
        },
        "DATLIV": {
          "description": "Order delivery date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEULIV": {
          "description": "Order delivery time (format HHMM)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])$",
          "examples": [
            "0930"
          ]
        },
        "CLILIV": {
          "description": "Customer code to deliver (Delivered to)",
          "type": "string",
          "maxLength": 14
        },
        "TYPLIV": {
          "description": "Shipping mode - see EnumTYPLIV",
          "$ref": "#/$defs/Enums/EnumTYPLIV"
        },
        "NUMVAG": {
          "description": "Preparation wave number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "DATPRP": {
          "description": "Wave preparation date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "CODRGT": {
          "description": "Region code for transport",
          "type": "string",
          "maxLength": 3
        },
        "TOULIV": {
          "description": "Goods delivery round",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "ORDLIV": {
          "description": "Delivery order in the round",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "NUMTOU": {
          "description": "Goods dispatch number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "DATEXP": {
          "description": "Goods dispatch date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUEXP": {
          "description": "Goods dispatch time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "093000"
          ]
        },
        "CODTRA": {
          "description": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "CODCAM": {
          "description": "Truck code (e.g.: license plate)",
          "type": "string",
          "maxLength": 14
        },
        "CODCHF": {
          "description": "Delivery driver code",
          "type": "string",
          "maxLength": 10
        },
        "CTRLIV": {
          "description": "Delivery control number",
          "type": "string",
          "maxLength": 10
        },
        "REFCNT": {
          "description": "Container reference",
          "type": "string",
          "maxLength": 10
        },
        "CODSIT": {
          "description": "Storage site code",
          "type": "string",
          "maxLength": 3
        },
        "NUMPLB": {
          "description": "Seal numbers",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Seal number",
            "type": "string",
            "maxLength": 8
          }
        },
        "CODLDR": {
          "description": "Reception/shipping location code",
          "type": "string",
          "maxLength": 3
        },
        "LIVSOL": {
          "description": "Settled delivery indicator / false = Not settled (remaining to deliver), true = Settled delivery",
          "type": "boolean",
          "default": false
        },
        "NUMCNT": {
          "description": "Container number",
          "type": "string",
          "maxLength": 17
        },
        "NUMTPT": {
          "description": "Delivery note number (transport note)",
          "type": "string",
          "pattern": "^[0-9]{1,10}$"
        },
        "INDRLQ": {
          "description": "Backorder presence indicator / false = No backorder generated, true = Backorder generated",
          "type": "boolean",
          "default": false
        },
        "GEEX5101": {
          "description": "Delivery confirmation additional header information",
          "$ref": "#/$defs/GEEX5101Wrapper"
        },
        "GEEX5105": {
          "description": "Order associated attributes",
          "type": "array",
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/GEEX5105Wrapper"
          }
        },
        "GEEX5110": {
          "description": "Delivery order header (if VPC address)",
          "$ref": "#/$defs/GEEX5110Wrapper"
        },
        "GEEX5120": {
          "description": "Delivered lines",
          "type": "array",
          "maxItems": 999,
          "items": {
            "$ref": "#/$defs/GEEX5120Wrapper"
          }
        },
        "GEEX5199": {
          "description": "Delivery confirmation totals",
          "$ref": "#/$defs/GEEX5199Wrapper"
        }
      },
      "required": [
        "CODACT",
        "CODCLI",
        "REFLIV",
        "CODTLI",
        "DATLIV",
        "LIVSOL"
      ],
      "additionalProperties": false
    },
    "GEEX5101Wrapper": {
      "description": "Delivery confirmation additional header information",
      "type": "object",
      "properties": {
        "TOPLIV": {
          "description": "Indicators for specific users",
          "type": "array",
          "maxItems": 5,
          "items": {
            "description": "Indicator for specific users",
            "type": "string",
            "maxLength": 1
          }
        },
        "DIPLIV": {
          "description": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "DATDEP": {
          "description": "Ship departure date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "CODNAV": {
          "description": "Ship code",
          "type": "string",
          "maxLength": 5
        },
        "LIBNAV": {
          "description": "Ship label",
          "type": "string",
          "maxLength": 30
        },
        "DATARR": {
          "description": "Ship arrival date",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "CODCIE": {
          "description": "Company code",
          "type": "string",
          "maxLength": 5
        },
        "NOMCIE": {
          "description": "Company name",
          "type": "string",
          "maxLength": 30
        },
        "TYPCNT": {
          "description": "Container type",
          "type": "string",
          "maxLength": 2
        },
        "CODTRS": {
          "description": "Departure forwarder code",
          "type": "string",
          "maxLength": 5
        },
        "NOMTRS": {
          "description": "Forwarder name",
          "type": "string",
          "maxLength": 30
        },
        "OPEDEP": {
          "description": "Truck departure top operator",
          "type": "string",
          "maxLength": 10
        },
        "TYPDSV": {
          "description": "DESADV type - see EnumTYPDSV",
          "$ref": "#/$defs/Enums/EnumTYPDSV"
        },
        "CUMVTE": {
          "description": "Sale valuation total (transport)",
          "type": "string",
          "pattern": "^[0-9]{1,8}\\.[0-9]{3}$",
          "examples": [
            "1000.000"
          ]
        },
        "ECRUTI": {
          "description": "User screen code",
          "type": "string",
          "maxLength": 10
        },
        "REFMIT": {
          "description": "Mission reference",
          "type": "string",
          "maxLength": 30
        },
        "CODCNT": {
          "description": "Container code (e.g.: wagon no., container no.)",
          "type": "string",
          "maxLength": 14
        },
        "EDITRA": {
          "description": "Carrier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDICLI": {
          "description": "Customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDICLF": {
          "description": "Final customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "REFCLI": {
          "description": "Recipient's order reference",
          "type": "string",
          "maxLength": 30
        },
        "PDVCNT": {
          "description": "Empty container weight",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "REFDAE": {
          "description": "DAE reference",
          "type": "string",
          "maxLength": 30
        },
        "DISEXC": {
          "description": "Area available for future use",
          "type": "string",
          "maxLength": 6
        },
        "NUMSHP": {
          "description": "Shipment number",
          "type": "string",
          "maxLength": 20
        },
        "HEUDEP": {
          "description": "Departure time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "093000"
          ]
        },
        "GABCNT": {
          "description": "Container template",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "DATCHT": {
          "description": "Latest loading date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
        "HEUCHT": {
          "description": "Loading time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": [
            "093001"
          ]
        },
        "TYPTTR": {
          "description": "Transit type",
          "type": "string",
          "maxLength": 3
        },
        "INFCPL": {
          "description": "Additional information",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Additional information",
            "type": "string",
            "maxLength": 35
          }
        },
        "SITDES": {
          "description": "Recipient site",
          "type": "array",
          "maxItems": 1,
          "items": {
            "description": "Recipient site",
            "type": "string",
            "maxLength": 3
          }
        },
        "REFPLB": {
          "description": "Seal number",
          "type": "array",
          "maxItems": 1,
          "items": {
            "description": "Seal number",
            "type": "string",
            "maxLength": 10
          }
        }
      },
      "additionalProperties": false
    },
    "GEEX5105Wrapper": {
      "description": "Order associated attributes",
      "type": "object",
      "properties": {
        "CODRUB": {
          "description": "Section code",
          "type": "string",
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value",
          "type": "string",
          "maxLength": 35
        }
      },
      "required": [
        "CODRUB",
        "VALRUB"
      ],
      "additionalProperties": false
    },
    "GEEX5110Wrapper": {
      "description": "Delivery order header (VPC address)",
      "type": "object",
      "properties": {
        "NOMCLI": {
          "description": "Customer name",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "AD1CLI": {
          "description": "Customer address line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2CLI": {
          "description": "Customer address line 2",
          "type": "string",
          "maxLength": 38
        },
        "AD3CLI": {
          "description": "Customer address line 3",
          "type": "string",
          "maxLength": 38
        },
        "CPOCLI": {
          "description": "Customer postal code",
          "type": "string",
          "minLength": 1,
          "pattern": "^[0-9]{1,5}$"
        },
        "VILCLI": {
          "description": "Customer city",
          "type": "string",
          "minLength": 1,
          "maxLength": 26
        },
        "TELCLI": {
          "description": "Customer phone number",
          "type": "string",
          "maxLength": 20
        },
        "PAYCLI": {
          "description": "Customer country code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CPICLI": {
          "description": "Customer postal code (international format)",
          "type": "string",
          "maxLength": 9
        },
        "CATCLI": {
          "description": "Customer category (e.g.: network)",
          "type": "string",
          "maxLength": 3
        },
        "CLICPI": {
          "description": "Customer postal code (international format)",
          "type": "string",
          "maxLength": 10
        }
      },
      "required": ["NOMCLI", "AD1CLI", "CPOCLI", "VILCLI", "PAYCLI"],
      "additionalProperties": false
    },
    "GEEX5120Wrapper": {
      "description": "Delivered lines",
      "type": "object",
      "properties": {
        "NLILIV": {
          "description": "Line number for the delivery interface",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODPRO": {
          "description": "Internal product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "UVCCDE": {
          "description": "Number of ordered CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "UNICDE": {
          "description": "Order quantity input unit",
          "type": "string",
          "maxLength": 3
        },
        "LIVSOL": {
          "description": "Settled line indicator / false = Not settled (remaining to deliver), true = Settled order line",
          "type": "boolean",
          "default": false
        },
        "UVCLIV": {
          "description": "Number of delivered CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "MESPRO": {
          "description": "Product measurement method - see EnumMESPRO",
          "$ref": "#/$defs/Enums/EnumMESPRO"
        },
        "PDNLIV": {
          "description": "Net weight delivered (variable weight valuation)",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "CODACL": {
          "description": "Delivery line cancellation code",
          "type": "string",
          "maxLength": 3
        },
        "MOTMVT": {
          "description": "Delivery discrepancy reason",
          "type": "string",
          "maxLength": 3
        },
        "TYPSTK": {
          "description": "Stock type (tool or retention) - see EnumTYPSTK",
          "$ref": "#/$defs/Enums/EnumTYPSTK"
        },
        "TYPOPE": {
          "description": "Operation type - see EnumTYPOPE",
          "$ref": "#/$defs/Enums/EnumTYPOPE"
        },
        "NUMOPE": {
          "description": "Operation number (Promo or reservation)",
          "type": "string",
          "pattern": "^[0-9]{1,6}$"
        },
        "SPCPRO": {
          "description": "Product sub-pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "DIPLIV": {
          "description": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "UVCSRV": {
          "description": "Number of CSUs served in the wave",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "UVCINI": {
          "description": "Number of initially ordered CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "NUMEBL": {
          "description": "Order number for BL - Invoice consistency",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNUEBL": {
          "description": "Order sub-number for BL - Invoice consistency",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "INDPRO": {
          "description": "Configurable product indicators",
          "type": "array",
          "maxItems": 10,
          "items": {
            "description": "Configurable product indicators",
            "type": "string",
            "maxLength": 1
          }
        },
        "GEEX5121": {
          "description": "Delivered line optional information",
          "$ref": "#/$defs/GEEX5121Wrapper"
        },
        "GEEX5125": {
          "description": "Imposed sections on delivered line",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5125Wrapper"
          }
        },
        "GEEX5130": {
          "description": "Support detail",
          "type": "array",
          "maxItems": 999,
          "items": {
            "$ref": "#/$defs/GEEX5130Wrapper"
          }
        }
      },
      "required": [
        "NLILIV",
        "CODPRO",
        "UVCCDE",
        "LIVSOL",
        "UVCLIV",
        "UVCSRV",
        "UVCINI"
      ],
      "additionalProperties": false
    },
    "GEEX5121Wrapper": {
      "description": "Delivered line optional information",
      "type": "object",
      "properties": {
        "CODOPE": {
          "description": "Operation code (Promo or reservation)",
          "type": "string",
          "maxLength": 14
        },
        "CODRPL": {
          "description": "Replacement product code",
          "type": "string",
          "maxLength": 17
        },
        "VALRPL": {
          "description": "Logistics variant of the replacement product",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "EDIRPL": {
          "description": "EDI code for replacement product",
          "type": "string",
          "maxLength": 17
        }
      },
      "additionalProperties": false
    },
    "GEEX5125Wrapper": {
      "description": "Imposed sections on delivered line",
      "type": "object",
      "properties": {
        "TYPRUB": {
          "description": "Section type - see EnumTYPRUB",
          "$ref": "#/$defs/Enums/EnumTYPRUB"
        },
        "CODRUB": {
          "description": "Section code",
          "type": "string",
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value",
          "type": "string",
          "maxLength": 35
        },
        "SIGMIN": {
          "description": "Minimum value sign / false = Positive value, true = Negative value",
          "type": "boolean",
          "default": false
        },
        "VALMIN": {
          "description": "Minimum value of the imposed section",
          "type": "string",
          "pattern": "^[0-9]{1,13}\\.[0-9]{5}$",
          "examples": [
            "100.00000"
          ]
        },
        "SIGMAX": {
          "description": "Maximum value sign / false = Positive value, true = Negative value",
          "type": "boolean",
          "default": false
        },
        "VALMAX": {
          "description": "Maximum value of the imposed section",
          "type": "string",
          "pattern": "^[0-9]{1,13}\\.[0-9]{5}$",
          "examples": [
            "100.00000"
          ]
        }
      },
      "required": [
        "CODRUB",
        "VALRUB"
      ],
      "additionalProperties": false
    },
    "GEEX5130Wrapper": {
      "description": "Support detail",
      "type": "object",
      "properties": {
        "UVCLIV": {
          "description": "Number of CSUs delivered on the support",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "PDNLIV": {
          "description": "Net weight delivered",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "MOTMVT": {
          "description": "Delivery discrepancy reason",
          "type": "string",
          "maxLength": 3
        },
        "CODLOT": {
          "description": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "NUMLOT": {
          "description": "Internal goods batch number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "CODPAL": {
          "description": "Stored pallet code per EAN128 standards",
          "type": "string",
          "maxLength": 18
        },
        "DATFVI": {
          "description": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": [
            "20250125"
          ]
        },
