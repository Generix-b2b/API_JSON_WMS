{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Schemas/SchemaGECOM97.json",
  "title": "GECOM97 - Status Orders",
  "x-wms-icon": "GECOM97",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client]/endpoint",
    "category": "Outbound",
    "version": "v1.0",
    "releaseDate": "2026-06-17"
  },
  "type": "object",
  "description": "JSON for updating the status of Reception Orders or Delivery Orders in the WMS",
  "properties": {
    "statusReceptionOrders": {
      "type": "array",
      "description": "Status Reception Orders",
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
            "enum": ["1", "2", "9"],
            "default": "2"
          },
          "EMTEXC": {
            "type": "string",
            "description": "Sender site of the information to be processed",
            "maxLength": 14
          },
          "RCTEXC": {
            "type": "string",
            "description": "Exchange recipient code",
            "maxLength": 14
          },
          "DATEXC": {
            "type": "string",
            "description": "Exchange date / format YYYYMMDD",
            "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          },
          "HEUEXC": {
            "type": "string",
            "description": "Exchange time / format HHMMSS",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
            "examples": ["143023"]
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "NUMREC": {
            "type": "string",
            "description": "Order number to be received",
            "pattern": "^[0-9]{1,8}$"
          },
          "SNUREC": {
            "type": "string",
            "description": "Sub-number of the order to be received",
            "pattern": "^[0-9]{1,3}$"
          },
          "REFREC": {
            "type": "string",
            "description": "Reception reference",
            "minLength": 1,
            "maxLength": 30
          },
          "BLOREC": {
            "type": "boolean",
            "description": "Reception block",
            "default": false
          },
          "ETAREC": {
            "type": "string",
            "description": "Reception status code / 00 = Being entered, 10 = Pending to be planned, 20 = Pending reception, 30 = Reception in progress, 35 = Distribution in progress, 40 = Received, 50 = Order Sent, 90 = Cancelled, 95 = Archived",
            "enum": ["00", "10", "20", "30", "35", "40", "50", "90", "95"]
          },
          "CODFOU": {
            "type": "string",
            "description": "Supplier code",
            "minLength": 1,
            "maxLength": 14
          },
          "CODTRE": {
            "type": "string",
            "description": "Reception type code",
            "minLength": 3,
            "maxLength": 3
          },
          "VALRUB": {
            "type": "string",
            "description": "Traceability element value array",
            "minLength": 1,
            "maxLength": 35
          }
        },
        "required": ["TRTEXC", "DATEXC", "HEUEXC", "CODACT", "REFREC", "ETAREC"]
      }
    },
    "statusDeliveryOrders": {
      "type": "array",
      "description": "Status Delivery Orders",
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
            "enum": ["1", "2", "9"],
            "default": "2"
          },
          "EMTEXC": {
            "type": "string",
            "description": "Sender site of the information to be processed",
            "maxLength": 14
          },
          "RCTEXC": {
            "type": "string",
            "description": "Exchange recipient code",
            "maxLength": 14
          },
          "DATEXC": {
            "type": "string",
            "description": "Exchange date / format YYYYMMDD",
            "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          },
          "HEUEXC": {
            "type": "string",
            "description": "Exchange time / format HHMMSS",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
            "examples": ["143023"]
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "NUMLIV": {
            "type": "string",
            "description": "Order number to be delivered",
            "pattern": "^[0-9]{1,8}$"
          },
          "SNULIV": {
            "type": "string",
            "description": "Sub-number of the order to be delivered",
            "pattern": "^[0-9]{1,3}$"
          },
          "REFLIV": {
            "type": "string",
            "description": "Delivery reference",
            "minLength": 1,
            "maxLength": 30
          },
          "BLOLIV": {
            "type": "boolean",
            "description": "Delivery block",
            "default": false
          },
          "ETALIV": {
            "type": "string",
            "description": "Delivery status code / 00 = Being entered, 10 = To be selected in a wave, 20 = Selected in a wave, 30 = Order to be prepared (extracted), 35 = Order in preparation, 40 = Order validated, 50 = Order Sent, 60 = Order dispatched, 90 = Cancelled, 95 = Archived",
            "enum": ["00", "10", "20", "30", "35", "40", "50", "60", "90", "95"]
          },
          "NUMVAG": {
            "type": "string",
            "description": "Preparation wave number",
            "minLength": 1,
            "maxLength": 8
          },
          "CODCLI": {
            "type": "string",
            "description": "Customer code",
            "minLength": 1,
            "maxLength": 14
          },
          "CODACL": {
            "type": "string",
            "description": "Code to cancel a delivery order",
            "minLength": 3,
            "maxLength": 3
          },
          "NUMTOU": {
            "type": "string",
            "description": "Round trip record number",
            "minLength": 1,
            "maxLength": 8
          },
          "ANLVAG": {
            "type": "boolean",
            "description": "Wave cancellation",
            "default": false
          },
          "RUPTOT": {
            "type": "boolean",
            "description": "Total break indicator",
            "default": false
          },
          "ACCRCP": {
            "type": "string",
            "description": "Reception access",
            "minLength": 1,
            "maxLength": 14
          },
          "CODEMT": {
            "type": "string",
            "description": "Sender code",
            "minLength": 1,
            "maxLength": 14
          },
          "KAILIV": {
            "type": "string",
            "description": "Shipping dock for loading",
            "minLength": 1,
            "maxLength": 3
          },
          "CODTLI": {
            "type": "string",
            "description": "Delivery type code",
            "minLength": 3,
            "maxLength": 3
          },
          "VALRUB": {
            "type": "string",
            "description": "Traceability element value array",
            "minLength": 1,
            "maxLength": 35
          },
          "TOULIV": {
            "type": "string",
            "description": "Goods delivery round",
            "minLength": 1,
            "maxLength": 4
          },
          "CRILIV": {
            "type": "string",
            "description": "Order extraction criteria",
            "minLength": 1,
            "maxLength": 20
          },
          "CODOFT": {
            "type": "string",
            "description": "Carrier offer code",
            "minLength": 1,
            "maxLength": 14
          }
        },
        "required": ["TRTEXC", "DATEXC", "HEUEXC", "CODACT", "REFLIV", "ETALIV"]
      }
    }
  },
  "oneOf": [
    {
      "required": ["statusReceptionOrders"]
    },
    {
      "required": ["statusDeliveryOrders"]
    }
  ]
}
