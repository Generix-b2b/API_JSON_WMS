                      "pattern": "^[0-9]{1,6}$"
                    },
                    "TYPOPE": {
                      "type": "string",
                      "description": "Operation type (e.g.: Promotion, reservation) / 0 = Normal, 1 = Promotion, 2 = Reservation, 3 = Operation code, 4 = Promo Circuit",
                      "enum": ["0","1","2","3","4"],
                      "default": "0"
                    },
                    "HEUFAB": {
                      "type": "string",
                      "description": "Manufacturing start and end times",
                      "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
                    },
                    "DATIMM": {
                      "type": "array",
                      "description": "Immobilization start and end dates",
                      "minItems": 0,
                      "maxItems": 2,
                      "items": {
                        "type": "string",
                        "description": "Immobilization start and end dates",
                        "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
                      }
                    },
                    "HEUIMM": {
                      "type": "array",
                      "description": "Immobilization start and end times",
                      "minItems": 0,
                      "maxItems": 2,
                      "items": {
                        "type": "string",
                        "description": "Immobilization start and end times",
                        "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
