                      "type": "string",
                      "description": "Product code for EDI",
                      "maxLength": 17
                    },
                    "CODOPE": {
                      "type": "string",
                      "description": "Operation code (Promo or reservation)",
                      "maxLength": 14
                    },
                    "TYPDAT": {
                      "type": "boolean",
                      "description": "Date type / false = Imposed, true = Proposed",
                      "default": false
                    },
                    "CODPPR": {
                      "type": "string",
                      "description": "Owner code",
                      "maxLength": 14
                    },
                    "CODEMB": {
                      "type": "string",
                      "description": "Package handling code",
                      "maxLength": 3
                    }
                  }
                },
                "GEEX5025": {
                  "type": "array",
                  "description": "Delivery Orders attributes line",
                  "minItems": 0,
                  "maxItems": 99,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "TYPRUB": {
                        "type": "string",
                        "description": "Header type / 1 = EDIFACT standard, 2 = Internal coding",
                        "enum": ["1", "2"],
                        "default": "1"
                      },
                      "CODRUB": {
                        "type": "string",
                        "description": "Section code",
                        "maxLength": 4
                      },
                      "VALRUB": {
                        "type": "string",
                        "description": "Traceability element value",
                        "maxLength": 35
                      },
                      "SIGMIN": {
                        "type": "boolean",
                        "description": "Minimum value sign / false = Positive value, true = Negative value",
                        "default": false
                      },
                      "VALMIN": {
                        "type": "string",
                        "description": "Minimum value of the imposed item",
                        "pattern": "^[0-9]{1,13}\\.[0-9]{5}$"
                      },
                      "SIGMAX": {
                        "type": "boolean",
                        "description": "Maximum value sign / false = Positive value, true = Negative value",
                        "default": false
                      },
                      "VALMAX": {
                        "type": "string",
                        "description": "Maximum value of the imposed section",
                        "pattern": "^[0-9]{1,13}\\.[0-9]{5}$"
                      },
                      "CODPAL": {
                        "type": "string",
                        "description": "Stored pallet code according to EAN128 standards",
                        "maxLength": 18
                      }
                    }
                  }
                }
              },
              "required": ["NLILIV", "CODPRO", "UVCCDE"]
            }
          },
          "GEEX5080": {
            "type": "array",
            "description": "Free text on delivery note",
            "minItems": 0,
            "maxItems": 99,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "SEQTXL": {
                  "type": "string",
                  "description": "Free text sequence number in the delivery note",
                  "pattern": "^[0-9]{1,4}$"
                },
                "LIBTXL": {
                  "type": "string",
                  "description": "Free text label in the delivery note",
                  "minLength": 1,
                  "maxLength": 120
                }
              },
              "required": ["SEQTXL", "LIBTXL"]
            }
          }
        },
        "required": ["TRTEXC", "REFLIV", "CODTLI", "CODACT", "CODCLI", "DTILIV", "HEILIV", "CUMLIG"]
      }
    }
  },
  "required": ["deliveryOrders"]
}