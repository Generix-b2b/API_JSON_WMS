{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom49/SchemaGECOM49.json",
  "title": "GECOM49 - Dispatch Advice",
  "title_es": "GECOM49 - Aviso de expedición",
  "title_en": "GECOM49 - Dispatch Advice",
  "x-wms-icon": "GECOM49",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m49_dispatchAdvice?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.2",
    "releaseDate": "2026-07-03"
  },
  "description": "JSON for creating a Dispatch Advice",
  "description_es": "JSON para la creación de un aviso de expedición",
  "description_en": "JSON for creating a Dispatch Advice",
  "type": "object",
  "properties": {
    "dispatchAdvices": {
      "description": "Dispatch Advice Header",
      "description_es": "Cabecera del aviso de expedición",
      "description_en": "Dispatch Advice Header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX4900"
      }
    }
  },
  "required": ["dispatchAdvices"],
  "additionalProperties": false,
  "$defs": {
    "GEEX4900": {
      "description": "Dispatch Advice Header",
      "description_es": "Cabecera del aviso de expedición",
      "description_en": "Dispatch Advice Header",
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODFOU": {
          "description": "Supplier code",
          "description_es": "Código de proveedor",
          "description_en": "Supplier code",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "AVIREF": {
          "description": "Dispatch advice reference",
          "description_es": "Referencia del aviso de expedición",
          "description_en": "Dispatch advice reference",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "REFLET": {
          "description": "Waybill number",
          "description_es": "Número de carta de porte",
          "description_en": "Waybill number",
          "type": "string",
          "maxLength": 10
        },
        "EDIFOU": {
          "description": "Supplier code for EDI",
          "description_es": "Código de proveedor para EDI",
          "description_en": "Supplier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDIACT": {
          "description": "Warehouse code for EDI",
          "description_es": "Código de almacén para EDI",
          "description_en": "Warehouse code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDITRA": {
          "description": "Carrier code for EDI",
          "description_es": "Código de transportista para EDI",
          "description_en": "Carrier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "CODTRA": {
          "description": "Carrier code",
          "description_es": "Código de transportista",
          "description_en": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "DATEXP": {
          "description": "Goods dispatch date (format YYYYMMDD)",
          "description_es": "Fecha de expedición de mercancías (formato AAAAMMDD)",
          "description_en": "Goods dispatch date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXP": {
          "description": "Goods dispatch time (format HHMMSS)",
          "description_es": "Hora de expedición de mercancías (formato HHMMSS)",
          "description_en": "Goods dispatch time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "DATLIV": {
          "description": "Order delivery date (format YYYYMMDD)",
          "description_es": "Fecha de entrega de la orden (formato AAAAMMDD)",
          "description_en": "Order delivery date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEULIV": {
          "description": "Order delivery time (format HHMMSS)",
          "description_es": "Hora de entrega de la orden (formato HHMMSS)",
          "description_en": "Order delivery time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "TYPTPT": {
          "description": "Transport type",
          "description_es": "Tipo de transporte",
          "description_en": "Transport type",
          "type": "string",
          "maxLength": 3
        },
        "TYPCHT": {
          "description": "Loading type",
          "description_es": "Tipo de carga",
          "description_en": "Loading type",
          "type": "string",
          "maxLength": 3
        },
        "REFPLB": {
          "description": "Seal number",
          "description_es": "Número de precinto",
          "description_en": "Seal number",
          "type": "string",
          "maxLength": 10
        },
        "CAMCOD": {
          "description": "Truck number",
          "description_es": "Número de camión",
          "description_en": "Truck number",
          "type": "string",
          "maxLength": 20
        },
        "DIPAVI": {
          "description": "Data transit area between software",
          "description_es": "Zona de tránsito de datos entre software",
          "description_en": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "SITRCT": {
          "description": "Reception site code (recipient's warehouse)",
          "description_es": "Código de sitio de recepción (almacén del destinatario)",
          "description_en": "Reception site code (recipient's warehouse)",
          "type": "string",
          "maxLength": 3
        },
        "CRERCP": {
          "description": "Reception creation / false = No, true = Yes",
          "description_es": "Creación de recepción / false = No, true = Sí",
          "description_en": "Reception creation / false = No, true = Yes",
          "type": "boolean",
          "default": false
        },
        "NUMTOU": {
          "description": "Tour record number",
          "description_es": "Número de registro del recorrido",
          "description_en": "Tour record number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "INDSBY": {
          "description": "Indicator for putting DESADV on hold - see EnumINDSBY",
          "description_es": "Indicador para poner el DESADV en espera - ver EnumINDSBY",
          "description_en": "Indicator for putting DESADV on hold - see EnumINDSBY",
          "$ref": "#/$defs/Enums/EnumINDSBY"
        },
        "CODTRE": {
          "description": "Reception type code",
          "description_es": "Código de tipo de recepción",
          "description_en": "Reception type code",
          "type": "string",
          "maxLength": 3
        },
        "TYPRMT": {
          "description": "Feedback type - see EnumTYPRMT",
          "description_es": "Tipo de retorno - ver EnumTYPRMT",
          "description_en": "Feedback type - see EnumTYPRMT",
          "$ref": "#/$defs/Enums/EnumTYPRMT"
        },
        "CUMLIG": {
          "description": "Total number of lines in the order",
          "description_es": "Número total de líneas de la orden",
          "description_en": "Total number of lines in the order",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "GEEX4905": {
          "description": "Dispatch advice associated attributes",
          "description_es": "Atributos asociados al aviso de expedición",
          "description_en": "Dispatch advice associated attributes",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4905Wrapper"
          }
        },
        "GEEX4910": {
          "description": "Logistics object header",
          "description_es": "Cabecera del objeto logístico",
          "description_en": "Logistics object header",
          "type": "array",
          "minItems": 1,
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4910Wrapper"
          }
        }
      },
      "required": ["RCTEXC", "TRTEXC", "CODFOU", "AVIREF", "CODACT", "DATEXP", "CUMLIG"],
      "if": {
        "properties": {
          "TRTEXC": { "enum": ["1","2"] }
        },
        "required": ["TRTEXC"]
      },
      "then": {
        "required": ["GEEX4910"]
      },
      "additionalProperties": false
    },
    "GEEX4905Wrapper": {
      "type": "object",
      "properties": {
        "CODRUB": {
          "description": "Section code",
          "description_es": "Código de sección",
          "description_en": "Section code",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value",
          "description_es": "Valor del elemento de trazabilidad",
          "description_en": "Traceability element value",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "GEEX4910Wrapper": {
      "description": "Logistics object header",
      "description_es": "Cabecera del objeto logístico",
      "description_en": "Logistics object header",
      "type": "object",
      "properties": {
        "CODOBL": {
          "description": "Logistics object code",
          "description_es": "Código del objeto logístico",
          "description_en": "Logistics object code",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        },
        "AVINLI": {
          "description": "Dispatch advice line number",
          "description_es": "Número de línea del aviso de expedición",
          "description_en": "Dispatch advice line number",
          "type": "string",
          "pattern": "^[0-9]{1,12}$"
        },
        "CUMCOL": {
          "description": "Total number of packages",
          "description_es": "Número total de paquetes",
          "description_en": "Total number of packages",
          "type": "string",
          "pattern": "^[0-9]{1,7}$"
        },
        "TYPMQG": {
          "description": "Marking type",
          "description_es": "Tipo de marcado",
          "description_en": "Marking type",
          "type": "string",
          "maxLength": 3
        },
        "CODEB1": {
          "description": "Handling packaging code",
          "description_es": "Código de embalaje de manipulación",
          "description_en": "Handling packaging code",
          "type": "string",
          "maxLength": 3
        },
        "CODEB2": {
          "description": "Packaging code associated with packing",
          "description_es": "Código de embalaje asociado al empaquetado",
          "description_en": "Packaging code associated with packing",
          "type": "string",
          "maxLength": 3
        },
        "PDBOBL": {
          "description": "Weight of the logistics object",
          "description_es": "Peso del objeto logístico",
          "description_en": "Weight of the logistics object",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "UNIPDB": {
          "description": "Weight measurement unit",
          "description_es": "Unidad de medida de peso",
          "description_en": "Weight measurement unit",
          "type": "string",
          "maxLength": 3
        },
        "LNGOBL": {
          "description": "Length of the logistics object",
          "description_es": "Longitud del objeto logístico",
          "description_en": "Length of the logistics object",
          "type": "string",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]
        },
        "LRGOBL": {
          "description": "Width of the logistics object",
          "description_es": "Anchura del objeto logístico",
          "description_en": "Width of the logistics object",
          "type": "string",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]
        },
        "HAUOBL": {
          "description": "Height of the logistics object",
          "description_es": "Altura del objeto logístico",
          "description_en": "Height of the logistics object",
          "type": "string",
          "pattern": "^[0-9]{1,9}\\.[0-9]{2}$",
          "examples": ["120.00"]            
        },
        "UNIDIM": {
          "description": "Dimensions measurement unit",
          "description_es": "Unidad de medida de dimensiones",
          "description_en": "Dimensions measurement unit",
          "type": "string",
          "maxLength": 3
        },
        "DATCRE": {
          "description": "Creation date (format YYYYMMDD)",
          "description_es": "Fecha de creación (formato AAAAMMDD)",
          "description_en": "Creation date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUCRE": {
          "description": "Creation time (format HHMMSS)",
          "description_es": "Hora de creación (formato HHMMSS)",
          "description_en": "Creation time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "PROEMB": {
          "description": "Packaging product code for interfacing",
          "description_es": "Código de producto de embalaje para la interfaz",
          "description_en": "Packaging product code for interfacing",
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "description": "Packaging product code for interfacing",
            "description_es": "Código de producto de embalaje para la interfaz",
            "description_en": "Packaging product code for interfacing",
            "type": "string",
            "maxLength": 17
          }
        },
        "CODTOB": {
          "description": "Object processing code",
          "description_es": "Código de procesamiento del objeto",
          "description_en": "Object processing code",
          "type": "string",
          "maxLength": 3
        },
        "DATSUP": {
          "description": "Support validation start and end dates",
          "description_es": "Fechas de inicio y fin de validación del soporte",
          "description_en": "Support validation start and end dates",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "description": "Support validation start and end dates (format YYYYMMDD)",
            "description_es": "Fechas de inicio y fin de validación del soporte (formato AAAAMMDD)",
            "description_en": "Support validation start and end dates (format YYYYMMDD)",
            "type": "string",
            "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          }
        },
        "HEUSUP": {
          "description": "Support validation start and end times",
          "description_es": "Horas de inicio y fin de validación del soporte",
          "description_en": "Support validation start and end times",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "description": "Support validation start and end times (format HHMMSS)",
            "description_es": "Horas de inicio y fin de validación del soporte (formato HHMMSS)",
            "description_en": "Support validation start and end times (format HHMMSS)",
            "type": "string",
            "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
            "examples": ["143023"]
          }
        },
        "COEUOT": {
          "description": "UOT calculation coefficient",
          "description_es": "Coeficiente de cálculo de UOT",
          "description_en": "UOT calculation coefficient",
          "type": "string",
          "pattern": "^[0-9]{1,2}\\.[0-9]{2}$",
          "examples": ["1.00"]
        },
        "TRAFUT": {
          "description": "Future carrier",
          "description_es": "Transportista futuro",
          "description_en": "Future carrier",
          "type": "string",
          "maxLength": 14
        },
        "MSGOBJ": {
          "description": "Message related to the object",
          "description_es": "Mensaje relacionado con el objeto",
          "description_en": "Message related to the object",
          "type": "string",
          "maxLength": 30
        },
        "GEEX4920": {
          "description": "Logistics object details",
          "description_es": "Detalles del objeto logístico",
          "description_en": "Logistics object details",
          "$ref": "#/$defs/GEEX4920Wrapper"
        },
        "GEEX4921": {
          "description": "Logistics object details",
          "description_es": "Detalles del objeto logístico",
          "description_en": "Logistics object details",
          "$ref": "#/$defs/GEEX4921Wrapper"
        },
        "GEEX4922": {
          "description": "Logistics object details",
          "description_es": "Detalles del objeto logístico",
          "description_en": "Logistics object details",
          "$ref": "#/$defs/GEEX4922Wrapper"
        },
        "GEEX4923": {
          "description": "Logistics object details",
          "description_es": "Detalles del objeto logístico",
          "description_en": "Logistics object details",
          "$ref": "#/$defs/GEEX4923Wrapper"
        },
        "GEEX4925": {
          "description": "Rubriques Declaration Line",
          "description_es": "Línea de declaración de rúbricas",
          "description_en": "Rubriques Declaration Line",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4925Wrapper"
          }
        }
      },
      "required": ["CODOBL", "AVINLI", "GEEX4920"],      
      "additionalProperties": false
    },
    "GEEX4920Wrapper": {
      "description": "Logistics object details",
      "description_es": "Detalles del objeto logístico",
      "description_en": "Logistics object details",
      "type": "object",
      "properties": {
        "NLIOBL": {
          "description": "Line number of the higher logistics object",
          "description_es": "Número de línea del objeto logístico superior",
          "description_en": "Line number of the higher logistics object",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODOBI": {
          "description": "Lower object code",
          "description_es": "Código del objeto inferior",
          "description_en": "Lower object code",
          "type": "string",
          "maxLength": 35
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "description_es": "Código de producto para EDI",
          "description_en": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "CODPRO": {
          "description": "Internal product code",
          "description_es": "Código interno del producto",
          "description_en": "Internal product code",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant (Gencod)",
          "description_es": "Variante logística (Gencod)",
          "description_en": "Logistics variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "EDICLI": {
          "description": "EDI code of the delivering customer (CLILIV)",
          "description_es": "Código EDI del cliente de entrega (CLILIV)",
          "description_en": "EDI code of the delivering customer (CLILIV)",
          "type": "string",
          "maxLength": 14
        },
        "CODCLI": {
          "description": "Internal code of the delivering customer (CLILIV)",
          "description_es": "Código interno del cliente de entrega (CLILIV)",
          "description_en": "Internal code of the delivering customer (CLILIV)",
          "type": "string",
          "maxLength": 14
        },
        "CODPAY": {
          "description": "Symbolic country code",
          "description_es": "Código simbólico de país",
          "description_en": "Symbolic country code",
          "type": "string",
          "maxLength": 3
        },
        "NATSTK": {
          "description": "Stock nature",
          "description_es": "Naturaleza del stock",
          "description_en": "Stock nature",
          "type": "string",
          "maxLength": 3
        },
        "CODLOT": {
          "description": "Stored batch code",
          "description_es": "Código de lote almacenado",
          "description_en": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "PDNLIV": {
          "description": "Net weight delivered",
          "description_es": "Peso neto entregado",
          "description_en": "Net weight delivered",
          "type": "number",
          "minimum": 0,
          "maximum": 99999999.999,
          "multipleOf": 0.001
        },
        "PCBPRO": {
          "description": "Product quantity",
          "description_es": "Cantidad del producto",
          "description_en": "Product quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        }
      },
      "required": ["NLIOBL", "CODPRO"],
      "additionalProperties": false
    },
    "GEEX4921Wrapper": {
      "description": "Logistics object details",
      "description_es": "Detalles del objeto logístico",
      "description_en": "Logistics object details",
      "type": "object",
      "properties": {
        "DATFAB": {
          "description": "Manufacturing date (format YYYYMMDD)",
          "description_es": "Fecha de fabricación (formato AAAAMMDD)",
          "description_en": "Manufacturing date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
            
          
        },
        "UVCOBI": {
          "description": "Number of CSUs of the lower logistics object",
          "description_es": "Número de UVC del objeto logístico inferior",
          "description_en": "Number of CSUs of the lower logistics object",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "UNIUVC": {
          "description": "Consumer Sales Unit measurement unit",
          "description_es": "Unidad de medida de la UVC",
          "description_en": "Consumer Sales Unit measurement unit",
          "type": "string",
          "maxLength": 3
        },
        "NUOOBI": {
          "description": "Object quantity in OU",
          "description_es": "Cantidad del objeto en UO",
          "description_en": "Object quantity in OU",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "UNIUOA": {
          "description": "Object unit",
          "description_es": "Unidad del objeto",
          "description_en": "Object unit",
          "type": "string",
          "maxLength": 3
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "description_es": "Motivo de inmovilización",
          "description_en": "Immobilization reason",
          "type": "string",
          "maxLength": 3
