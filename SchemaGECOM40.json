{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/blob/main/SchemaGECOM40.json",
  "title": "GECOM40 - Reception Orders",
  "type": "object",
  "description": "JSON schema generated by Generix SP",
  "properties": {
    "receptionOrders": {
      "type": "array",
      "description": "Reception Orders Header",
      "minItems": 1,
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 7 = Header Modification, 9 = Cancellation",
            "enum": ["1", "2", "7", "9"],
            "default": "2"
          },
          "NUMREC": {
            "type": "string",
            "description": "Order number to be received",
            "pattern": "^[0-9]{1,8}$"
          },
          "SNUREC": {
            "type": "string",
            "description": "Sub-number of the order to be received",
            "pattern": "^[0-9]{1,3}$"
          },
          "REFREC": {
            "type": "string",
            "description": "Reception reference",
            "minLength": 1,
            "maxLength": 30
          },
          "CODAPP": {
            "type": "string",
            "description": "Buyer/replenisher code",
            "maxLength": 10
          },
          "CODLDR": {
            "type": "string",
            "description": "Reception/shipping location code",
            "maxLength": 3
          },
          "CODTRE": {
            "type": "string",
            "description": "Reception type",
            "minLength": 3,
            "maxLength": 3
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "CODFOU": {
            "type": "string",
            "description": "Supplier code",
            "minLength": 1,
            "maxLength": 14
          },
          "CODTRA": {
            "type": "string",
            "description": "Carrier code",
            "maxLength": 14
          },
          "DTIREC": {
            "type": "string",
            "description": "Initially scheduled reception date",
            "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
          },
          "HEIREC": {
            "type": "string",
            "description": "Original scheduled reception time",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
          },
          "KAIREC": {
            "type": "string",
            "description": "Goods reception dock",
            "pattern": "^[0-9]{1,3}$"
          },
          "MSGREC": {
            "type": "array",
            "description": "Message to be printed on the receipt",
            "minItems": 0,
            "maxItems": 2,
            "items": {
              "type": "string",
              "maxLength": 30
            }
          },
          "IGLSIT": {
            "type": "string",
            "description": "GE site identifier for Infolog GL",
            "pattern": "^[0-9]{1,3}$"
          },
          "DTFREC": {
            "type": "string",
            "description": "Final reception date",
            "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
          },
          "EDIFOU": {
            "type": "string",
            "description": "Supplier code for EDI",
            "maxLength": 14
          },
          "METTRP": {
            "type": "string",
            "description": "Goods transport method / 1 = Delivered by supplier, 2 = Picked up by a third party, 3 = Picked up by us",
            "enum": ["1", "2", "3"],
            "default": "1"
          },
          "CODRTN": {
            "type": "string",
            "description": "Retention code",
            "maxLength": 3
          },
          "EDITRA": {
            "type": "string",
            "description": "Carrier code for EDI",
            "maxLength": 14
          },
          "CODRGT": {
            "type": "string",
            "description": "Area code for transport",
            "maxLength": 3
          },
          "CUMLIG": {
            "type": "string",
            "description": "Total number of lines in the order",
            "pattern": "^[0-9]{1,4}$"
          },
          "GEEX4001": {
            "type": "object",
            "description": "Supplier Information",
            "additionalProperties": false,
            "properties": {
              "DIPRECH": {
                "type": "string",
                "description": "Data transit area between software",
                "maxLength": 50
              },
              "TOPREC": {
                "type": "array",
                "description": "Indicators for specific users",
                "minItems": 0,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "maxLength": 1
                }
              },
              "NOMFOU": {
                "type": "string",
                "description": "Supplier name",
                "maxLength": 30
