{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom80/SchemaGECOM80.json",
  "title": "GECOM80 - Stock Movement",
  "title_es": "GECOM80 - Movimiento de stock",
  "title_en": "GECOM80 - Stock Movement",
  "x-wms-icon": "GECOM80",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client]/endpoint",
    "category": "Outbound",
    "version": "v1.2",
    "releaseDate": "2026-07-03"
  },
  "description": "JSON for stock movement feedback from the WMS",
  "description_es": "JSON para el retorno de movimientos de stock del WMS",
  "description_en": "JSON for stock movement feedback from the WMS",
  "type": "object",
  "properties": {
    "stockMovements": {
      "description": "Stock movement header",
      "description_es": "Cabecera de movimiento de stock",
      "description_en": "Stock movement header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX8000"
      }
    }
  },
  "required": ["stockMovements"],
  "additionalProperties": false,
  "$defs": {
    "GEEX8000": {
      "description": "Stock movement header",
      "description_es": "Cabecera de movimiento de stock",
      "description_en": "Stock movement header",
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "DATMVT": {
          "description": "Movement date (format YYYYMMDD)",
          "description_es": "Fecha del movimiento (formato AAAAMMDD)",
          "description_en": "Movement date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUMVT": {
          "description": "Movement time (format HHMMSS)",
          "description_es": "Hora del movimiento (formato HHMMSS)",
          "description_en": "Movement time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "DATRGL": {
          "description": "Adjustment date (format YYYYMMDD)",
          "description_es": "Fecha de ajuste (formato AAAAMMDD)",
          "description_en": "Adjustment date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "CODMDU": {
          "description": "Module code",
          "description_es": "Código de módulo",
          "description_en": "Module code",
          "type": "string",
          "maxLength": 2
        },
        "CODFON": {
          "description": "Function code",
          "description_es": "Código de función",
          "description_en": "Function code",
          "type": "string",
          "pattern": "^[0-9]{1,1}$"
        },
        "CODMVT": {
          "description": "Journaling movement code - see EnumCODMVT",
          "description_es": "Código de movimiento de registro - ver EnumCODMVT",
          "description_en": "Journaling movement code - see EnumCODMVT",
          "$ref": "#/$defs/Enums/EnumCODMVT"
        },
        "SENMVT": {
          "description": "Physical movement direction - see EnumSENMVT",
          "description_es": "Sentido del movimiento físico - ver EnumSENMVT",
          "description_en": "Physical movement direction - see EnumSENMVT",
          "$ref": "#/$defs/Enums/EnumSENMVT"
        },
        "MOTMVT": {
          "description": "Reason for the journaled movement",
          "description_es": "Motivo del movimiento registrado",
          "description_en": "Reason for the journaled movement",
          "type": "string",
          "maxLength": 3
        },
        "EDIMVT": {
          "description": "Movement code for EDI",
          "description_es": "Código de movimiento para EDI",
          "description_en": "Movement code for EDI",
          "type": "string",
          "maxLength": 3
        },
        "REFMVT": {
          "description": "Movement reference",
          "description_es": "Referencia del movimiento",
          "description_en": "Movement reference",
          "type": "string",
          "maxLength": 30
        },
        "UVCMVT": {
          "description": "Number of units of the adjustment movement",
          "description_es": "Número de unidades del movimiento de ajuste",
          "description_en": "Number of units of the adjustment movement",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "description_es": "Código de cliente propietario del stock",
          "description_en": "Stock owner customer code",
          "type": "string",
          "maxLength": 14
        },
        "CODPRO": {
          "description": "Product code",
          "description_es": "Código del producto",
          "description_en": "Product code",
          "type": "string",
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant",
          "description_es": "Variante logística",
          "description_en": "Logistics variant",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODPRN": {
          "description": "Product code from a bill of materials",
          "description_es": "Código de producto de una lista de materiales",
          "description_en": "Product code from a bill of materials",
          "type": "string",
          "maxLength": 17
        },
        "SPCPRO": {
          "description": "Product sub-pack quantity",
          "description_es": "Cantidad de subembalaje del producto",
          "description_en": "Product sub-pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "description_es": "Cantidad de embalaje del producto",
          "description_en": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "CODSIT": {
          "description": "Storage site code",
          "description_es": "Código del sitio de almacenamiento",
          "description_en": "Storage site code",
          "type": "string",
          "maxLength": 3
        },
        "ZONSTS": {
          "description": "Warehouse storage area",
          "description_es": "Zona de almacenamiento del almacén",
          "description_en": "Warehouse storage area",
          "type": "string",
          "maxLength": 1
        },
        "ALLSTS": {
          "description": "Aisle code in the area",
          "description_es": "Código de pasillo en la zona",
          "description_en": "Aisle code in the area",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "DPLSTS": {
          "description": "Location displacement in the aisle",
          "description_es": "Desplazamiento de la ubicación en el pasillo",
          "description_en": "Location displacement in the aisle",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "NIVSTS": {
          "description": "Location level in the column",
          "description_es": "Nivel de la ubicación en la columna",
          "description_en": "Location level in the column",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODLOT": {
          "description": "Stored batch code",
          "description_es": "Código de lote almacenado",
          "description_en": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "NUMLOT": {
          "description": "Internal goods batch number",
          "description_es": "Número de lote interno de la mercancía",
          "description_en": "Internal goods batch number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "CODPAL": {
          "description": "Stored pallet code per EAN128 standards",
          "description_es": "Código de palé almacenado según estándares EAN128",
          "description_en": "Stored pallet code per EAN128 standards",
          "type": "string",
          "maxLength": 18
        },
        "DATFVI": {
          "description": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "description_es": "Fecha de fin de vida del producto (obsolescencia) (formato AAAAMMDD)",
          "description_en": "Product end-of-life date (obsolescence) (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "NUMDIM": {
          "description": "De-immobilization number",
          "description_es": "Número de desinmovilización",
          "description_en": "De-immobilization number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "CODTIE": {
          "description": "Third-party code (Supplier or Customer)",
          "description_es": "Código de tercero (proveedor o cliente)",
          "description_en": "Third-party code (Supplier or Customer)",
          "type": "string",
          "maxLength": 14
        },
        "TYPTIE": {
          "description": "Third-party type - see EnumTYPTIE",
          "description_es": "Tipo de tercero - ver EnumTYPTIE",
          "description_en": "Third-party type - see EnumTYPTIE",
          "$ref": "#/$defs/Enums/EnumTYPTIE"
        },
        "NUMCDE": {
          "description": "Order number (Reception or delivery)",
          "description_es": "Número de orden (recepción o entrega)",
          "description_en": "Order number (Reception or delivery)",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNUCDE": {
          "description": "Order sub-number (Reception/Delivery)",
          "description_es": "Subnúmero de orden (recepción/entrega)",
          "description_en": "Order sub-number (Reception/Delivery)",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODUTI": {
          "description": "User code responsible for the movement",
          "description_es": "Código del usuario responsable del movimiento",
          "description_en": "User code responsible for the movement",
          "type": "string",
          "maxLength": 10
        },
        "UNIPRO": {
          "description": "Product unit of measure",
          "description_es": "Unidad de medida del producto",
          "description_en": "Product unit of measure",
          "type": "string",
          "maxLength": 3
        },
        "GEEX8001": {
          "description": "Stock movement additional information",
          "description_es": "Información adicional del movimiento de stock",
          "description_en": "Stock movement additional information",
          "$ref": "#/$defs/GEEX8001Wrapper"
        },
        "GEEX8060": {
          "description": "Immobilization / de-immobilization movement",
          "description_es": "Movimiento de inmovilización/desinmovilización",
          "description_en": "Immobilization / de-immobilization movement",
          "$ref": "#/$defs/GEEX8060Wrapper"
        },
        "GEEX8090": {
          "description": "Positive release complementary movement",
          "description_es": "Movimiento complementario de liberación positiva",
          "description_en": "Positive release complementary movement",
          "$ref": "#/$defs/GEEX8090Wrapper"
        }
      },
      "required": ["RCTEXC", "DATMVT", "CODMVT", "SENMVT", "MOTMVT", "CODACT", "CODPRO"],
      "additionalProperties": false
    },
    "GEEX8001Wrapper": {
      "description": "Stock movement additional information",
      "description_es": "Información adicional del movimiento de stock",
      "description_en": "Stock movement additional information",
      "type": "object",
      "properties": {
        "ANAPRO": {
          "description": "Product analysis code",
          "description_es": "Código de análisis del producto",
          "description_en": "Product analysis code",
          "type": "string",
          "maxLength": 15
        },
        "NLILIV": {
          "description": "Line number for the delivery interface",
          "description_es": "Número de línea para la interfaz de entrega",
          "description_en": "Line number for the delivery interface",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODTLI": {
          "description": "Delivery type code",
          "description_es": "Código de tipo de entrega",
          "description_en": "Delivery type code",
          "type": "string",
          "maxLength": 3
        },
        "DATFAB": {
          "description": "Manufacturing date (format YYYYMMDD)",
          "description_es": "Fecha de fabricación (formato AAAAMMDD)",
          "description_en": "Manufacturing date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "MOTSAP": {
          "description": "S.A.P. reason",
          "description_es": "Motivo S.A.P.",
          "description_en": "S.A.P. reason",
          "type": "string",
          "maxLength": 4
        },
        "CODSAP": {
          "description": "S.A.P. code (+/-)",
          "description_es": "Código S.A.P. (+/-)",
          "description_en": "S.A.P. code (+/-)",
          "type": "string",
          "maxLength": 3
        },
        "STOSAP": {
          "description": "S.A.P. storage location (+/-)",
          "description_es": "Ubicación de almacenamiento S.A.P. (+/-)",
          "description_en": "S.A.P. storage location (+/-)",
          "type": "string",
          "maxLength": 4
        },
        "STASAP": {
          "description": "S.A.P. status (+/-)",
          "description_es": "Estado S.A.P. (+/-)",
          "description_en": "S.A.P. status (+/-)",
          "type": "string",
          "maxLength": 1
        },
        "MESPRO": {
          "description": "Product measurement method - see EnumMESPRO",
          "description_es": "Método de medición del producto - ver EnumMESPRO",
          "description_en": "Product measurement method - see EnumMESPRO",
          "$ref": "#/$defs/Enums/EnumMESPRO"
        },
        "DIPMVT": {
          "description": "Data transit area between software",
          "description_es": "Zona de tránsito de datos entre software",
          "description_en": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "CODRGT": {
          "description": "Region code for transport",
          "description_es": "Código de región para transporte",
          "description_en": "Region code for transport",
          "type": "string",
          "maxLength": 3
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "description_es": "Código de producto para EDI",
          "description_en": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "NUMGRP": {
          "description": "Group identification number",
          "description_es": "Número de identificación de grupo",
          "description_en": "Group identification number",
          "type": "string",
          "pattern": "^[0-9]{1,10}$"
        },
        "PDBPAL": {
          "description": "Gross weight of the pallet in Kg",
          "description_es": "Peso bruto del palé en kg",
          "description_en": "Gross weight of the pallet in Kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "PDBMVT": {
          "description": "Gross weight moved",
          "description_es": "Peso bruto movido",
          "description_en": "Gross weight moved",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "FAMPRO": {
          "description": "Product classification family",
          "description_es": "Familia de clasificación del producto",
          "description_en": "Product classification family",
          "type": "string",
          "maxLength": 10
        },
        "INDPRO": {
          "description": "Configurable product indicators",
          "description_es": "Indicadores configurables del producto",
          "description_en": "Configurable product indicators",
          "type": "array",
          "maxItems": 10,
          "items": {
            "description": "Configurable product indicators",
            "description_es": "Indicadores configurables del producto",
            "description_en": "Configurable product indicators",
            "type": "string",
            "maxLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "GEEX8060Wrapper": {
      "description": "Immobilization / de-immobilization movement",
      "description_es": "Movimiento de inmovilización/desinmovilización",
      "description_en": "Immobilization / de-immobilization movement",
      "type": "object",
      "properties": {
        "MOTIMM": {
          "description": "Immobilization reason",
          "description_es": "Motivo de inmovilización",
          "description_en": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "DATIMM1": {
          "description": "Immobilization start date (format YYYYMMDD)",
          "description_es": "Fecha de inicio de inmovilización (formato AAAAMMDD)",
          "description_en": "Immobilization start date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "DATIMM2": {
          "description": "Immobilization end date (format YYYYMMDD)",
          "description_es": "Fecha de fin de inmovilización (formato AAAAMMDD)",
          "description_en": "Immobilization end date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "SITPAL": {
          "description": "Origin site of the updated pallet",
          "description_es": "Sitio de origen del palé actualizado",
          "description_en": "Origin site of the updated pallet",
          "type": "string",
          "maxLength": 3
        },
        "HEUIMM1": {
          "description": "Immobilization start time (format HHMMSS)",
          "description_es": "Hora de inicio de inmovilización (formato HHMMSS)",
          "description_en": "Immobilization start time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "HEUIMM2": {
          "description": "Immobilization end time (format HHMMSS)",
          "description_es": "Hora de fin de inmovilización (formato HHMMSS)",
          "description_en": "Immobilization end time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "CODSAP": {
          "description": "S.A.P. code (+/-)",
          "description_es": "Código S.A.P. (+/-)",
          "description_en": "S.A.P. code (+/-)",
          "type": "string",
          "maxLength": 3
        },
        "STOSAP": {
          "description": "S.A.P. storage location (+/-)",
          "description_es": "Ubicación de almacenamiento S.A.P. (+/-)",
          "description_en": "S.A.P. storage location (+/-)",
          "type": "string",
          "maxLength": 4
        },
        "STASAP": {
          "description": "S.A.P. status (+/-)",
          "description_es": "Estado S.A.P. (+/-)",
          "description_en": "S.A.P. status (+/-)",
          "type": "string",
          "maxLength": 1
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "description_es": "Código de producto para EDI",
          "description_en": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "IMMPAL": {
          "description": "Pallet immobilization management / false = No, true = Yes",
          "description_es": "Gestión de inmovilización del palé / false = No, true = Sí",
          "description_en": "Pallet immobilization management / false = No, true = Yes",
          "type": "boolean",
          "default": false
        },
        "CODRIM": {
          "description": "Immobilization reasons code",
          "description_es": "Código de motivos de inmovilización",
          "description_en": "Immobilization reasons code",
          "type": "string",
          "maxLength": 3
        }
      },
      "additionalProperties": false
    },
    "GEEX8090Wrapper": {
      "description": "Positive release complementary movement",
      "description_es": "Movimiento complementario de liberación positiva",
      "description_en": "Positive release complementary movement",
      "type": "object",
      "properties": {
        "NUMPAL": {
          "description": "Stored pallet number",
          "description_es": "Número de palé almacenado",
          "description_en": "Stored pallet number",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "SNUPAL": {
          "description": "Stored pallet sub-number",
          "description_es": "Subnúmero de palé almacenado",
          "description_en": "Stored pallet sub-number",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "ETAPAL": {
          "description": "Stored pallets status code - see EnumETAPAL",
          "description_es": "Código de estado de los palés almacenados - ver EnumETAPAL",
          "description_en": "Stored pallets status code - see EnumETAPAL",
          "$ref": "#/$defs/Enums/EnumETAPAL"
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "description_es": "Motivo de inmovilización",
          "description_en": "Immobilization reason",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Immobilization reason",
            "description_es": "Motivo de inmovilización",
            "description_en": "Immobilization reason",
            "type": "string",
            "maxLength": 3
          }
        },
        "DATLIB": {
          "description": "Support code release date",
          "description_es": "Fecha de liberación del código de soporte",
          "description_en": "Support code release date",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Support code release date (format YYYYMMDD)",
            "description_es": "Fecha de liberación del código de soporte (formato AAAAMMDD)",
            "description_en": "Support code release date (format YYYYMMDD)",
            "type": "string",
            "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
            "examples": ["20250125"]
          }
        },
        "HEULIB": {
          "description": "Support code release time",
          "description_es": "Hora de liberación del código de soporte",
          "description_en": "Support code release time",
          "type": "array",
          "maxItems": 3,
          "items": {
            "description": "Support code release time (format HHMMSS)",
            "description_es": "Hora de liberación del código de soporte (formato HHMMSS)",
