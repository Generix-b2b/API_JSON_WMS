{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom84/SchemaGECOM84.json",
  "title": "GECOM84 - Multi-Exchange",
  "title_es": "GECOM84 - Multiintercambio",
  "title_en": "GECOM84 - Multi-Exchange",
  "x-wms-icon": "GECOM84",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m84_multiexchange?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.1-BETA",
    "releaseDate": "2026-07-22"
  },
  "description": "JSON for Multi-Exchange",
  "description_es": "JSON para Multiintercambio",
  "description_en": "JSON for Multi-Exchange",
  "type": "object",
  "properties": {
    "multiexchange": {
      "description": "Multi-Exchange",
      "description_es": "Multiintercambio",
      "description_en": "Multi-Exchange",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX8400"
			}
    }
  },
  "required": ["multiexchange"],
  "additionalProperties": false,
  "$defs": {
    "GEEX8400": {
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODPGM": {
          "description": "Program Code",
          "description_es": "Código de Programa",
          "description_en": "Program Code",
          "type": "string",
          "minLength": 1,
          "maxLength": 10
        },
        "ZONLNK": {
          "description": "Area Available for Movement Recording",
          "description_es": "Zona disponible para la escritura de movimientos",
          "description_en": "Area Available for Movement Recording",
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      },
      "required": ["RCTEXC", "TRTEXC", "CODPGM", "ZONLNK"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "description_es": "Código de procesamiento del movimiento / 1 = Crear, 2 = Modificar o crear, 9 = Cancelación",
        "description_en": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "9"],
        "default": "2"
      }
    } 
  }
