{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Schemas/SchemaGECOM20.json",
  "title": "GECOM20 - Customer Master Data",
  "x-wms-icon": "GECOM20",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m20_client",
    "category": "Inbound",
    "version": "v1.1",
    "releaseDate": "2026-06-17"
  },
  "description": "JSON for customer master data load",
  "type": "object",
  "properties": {
    "customerMasterData": {
      "description": "Customer declaration",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX2000"
			}
    }
  },
  "required": ["customerMasterData"],
  "$defs": {
    "GEEX2000": {
      "description": "Customer declaration",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Stock owner customer code",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "TYPCLI": {
          "description": "Customer type / 1 = Final Delivery Point, 2 = Grouping Customer, 3 = Platform, 4 = Workshop",
          "$ref": "#/$defs/Enums/EnumTYPCLI"
        },
        "CATCLI": {
          "description": "Customer category (e.g.: network)",
          "type": "string",
          "maxLength": 3
        },
        "CLILIV": {
          "description": "Customer code to be delivered to",
          "type": "string",
          "maxLength": 14
        },
        "EDICLI": {
          "description": "Customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "NOMCLI": {
          "description": "Customer name",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD1CLI": {
          "description": "Customer address line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2CLI": {
          "description": "Customer address line 2",
          "type": "string",
          "maxLength": 38
        },
        "AD3CLI": {
          "description": "Customer address line 3",
          "type": "string",
          "maxLength": 38
        },
        "CPOCLI": {
          "description": "Customer postal code in numeric format",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CPICLI": {
          "description": "Customer postal code (international format)",
          "type": "string",
          "minLength": 1,
          "maxLength": 10
        },
        "VILCLI": {
          "description": "Customer city",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "PAYCLI": {
          "description": "Customer country code (ISO 3166-1 alpha-2 or alpha-3 accepted)",
          "$ref": "#/$defs/Enums/EnumPAYCLI"
        },
        "TELCLI": {
          "description": "Customer phone number",
          "type": "string",
          "maxLength": 20
        },
        "FAXCLI": {
          "description": "Customer fax number",
          "type": "string",
          "maxLength": 20
        },
        "TLXCLI": {
          "description": "Customer telex number",
          "type": "string",
          "maxLength": 15
        },
        "CODLGE": {
          "description": "Language code",
          "type": "string",
          "maxLength": 3
        },
        "CODDEV": {
          "description": "Currency code",
          "type": "string",
          "maxLength": 3
        },
        "IGLSIT": {
          "description": "Site identifier for Infolog GL",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "PTYCLI": {
          "description": "Store service priority",
          "type": "string",
          "maxLength": 3
        },
        "ETACLI": {
          "description": "Customer status code / 20 = Not considered, 30 = Customer record, 40 = M50 Interface",
          "$ref": "#/$defs/Enums/EnumETACLI"
        },
        "INDADR": {
          "description": "Address indicator",
          "type": "string",
          "maxLength": 1
        },
        "CODCLV": {
          "description": "Delivery requirement",
          "type": "string",
          "maxLength": 3
        },
        "GEEX2001": {
          "description": "Customer Additional Declaration",
          "$ref": "#/$defs/GEEX2001Wrapper"
        },
        "GEEX2050": {
          "description": "Customer rubriques declaration",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX2050Wrapper"
          }
        }
      },
      "required": ["TRTEXC", "CODACT", "CODCLI", "NOMCLI", "AD1CLI", "VILCLI", "PAYCLI"],
      "oneOf": [
        { "required": ["CPOCLI"], "not": { "required": ["CPICLI"] } },
        { "required": ["CPICLI"], "not": { "required": ["CPOCLI"] } }
      ],
      "additionalProperties": false
    },
    "GEEX2001Wrapper": {
      "description": "Customer Additional Declaration",
      "type": "object",
      "properties": {
        "RSPCLI": {
          "description": "Name of the person in charge at the customer",
          "type": "string",
          "maxLength": 30
        },
        "CODMOP": {
          "description": "Preparation mode code for a customer",
          "type": "string",
          "maxLength": 3
        },
        "CODRGT": {
          "description": "Area code for transport",
          "type": "string",
          "maxLength": 3
        },
        "CODTRA": {
          "description": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "TOULIV": {
          "description": "Goods delivery round",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Goods delivery round",
            "type": "string",
            "pattern": "^[0-9]{1,4}$"
          }
        },
        "ORDLIV": {
          "description": "Delivery order in the round",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Delivery order in the round",
            "type": "string",
            "pattern": "^[0-9]{1,4}$"
          }
        },
        "KAILIV": {
          "description": "Freight transport docks",
          "type": "array",
          "maxItems": 7,
          "items": {
            "description": "Freight transport docks",
            "type": "string",
            "pattern": "^[0-9]{1,3}$"
          }
        },
        "GSTALC": {
          "description": "Liquor management mode / 0 = No alcohol management, 1 = Delivery with suspended duty, 2 = Delivery under voucher, 3 = Out of customs, no taxes",
          "$ref": "#/$defs/Enums/EnumGSTALC"
        },
        "PTYDES": {
          "description": "Pallet retrieval priority",
          "$ref": "#/$defs/Enums/EnumPTYDES"
        },
        "NUMACS": {
          "description": "Excise duty number (Alcohol)",
          "type": "string",
          "maxLength": 20
        },
        "TVACCE": {
          "description": "Intra-community VAT",
          "type": "string",
          "maxLength": 20
        },
        "IDEALC": {
          "description": "Alcohol identifier",
          "type": "string",
          "maxLength": 20
        },
        "CTRPRP": {
          "description": "Quantity control during preparation / false = Non-systematic, true = Systematic",
          "type": "boolean",
          "default": false
        },
        "CLIDAE": {
          "description": "DEA management mode",
          "type": "string",
          "maxLength": 1
        },
        "TYPDES": {
          "description": "GAMM@ destination type",
          "type": "string",
          "maxLength": 1
        },
        "BUREXP": {
          "description": "Ref. GAMM@ Export Office",
          "type": "string",
          "maxLength":8
        },
        "PTYPRP": {
          "description": "Priority of heterogeneous supports in ML preparation",
          "$ref": "#/$defs/Enums/EnumPTYPRP"
        },
        "GENAVI": {
          "description": "Shipping notice generation",
          "type": "string",
          "maxLength": 1
        },
        "HEUCHV": {
          "description": "Riding Time /  false = No, true = Yes",
          "type": "boolean",
          "default": false
        },
        "TYPDES2": {
          "description": "GAMM@ destination type",
          "type": "string",
          "maxLength": 2
        },
        "CODFCQ": {
          "description": "Quality control sheet code",
          "type": "string",
          "maxLength": 3
        },
        "CM1CLI": {
          "description": "Customer comment (line 1)",
          "type": "string",
          "maxLength":45
        },
        "CM2CLI": {
          "description": "Customer comment (line 2)",
          "type": "string",
          "maxLength":45
        },
        "CM3CLI": {
          "description": "Customer comment (line 3)",
          "type": "string",
          "maxLength":45
        },
        "EMLADR": {
          "description": "Email address",
          "type": "string",
          "minLength": 1,
          "maxLength":50,
          "format": "email"
        },
        "CODRST": {
          "description": "In-transit inventory rule code",
          "type": "string",
          "maxLength": 3
        },
        "LIBCPL": {
          "description": "Additional name",
          "type": "string",
          "maxLength": 38
        },
        "LIBCP2": {
          "description": "Additional name 2",
          "type": "string",
          "maxLength": 38
        },
        "EXLGRP": {
          "description": "Out of group / false = no, true = Yes",
          "type": "boolean",
          "default": false
        },
        "TYPDSV": {
          "description": "DESADV type",
          "type": "string",
          "maxLength": 1
        },
        "PTYSND": {
          "description": "Shipping priority",
          "type": "string",
          "maxLength": 1
        },
        "IDEEXT": {
          "description": "External identifier",
          "type": "string",
          "maxLength": 35
        },
        "ARDPEN": {
          "description": "Shortage rounding indicator",
          "type": "string",
          "maxLength": 1
        }
      },
      "additionalProperties": false
    },
    "GEEX2050Wrapper": {
      "description": "Customer rubriques declaration",
      "type": "object",
      "properties": {
        "TYPRUB": {
          "description": "Heading type / 1 = EDIFACT Standard, 2 = Internal Coding",
					"$ref": "#/$defs/Enums/EnumTYPRUB"
        },
        "CODRUB": {
          "description": "Section code",
          "type": "string",
          "minLength": 1,
          "maxLength":4
        },
        "VALRUB": {
          "description": "Item value",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["TYPRUB", "CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "9"],
        "default": "2"
