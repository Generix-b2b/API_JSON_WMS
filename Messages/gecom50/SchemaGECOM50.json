{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Schemas/SchemaGECOM50.json",
  "title": "GECOM50 - Delivery Orders",
  "x-wms-icon": "GECOM50",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m50_expedition",
    "category": "Inbound",
    "version": "v1.1",
    "releaseDate": "2026-06-17"
  },
  "description": "JSON for creating a Delivery Orders",
  "type": "object",
  "properties": {
    "deliveryOrders": {
      "description": "Delivery Orders Header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX5000"
			}
    }
  },
  "required": ["deliveryOrders"],
  "$defs": {
    "GEEX5000": {
      "description": "Delivery Orders Header",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 7 = Header Modification, 9 = Cancellation",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "NUMLIV": {
          "description": "Order number to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNULIV": {
          "description": "Sub-number of the order to be delivered",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "CODCLI": {
          "description": "Customer code of the stock owner",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "REFLIV": {
          "description": "Delivery reference",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "CODTLI": {
          "description": "Delivery type code",
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "DTILIV": {
          "description": "Initially scheduled delivery date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEILIV": {
          "description": "Originally scheduled delivery time / format HHMM",
          "type": "string",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$",
          "examples": ["1430"]
        },
        "CLILIV": {
          "description": "Customer code to deliver",
          "type": "string",
          "maxLength": 14
        },
        "TYPLIV": {
          "description": "Delivery type (notion of collected/delivered) / 1 = Delivered, 2 = Collected",
          "$ref": "#/$defs/Enums/EnumTYPLIV"
        },
        "CODMOP": {
          "description": "Preparation mode code for a customer",
          "type": "string",
          "maxLength": 3
        },
        "CODTRA": {
          "description": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "CODRGT": {
          "description": "Area code for transport",
          "type": "string",
          "maxLength": 3
        },
        "TOULIV": {
          "description": "Goods delivery round",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "ORDLIV": {
          "description": "Delivery order in the tour",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "KAILIV": {
          "description": "Cargo shipping dock",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "MSGPRP": {
          "description": "Message to edit on the packing slip",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Message to edit on the packing slip",
            "type": "string",
            "maxLength": 30
          }
        },
        "MSGLIV": {
          "description": "Message to edit on the delivery note",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Message to edit on the delivery note",
            "type": "string",
            "maxLength": 30
          }
        },
        "GSTALC": {
          "description": "Alcohol management mode / 0 = No alcohol management, 1 = Delivery with Release (DSAC), 2 = Delivery under Acquit (DAC), 3 = Duty free, tax free",
          "$ref": "#/$defs/Enums/EnumGSTALC"
        },
        "CODSIT": {
          "description": "Storage site code",
          "type": "string",
          "maxLength": 3
        },
        "IGLSIT": {
          "description": "GE site identifier for Infolog GL",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "CODBAS": {
          "description": "Database code",
          "type": "string",
          "maxLength": 3
        },
        "TYPCDE": {
          "description": "Order type (provisional or firm) / false = Firm order, true = Provisional order",
          "type": "boolean",
          "default": false
        },
        "CUMLIG": {
          "description": "Total number of lines in the order",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "CUMPOI": {
          "description": "Cumulated gross weight of the order in Kg",
          "type": "string",
          "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
        },
        "CUMVOL": {
          "description": "Cumulated order volumes in Dm3",
          "type": "string",
          "pattern": "^[0-9]{1,8}\\.[0-9]{3}$"
        },
        "CUMCOL": {
          "description": "Total number of packages",
          "type": "string",
          "pattern": "^[0-9]{1,7}$"
        },
        "GEEX5001": {
          "description": "Delivery Order Additional Header Information",
          "$ref": "#/$defs/GEEX5001Wrapper"
        },
        "GEEX5005": {
          "description": "Delivery Orders Rubriques Declaration header",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5005Wrapper"
          }
        },
        "GEEX5010": {
          "description": "Customer VPC Address Information",
          "$ref": "#/$defs/GEEX5010Wrapper"
        },
        "GEEX5020": {
          "description": "Delivery Order Lines",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5020Wrapper"
          }
        },
        "GEEX5080": {
          "description": "Free text on delivery note",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5080Wrapper"
          }
        }
      },
      "required": ["TRTEXC", "REFLIV", "CODTLI", "CODACT", "CODCLI", "DTILIV", "HEILIV", "CUMLIG"],
      "if": {
        "properties": {
          "TRTEXC": { "enum": ["1", "2"] }
        },
        "required": ["TRTEXC"]
      },
      "then": {
        "required": ["GEEX5020"]
      },
      "additionalProperties": false
    },
    "GEEX5001Wrapper": {
      "description": "Delivery Order Additional Header Information",
      "type": "object",
      "properties": {
        "TOPLIV": {
          "description": "Indicators for specific users",
          "type": "array",
          "maxItems": 5,
          "items": {
            "description": "Indicators for specific users",
            "type": "string",
            "maxLength": 1
          }
        },
        "DIPLIV": {
          "description": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "DATEXP": {
          "description": "Goods dispatch date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXP": {
          "description": "Goods dispatch time / format HHMM",
          "type": "string",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$",
          "examples": ["1430"]
        },
        "MNTCRB": {
          "description": "Cash on delivery amount",
          "type": "string",
          "pattern": "^[0-9]{1,11}\\.[0-9]{3}$",
          "examples": ["100.780"]
        },
        "REFCLI": {
          "description": "Recipient's order reference",
          "type": "string",
          "maxLength": 30
        },
        "CRILIV": {
          "description": "Order extraction criteria",
          "type": "string",
          "maxLength": 20
        },
        "PTYCLI": {
          "description": "Store service priority",
          "type": "string",
          "maxLength": 3
        },
        "CODLDP": {
          "description": "Preparation location code",
          "type": "string",
          "maxLength": 3
        },
        "EDICLF": {
          "description": "Final customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDICLI": {
          "description": "Customer code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "EDITRA": {
          "description": "Carrier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "DATCHT": {
          "description": "Goods loading date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUCHT": {
          "description": "Goods loading time / format HHMM",
          "type": "string",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)$",
          "examples": ["1430"]
        },
        "NUMTOU": {
          "description": "Return record number",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "DATPTD": {
          "description": "Last preparation date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUPTD": {
          "description": "Last preparation time / format HHMMSS",
          "type": "string",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "CODAFI": {
          "description": "Affiliation code",
          "type": "string",
          "maxLength": 10
        },
        "CODDDO": {
          "description": "Originator code",
          "type": "string",
          "maxLength": 14
        },
        "SITPAL": {
          "description": "Updated pallet origin site",
          "type": "string",
          "maxLength": 3
        },
        "CLIVIA": {
          "description": "Intermediate delivery point / Relay point",
          "type": "string",
          "maxLength": 14
        },
        "DATEXC": {
          "description": "Negotiation date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEUEXC": {
          "description": "Exchange time / format HHMMSS",
          "type": "string",
          "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$",
          "examples": ["143023"]
        },
        "CODCLV": {
          "description": "Delivery requirement code",
          "type": "string",
          "maxLength": 3
        },
        "CODOWN": {
          "description": "Holder code",
          "type": "string",
          "maxLength": 14
        },
        "CODOFT": {
          "description": "Operator offer code",
          "type": "string",
          "maxLength": 14
        },
        "SITRCT": {
          "description": "Reception site code (recipient's warehouse)",
          "type": "string",
          "maxLength": 3
        },
        "TOPVIA": {
          "description": "Supplier type indicator",
          "type": "string",
          "maxLength": 1
        },
        "CODGLN": {
          "description": "Global logistics number",
          "type": "string",
          "maxLength": 14
        },
        "REFEXT": {
          "description": "External reference",
          "type": "string",
          "maxLength": 30
        },
        "HLIMIN": {
          "description": "Minimum delivery time",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "HLIMAX": {
          "description": "Maximum delivery time",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "CODACL": {
          "description": "Code to cancel an order to be delivered",
          "type": "string",
          "maxLength": 3
        },
        "CODTTO": {
          "description": "Route type code",
          "type": "string",
          "maxLength": 3
        },
        "DATLIV": {
          "description": "Order delivery date / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        }
      },
      "additionalProperties": false
    },
    "GEEX5005Wrapper": {
      "description": "Delivery Orders Rubriques Declaration header",
      "type": "object",
      "properties": {
        "CODRUB": {
          "description": "Section code array",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value array",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "GEEX5010Wrapper": {
      "description": "Customer VPC Address Information",
      "type": "object",
      "properties": {
        "NOMCLI": {
          "description": "Customer name",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "AD1CLI": {
          "description": "Customer address line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2CLI": {
          "description": "Customer address line 2",
          "type": "string",
          "maxLength": 38
        },
        "AD3CLI": {
          "description": "Customer address line 3",
          "type": "string",
          "maxLength": 38
        },
        "CPOCLI": {
          "description": "Customer postal code",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CPICLI": {
          "description": "Customer postal code (international format)",
          "type": "string",
          "minLength": 1,
          "maxLength": 10
        },
        "VILCLI": {
          "description": "Customer city",
          "type": "string",
          "minLength": 1,
          "maxLength": 26
        },
        "TELCLI": {
          "description": "Customer phone number",
          "type": "string",
          "maxLength": 20
        },
        "PAYCLI": {
          "description": "Customer country code (ISO 3166-1 alpha-2 or alpha-3 accepted)",
          "$ref": "#/$defs/Enums/EnumPAYCLI"
        },
        "CATCLI": {
          "description": "Customer category (e.g.: network)",
          "type": "string",
          "maxLength": 3
        },
        "EMLADR": {
          "description": "Email address",
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "format": "email"
        }
      },
      "required": ["NOMCLI", "AD1CLI", "VILCLI", "PAYCLI"],
      "oneOf": [
        { "required": ["CPOCLI"], "not": { "required": ["CPICLI"] } },
        { "required": ["CPICLI"], "not": { "required": ["CPOCLI"] } }
      ],
      "additionalProperties": false
    },
    "GEEX5020Wrapper": {
      "description": "Delivery Order Lines",
      "type": "object",
      "properties": {
        "NLILIV": {
          "description": "Line number for the delivery interface",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODPRO": {
          "description": "Internal product code",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "METRPL": {
          "description": "Product replacement method / 0 = No replacement, 1 = Replaced by, 2 = Substituted by",
          "$ref": "#/$defs/Enums/EnumMETRPL"
        },
        "CODRPL": {
          "description": "Replacement product code",
          "type": "string",
          "maxLength": 17
        },
        "VALRPL": {
          "description": "Replacement product NAV",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODPRN": {
          "description": "Bill of materials product code",
          "type": "string",
          "maxLength": 17
        },
        "UVCCDE": {
          "description": "Number of ordered CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "UNICDE": {
          "description": "Order quantity input unit",
          "type": "string",
          "maxLength": 3
        },
        "TYPSTK": {
          "description": "Stock type (tool or retention) / 1 = Tool stock, 2 = Retention stock",
          "$ref": "#/$defs/Enums/EnumTYPSTK"
        },
        "AIGPRI": {
          "description": "Switch for price marking control / false = Unmarked product, true = Marked product",
          "type": "boolean",
          "default": false
        },
        "PRILIV": {
          "description": "Price marked on the product to be stamped",
          "type": "string",
          "pattern": "^[0-9]{1,5}\\.[0-9]{3}$"
        },
        "TYPOPE": {
          "description": "Operation type (e.g.: Promotion, reservation) / 0 = Normal, 1 = Promotion, 2 = Reservation, 4 = Promo Circuit",
          "$ref": "#/$defs/Enums/EnumTYPOPE"
        },
        "NUMOPE": {
          "description": "Operation number (Promo or reservation)",
          "type": "string",
          "pattern": "^[0-9]{1,6}$"
        },
        "SPCPRO": {
          "description": "Product sub-quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Product quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "CODLOT": {
          "description": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "MSGLIG": {
          "description": "Line-by-line message printed on the delivery note",
          "type": "string",
          "maxLength": 30
        },
        "UVCINI": {
          "description": "Number of initially ordered CSUs",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "QTECDE": {
          "description": "Quantity ordered in the specified unit",
          "type": "string",
          "pattern": "^[0-9]{1,9}$"
        },
        "DATFVI2": {
          "description": "Product end-of-useful-life date (until) / format YYYYMMDD",
          "type": "string",
          "pattern": "^(20|21|22)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "IMMFRG": {
          "description": "Reason for forced immobilization",
          "type": "string",
          "maxLength": 3
        },
        "GEEX5021": {
          "description": "Delivery Order Optional Line Information",
          "$ref": "#/$defs/GEEX5021Wrapper"
        },
        "GEEX5025": {
          "type": "array",
          "description": "Delivery Orders Rubriques Declaration line",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX5025Wrapper"
          }
        }
      },
      "required": ["NLILIV", "CODPRO", "UVCCDE"],
      "additionalProperties": false
    },
    "GEEX5021Wrapper": {
      "description": "Delivery Order Optional Line Information",
      "type": "object",
      "properties": {
        "DIPLIV": {
          "description": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "DS1PRO": {
          "description": "Product designation line 1",
          "type": "string",
          "maxLength": 30
        },
        "DS2PRO": {
          "description": "Product designation line 2",
          "type": "string",
          "maxLength": 30
        },
        "DS3PRO": {
          "description": "Product designation line 3",
          "type": "string",
          "maxLength": 35
        },
        "REFREC": {
          "description": "Receipt reference",
          "type": "string",
          "maxLength": 30
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "CODOPE": {
          "description": "Operation code (Promo or reservation)",
          "type": "string",
          "maxLength": 14
        },
        "TYPDAT": {
          "description": "Date type / false = Imposed, true = Proposed",
          "type": "boolean",
          "default": false
        },
        "CODPPR": {
          "description": "Owner code",
          "type": "string",
          "maxLength": 14
        },
        "CODEMB": {
          "description": "Package handling code",
          "type": "string",
          "maxLength": 3
        }
      },
      "additionalProperties": false     
    },
    "GEEX5025Wrapper": {
      "description": "Delivery Orders Rubriques Declaration line",
      "type": "object",
      "properties": {
        "TYPRUB": {
          "description": "Header type / 1 = EDIFACT standard, 2 = Internal coding",
          "$ref": "#/$defs/Enums/EnumTYPRUB"
        },
        "CODRUB": {
          "description": "Section code",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Traceability element value",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        },
        "SIGMIN": {
          "description": "Minimum value sign / false = Positive value, true = Negative value",
          "type": "boolean",
          "default": false
        },
        "VALMIN": {
          "description": "Minimum value of the imposed item",
          "type": "string",
          "pattern": "^[0-9]{1,13}\\.[0-9]{5}$",
          "examples": ["12.78087"]
        },
        "SIGMAX": {
          "description": "Maximum value sign / false = Positive value, true = Negative value",
          "type": "boolean",
          "default": false
        },
        "VALMAX": {
          "description": "Maximum value of the imposed section",
          "type": "string",
          "pattern": "^[0-9]{1,13}\\.[0-9]{5}$",
          "examples": ["12.78087"]
        },
        "CODPAL": {
          "description": "Stored pallet code according to EAN128 standards",
          "type": "string",
          "maxLength": 18
        }
      },
      "required": ["TYPRUB","CODRUB","VALRUB"],
      "additionalProperties": false
    },
    "GEEX5080Wrapper": {
      "description": "Free text on delivery note",
      "type": "object",
      "properties": {
        "SEQTXL": {
          "description": "Free text sequence number in the delivery note",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "LIBTXL": {
          "description": "Free text label in the delivery note",
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      },
      "required": ["SEQTXL", "LIBTXL"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 7 = Header Modification, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "7", "9"],
        "default": "2"
      },
