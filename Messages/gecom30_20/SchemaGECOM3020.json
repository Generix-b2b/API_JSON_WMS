{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom30_20/SchemaGECOM3020.json",
  "title": "GECOM30 - Product Master Data (EAN)",
  "x-wms-icon": "GECOM30",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m30_ean?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.1",
    "releaseDate": "2026-06-25"
  },
  "description": "JSON for EAN master data load",
  "type": "object",
  "properties": {
    "eanMasterData": {
      "description": "EAN Master Data declaration",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX3020"
			}
    }
  },
  "required": ["eanMasterData"],
  "$defs": {
    "GEEX3020": {
      "description": "Product EAN declaration",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODPRO": {
          "description": "Internal product code",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "DS1PRO": {
          "description": "Product designation line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "EANDS1": {
          "description": "Designation linked to the EAN code",
          "type": "string",
          "maxLength": 30
        },
        "EDIPRM": {
          "description": "Main EDI code identification / false = Secondary code, true = Primary code",
          "type": "boolean"          
        },
        "EDIQLF": {
          "description": "EDI code qualifier - see EnumEDIQLF",
          "$ref": "#/$defs/Enums/EnumEDIQLF"
        },
        "EANVTE": {
          "description": "Sale EAN / false = Not for sale, true = For sale",
          "type": "boolean",
          "default": false
        }
      },
      "required": ["TRTEXC", "CODACT", "CODPRO", "EDIPRO", "EDIPRM", "EDIQLF"],
      "additionalProperties": false
    },
    "Enums": {
      "EnumTRTEXC": {
        "description": "Movement processing code / 1 = Create, 2 = Modify or Create, 9 = Cancellation",
        "type": "string",
        "enum": ["1", "2", "9"],
        "default": "2"
      },
      "EnumMESPRO": {
        "description": "Product measurement method / 1 = Fixed Weight, 2 = Variable Weight, 3 = Regulated Measurement",
        "type": "string",
        "enum": ["1", "2", "3"],
        "default": "1"
      },
      "EnumMODREC": {
        "description": "Receiving mode / 1 = Full Pallet, 2 = Unit",
        "type": "string",
        "enum": ["1", "2"],
        "default": "1"
      },
      "EnumHOMGRB": {
        "description": "Type of sheaf homogeneity (rack or bulk) / 0 = No date uniformity, 1 = Variable per day, 2 = Variable per week, 3 = Variable per decade, 4 = Variable per month, 5 = Single batch",
        "type": "string",
        "enum": ["0", "1", "2", "3", "4", "5"],
        "default": "0"
      },
      "EnumTOPPRN": {
        "description": "Indicator for composite or unit product / 0 = Unit Product, 1 = Bill of Materials",
        "type": "string",
        "enum": ["0", "1"],
        "default": "0"
      },
      "EnumMETRPL": {
        "description": "Product replacement method / 0 = No substitute, 1 = Substituted by..., 2 = Replaced by...",
        "type": "string",
        "enum": ["0", "1", "2"],
        "default": "0"
      },
      "EnumUNIARR": {
        "description": "Upper rounding unit / 1 = Pallet, 2 = Layer, 3 = PCB, 4 = SPCB, 5 = CSU",
        "type": "string",
        "enum": ["1", "2", "3", "4", "5"]
      },
      "EnumUNICAL": {
        "description": "Hazardous materials quantity calculation unit / 1 = Net weight, 2 = Gross weight, 3 = Volume",
        "type": "string",
        "enum": ["1", "2", "3"]
      },
      "EnumEMBCLQ": {
        "description": "LQ packaging type / 1 = Box, 2 = Pallet",
        "type": "string",
        "enum": ["1", "2"]
      },
      "EnumTYPCPS": {
        "description": "Component indicator / 1 = Main, 2 = Secondary",
        "type": "string",
        "enum": ["1", "2"]
      },
      "EnumEDIQLF": {
        "description": "EDI code qualifier / 0 = CSU, 1 = Multi-product batch, 2 = SPCB, 3 = PCB, 4 = Box, 5 = Pallet",
        "type": "string",
        "enum": ["0", "1", "2", "3", "4", "5"]
      },
      "EnumTYPRIC": {
        "description": "Applied regulation / 0 = ICPE only, 1 = SEVESO only, 2 = ICPE and SEVESO, 9 = heading",
        "type": "string",
        "enum": ["0", "1", "2", "9"]
      },
      "EnumTYPRUB": {
        "description": "Section type / 1 = EDIFACT standard, 2 = Internal coding",
        "type": "string",
        "enum": ["1","2"],
        "default": "2"
      }
    }
  }
}
