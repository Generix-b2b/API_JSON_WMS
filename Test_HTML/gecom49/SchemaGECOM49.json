{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/blob/main/SchemaGECOM49.json",
  "title": "GECOM49 - Dispatch Advice",
  "type": "object",
  "description": "JSON schema generated by GENERIX GROUP SP",
  "properties": {
    "dispatchAdvices": {
      "type": "array",
      "description": "Dispatch Advice Header",
      "minItems": 1,
      "maxItems": 999,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "TRTEXC": {
            "type": "string",
            "description": "Movement processing code / 1 = Creation / 2 = Modification / 9 = Cancellation",
            "enum": ["1","2","9"],
            "default": "2"
          },
          "CODFOU": {
            "type": "string",
            "description": "Supplier code",
            "minLength": 1,
            "maxLength": 14
          },
          "AVIREF": {
            "type": "string",
            "description": "Dispatch advice reference",
            "minLength": 1,
            "maxLength": 35
          },
          "CODACT": {
            "type": "string",
            "description": "Logistics activity code",
            "minLength": 3,
            "maxLength": 3
          },
          "REFLET": {
            "type": "string",
            "description": "Waybill number",
            "maxLength": 10
          },
          "EDIFOU": {
            "type": "string",
            "description": "Supplier code for EDI",
            "maxLength": 14
          },
          "EDIACT": {
            "type": "string",
            "description": "Warehouse code for EDI",
            "maxLength": 14
          },
          "EDITRA": {
            "type": "string",
            "description": "Carrier code for EDI",
            "maxLength": 14
          },
          "CODTRA": {
            "type": "string",
            "description": "Carrier code",
            "maxLength": 14
          },
          "DATEXP": {
            "type": "string",
            "description": "Goods dispatch date",
            "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
          },
          "HEUEXP": {
            "type": "string",
            "description": "Goods dispatch time",
            "pattern": "^([01]\\d|2[0-3])([0-5]\\d)([0-5]\\d)$"
          },
          "DATLIV": {
            "type": "string",
            "description": "Order delivery date",
            "pattern": "^(19|20|21)[0-9]{2}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$"
