{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom40/SchemaGECOM40.json",
  "title": "GECOM40 - Reception Orders",
  "title_es": "GECOM40 - Órdenes de recepción",
  "title_en": "GECOM40 - Reception Orders",
  "x-wms-icon": "GECOM40",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m40_reception?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.2",
    "releaseDate": "2026-07-03"
  },
  "description": "JSON for creating a Reception Orders",
  "description_es": "JSON para la creación de órdenes de recepción",
  "description_en": "JSON for creating a Reception Orders",
  "type": "object",
  "properties": {
    "receptionOrders": {
      "description": "Reception Orders Header",
      "description_es": "Cabecera de órdenes de recepción",
      "description_en": "Reception Orders Header",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
        "$ref": "#/$defs/GEEX4000"
      }
    }
  },
  "required": ["receptionOrders"],
  "additionalProperties": false,
  "$defs": {
    "GEEX4000": {
      "description": "Reception Orders Header",
      "description_es": "Cabecera de órdenes de recepción",
      "description_en": "Reception Orders Header",
      "type": "object",
      "properties": {
        "RCTEXC": {
          "description": "Code of exchange recipient",
          "description_es": "Código del destinatario del intercambio",
          "description_en": "Code of exchange recipient",
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "description_es": "Código de procesamiento del movimiento - ver EnumTRTEXC",
          "description_en": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "NUMREC": {
          "description": "Order number to be received",
          "description_es": "Número de orden a recibir",
          "description_en": "Order number to be received",
          "type": "string",
          "pattern": "^[0-9]{1,8}$"
        },
        "SNUREC": {
          "description": "Sub-number of the order to be received",
          "description_es": "Subnúmero de la orden a recibir",
          "description_en": "Sub-number of the order to be received",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "REFREC": {
          "description": "Reception reference",
          "description_es": "Referencia de recepción",
          "description_en": "Reception reference",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "CODAPP": {
          "description": "Buyer/replenisher code",
          "description_es": "Código del comprador/reaprovisionador",
          "description_en": "Buyer/replenisher code",
          "type": "string",
          "maxLength": 10
        },
        "CODLDR": {
          "description": "Reception/shipping location code",
          "description_es": "Código de ubicación de recepción/expedición",
          "description_en": "Reception/shipping location code",
          "type": "string",
          "maxLength": 3
        },
        "CODTRE": {
          "description": "Reception type",
          "description_es": "Tipo de recepción",
          "description_en": "Reception type",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODACT": {
          "description": "Logistics activity code",
          "description_es": "Código de actividad logística",
          "description_en": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODFOU": {
          "description": "Supplier code",
          "description_es": "Código de proveedor",
          "description_en": "Supplier code",
          "type": "string",
          "minLength": 1,
          "maxLength": 14
        },
        "CODTRA": {
          "description": "Carrier code",
          "description_es": "Código de transportista",
          "description_en": "Carrier code",
          "type": "string",
          "maxLength": 14
        },
        "DTIREC": {
          "description": "Initially scheduled reception date (format YYYYMMDD)",
          "description_es": "Fecha de recepción inicialmente programada (formato AAAAMMDD)",
          "description_en": "Initially scheduled reception date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "HEIREC": {
          "description": "Original scheduled reception time (format HHMMSS)",
          "description_es": "Hora de recepción originalmente programada (formato HHMMSS)",
          "description_en": "Original scheduled reception time (format HHMMSS)",
          "type": "string",
          "pattern": "^(0[0-9]|1[0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$",
          "examples": ["143023"]
        },
        "KAIREC": {
          "description": "Goods reception dock",
          "description_es": "Muelle de recepción de mercancías",
          "description_en": "Goods reception dock",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "MSGREC": {
          "description": "Message to be printed on the receipt",
          "description_es": "Mensaje a imprimir en la recepción",
          "description_en": "Message to be printed on the receipt",
          "type": "array",
          "maxItems": 2,
          "items": {
            "description": "Message to be printed on the receipt",
            "description_es": "Mensaje a imprimir en la recepción",
            "description_en": "Message to be printed on the receipt",
            "type": "string",
            "maxLength": 30
          }
        },
        "IGLSIT": {
          "description": "GE site identifier for Infolog GL",
          "description_es": "Identificador de sitio GE para Infolog GL",
          "description_en": "GE site identifier for Infolog GL",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "DTFREC": {
          "description": "Final reception date (format YYYYMMDD)",
          "description_es": "Fecha final de recepción (formato AAAAMMDD)",
          "description_en": "Final reception date (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "EDIFOU": {
          "description": "Supplier code for EDI",
          "description_es": "Código de proveedor para EDI",
          "description_en": "Supplier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "METTRP": {
          "description": "Goods transport method - see EnumMETTRP",
          "description_es": "Método de transporte de mercancías - ver EnumMETTRP",
          "description_en": "Goods transport method - see EnumMETTRP",
          "$ref": "#/$defs/Enums/EnumMETTRP"
        },
        "CODRTN": {
          "description": "Retention code",
          "description_es": "Código de retención",
          "description_en": "Retention code",
          "type": "string",
          "maxLength": 3
        },
        "EDITRA": {
          "description": "Carrier code for EDI",
          "description_es": "Código de transportista para EDI",
          "description_en": "Carrier code for EDI",
          "type": "string",
          "maxLength": 14
        },
        "CODRGT": {
          "description": "Area code for transport",
          "description_es": "Código de zona para transporte",
          "description_en": "Area code for transport",
          "type": "string",
          "maxLength": 3
        },
        "CUMLIG": {
          "description": "Total number of lines in the order",
          "description_es": "Número total de líneas de la orden",
          "description_en": "Total number of lines in the order",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "GEEX4001": {
          "description": "Supplier Information",
          "description_es": "Información del proveedor",
          "description_en": "Supplier Information",
          "$ref": "#/$defs/GEEX4001Wrapper"
        },
        "GEEX4005": {
          "description": "Rubriques Declaration Header",
          "description_es": "Cabecera de declaración de rúbricas",
          "description_en": "Rubriques Declaration Header",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4005Wrapper"
          }
        },
        "GEEX4020": {
          "description": "Reception Orders Declaration Line",
          "description_es": "Línea de declaración de órdenes de recepción",
          "description_en": "Reception Orders Declaration Line",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4020Wrapper"
          }
        },
        "GEEX4080": {
          "description": "Free Text",
          "description_es": "Texto libre",
          "description_en": "Free Text",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4080Wrapper"
          }
        }
      },
      "required": ["RCTEXC", "TRTEXC", "REFREC", "CODTRE", "CODACT", "CODFOU", "DTIREC", "HEIREC", "CUMLIG"],
      "if": {
        "properties": {
          "TRTEXC": { "enum": ["1", "2"] }
        },
        "required": ["TRTEXC"]
      },
      "then": {
        "required": ["GEEX4020"]
      },
      "additionalProperties": false
    },
    "GEEX4001Wrapper": {
      "description": "Supplier Information",
      "description_es": "Información del proveedor",
      "description_en": "Supplier Information",
      "type": "object",
      "properties": {
        "DIPRECH": {
          "description": "Data transit area between software",
          "description_es": "Zona de tránsito de datos entre software",
          "description_en": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "TOPREC": {
          "description": "Indicators for specific users",
          "description_es": "Indicadores para usuarios específicos",
          "description_en": "Indicators for specific users",
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "string",
            "maxLength": 1
          }
        },
        "NOMFOU": {
          "description": "Supplier name",
          "description_es": "Nombre del proveedor",
          "description_en": "Supplier name",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "AD1FOU": {
          "description": "Supplier address line 1",
          "description_es": "Dirección del proveedor línea 1",
          "description_en": "Supplier address line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 38
        },
        "AD2FOU": {
          "description": "Supplier address line 2",
          "description_es": "Dirección del proveedor línea 2",
          "description_en": "Supplier address line 2",
          "type": "string",
          "maxLength": 38
        },
        "AD3FOU": {
          "description": "Supplier address line 3",
          "description_es": "Dirección del proveedor línea 3",
          "description_en": "Supplier address line 3",
          "type": "string",
          "maxLength": 38
        },
        "CPIFOU": {
          "description": "Supplier postal code",
          "description_es": "Código postal del proveedor",
          "description_en": "Supplier postal code",
          "type": "string",
          "minLength": 1,
          "maxLength": 10
        },
        "VILFOU": {
          "description": "Supplier city",
          "description_es": "Ciudad del proveedor",
          "description_en": "Supplier city",
          "type": "string",
          "minLength": 1,
          "maxLength": 26
        },
        "PAYFOU": {
          "description": "Supplier country code",
          "description_es": "Código de país del proveedor",
          "description_en": "Supplier country code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "TELFOU": {
          "description": "Supplier phone number",
          "description_es": "Número de teléfono del proveedor",
          "description_en": "Supplier phone number",
          "type": "string",
          "maxLength": 20
        },
        "TYPFOU": {
          "description": "Supplier type - see EnumTYPFOU",
          "description_es": "Tipo de proveedor - ver EnumTYPFOU",
          "description_en": "Supplier type - see EnumTYPFOU",
          "$ref": "#/$defs/Enums/EnumTYPFOU"
        },
        "CODDDO": {
          "description": "Originator code",
          "description_es": "Código del originador",
          "description_en": "Originator code",
          "type": "string",
          "maxLength": 14
        },
        "CODCLV": {
          "description": "Delivery requirement",
          "description_es": "Requisito de entrega",
          "description_en": "Delivery requirement",
          "type": "string",
          "maxLength": 3
        },
        "CODOWN": {
          "description": "Owner code",
          "description_es": "Código del propietario",
          "description_en": "Owner code",
          "type": "string",
          "maxLength": 14
        }
      },
      "required": ["NOMFOU", "AD1FOU", "CPIFOU", "VILFOU", "PAYFOU"],
      "additionalProperties": false
    },
    "GEEX4005Wrapper": {
      "description": "Rubriques Declaration Header",
      "description_es": "Cabecera de declaración de rúbricas",
      "description_en": "Rubriques Declaration Header",
      "type": "object",
      "properties": {
        "CODRUB": {
          "description": "Section code",
          "description_es": "Código de sección",
          "description_en": "Section code",
          "type": "string",
          "minLength": 1,
          "maxLength": 4
        },
        "VALRUB": {
          "description": "Value of a traceability item",
          "description_es": "Valor de un elemento de trazabilidad",
          "description_en": "Value of a traceability item",
          "type": "string",
          "minLength": 1,
          "maxLength": 35
        }
      },
      "required": ["CODRUB", "VALRUB"],
      "additionalProperties": false
    },
    "GEEX4020Wrapper": {
      "description": "Reception Orders Declaration Line",
      "description_es": "Línea de declaración de órdenes de recepción",
      "description_en": "Reception Orders Declaration Line",
      "type": "object",
      "properties": {
        "NLIREC": {
          "description": "Line number for the reception interface",
          "description_es": "Número de línea para la interfaz de recepción",
          "description_en": "Line number for the reception interface",
          "type": "string",
          "pattern": "^[0-9]{1,5}$"
        },
        "CODCLI": {
          "description": "Customer code of the stock owner",
          "description_es": "Código de cliente del propietario del stock",
          "description_en": "Customer code of the stock owner",
          "type": "string",
          "maxLength": 14
        },
        "CODPRO": {
          "description": "Internal product code",
          "description_es": "Código interno del producto",
          "description_en": "Internal product code",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistic variant (Gencod)",
          "description_es": "Variante logística (Gencod)",
          "description_en": "Logistic variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "UVCREA": {
          "description": "Number of CSU replenished (ordered)",
          "description_es": "Número de UVC reaprovisionadas (pedidas)",
          "description_en": "Number of CSU replenished (ordered)",
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        },
        "UNICDE": {
          "description": "Order quantity entry unit",
          "description_es": "Unidad de introducción de cantidad del pedido",
          "description_en": "Order quantity entry unit",
          "type": "string",
          "maxLength": 3
        },
        "CODPRN": {
          "description": "Product code from a bill of materials (Same as PRODN)",
          "description_es": "Código de producto de una lista de materiales (igual que PRODN)",
          "description_en": "Product code from a bill of materials (Same as PRODN)",
          "type": "string",
          "maxLength": 17
        },
        "TYPOPE": {
          "description": "Operation type (e.g., Promotion, reservation) - see EnumTYPOPE",
          "description_es": "Tipo de operación (p. ej., promoción, reserva) - ver EnumTYPOPE",
          "description_en": "Operation type (e.g., Promotion, reservation) - see EnumTYPOPE",
          "$ref": "#/$defs/Enums/EnumTYPOPE"
        },
        "NUMOPE": {
          "description": "Operation number (Promo or reservation)",
          "description_es": "Número de operación (promoción o reserva)",
          "description_en": "Operation number (Promo or reservation)",
          "type": "string",
          "pattern": "^[0-9]{1,6}$"
        },
        "AIGPRI": {
          "description": "Switch for PVC marking control / false = Unmarked Product, true = Marked Product",
          "description_es": "Conmutador para el control de marcado de precio (PVC) / false = Producto sin marcar, true = Producto marcado",
          "description_en": "Switch for PVC marking control / false = Unmarked Product, true = Marked Product",
          "type": "boolean",
          "default": false
        },
        "PRIREC": {
          "description": "Price marked on the product to be checked",
          "description_es": "Precio marcado en el producto a comprobar",
          "description_en": "Price marked on the product to be checked",
          "type": "string",
          "pattern": "^[0-9]{1,6}\\.[0-9]{3}$",
          "examples": ["10.500"]
        },
        "MSGLIG": {
          "description": "Line-by-line message (Same as MESLL)",
          "description_es": "Mensaje línea por línea (igual que MESLL)",
          "description_en": "Line-by-line message (Same as MESLL)",
          "type": "string",
          "maxLength": 30
        },
        "MOTIMM": {
          "description": "Reason for immobilization",
          "description_es": "Motivo de inmovilización",
          "description_en": "Reason for immobilization",
          "type": "string",
          "maxLength": 3
        },
        "CODLOT": {
          "description": "Stored batch code",
          "description_es": "Código de lote almacenado",
          "description_en": "Stored batch code",
          "type": "string",
          "maxLength": 20
        },
        "DATFAB": {
          "description": "Manufacturing start and end dates (format YYYYMMDD)",
          "description_es": "Fechas de inicio y fin de fabricación (formato AAAAMMDD)",
          "description_en": "Manufacturing start and end dates (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "SPCPRO": {
          "description": "Sub-package quantity of the product",
          "description_es": "Cantidad de subembalaje del producto",
          "description_en": "Sub-package quantity of the product",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Package quantity of the product",
          "description_es": "Cantidad de embalaje del producto",
          "description_en": "Package quantity of the product",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "PDBCOL": {
          "description": "Gross weight of the package in Kg",
          "description_es": "Peso bruto del paquete en kg",
          "description_en": "Gross weight of the package in Kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "VOLCOL": {
          "description": "Package volume expressed in dm3",
          "description_es": "Volumen del paquete expresado en dm3",
          "description_en": "Package volume expressed in dm3",
          "type": "string",
          "pattern": "^[0-9]{1,4}\\.[0-9]{3}$",
          "examples": ["0.780"]
        },
        "COLCOU": {
          "description": "Number of packages per layer",
          "description_es": "Número de paquetes por capa",
          "description_en": "Number of packages per layer",
          "type": "integer",
          "minimum": 1,
          "maximum": 9999
        },
        "COUPAL": {
          "description": "Number of layers per pallet",
          "description_es": "Número de capas por palé",
          "description_en": "Number of layers per pallet",
          "type": "integer",
          "minimum": 1,
          "maximum": 9999
        },
        "CODEMB": {
          "description": "Package code handling",
          "description_es": "Gestión del código de paquete",
          "description_en": "Package code handling",
          "type": "string",
          "maxLength": 3
        },
        "GERPAL": {
          "description": "Number of pallet stackings in storage",
          "description_es": "Número de pilas de palés en almacenamiento",
          "description_en": "Number of pallet stackings in storage",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "GERHAU": {
          "description": "Number of pallets stacked high",
          "description_es": "Número de palés apilados en altura",
          "description_en": "Number of pallets stacked high",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "CODMDR": {
          "description": "Goods reception method.",
          "description_es": "Método de recepción de mercancías.",
          "description_en": "Goods reception method.",
          "type": "string",
          "maxLength": 3
        },
        "INDUNI": {
          "description": "Unit processing indicator / false = UNICDE not used, true = UNICDE used",
          "description_es": "Indicador de procesamiento por unidad / false = UNICDE no utilizado, true = UNICDE utilizado",
          "description_en": "Unit processing indicator / false = UNICDE not used, true = UNICDE used",
          "type": "boolean",
          "default": false
        },
        "GEEX4021": {
          "description": "Reception Orders Declaration Additional Line",
          "description_es": "Línea adicional de declaración de órdenes de recepción",
          "description_en": "Reception Orders Declaration Additional Line",
          "$ref": "#/$defs/GEEX4021Wrapper"
        },
        "GEEX4025": {
          "description": "Reception Orders rubriques line declaration",
          "description_es": "Declaración de línea de rúbricas de órdenes de recepción",
          "description_en": "Reception Orders rubriques line declaration",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4025Wrapper"
          }
        },
        "GEEX4030": {
          "description": "Reception Orders Pallets line declaration",
          "description_es": "Declaración de línea de palés de órdenes de recepción",
          "description_en": "Reception Orders Pallets line declaration",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX4030Wrapper"
          }
        }
      },
      "required": ["NLIREC", "CODPRO", "UVCREA"],
      "additionalProperties": false
    },
    "GEEX4021Wrapper": {
      "description": "Reception Orders Declaration Additional Line",
      "description_es": "Línea adicional de declaración de órdenes de recepción",
      "description_en": "Reception Orders Declaration Additional Line",
      "type": "object",
      "properties": {
        "DIPRECL": {
          "description": "Data transit area between software",
          "description_es": "Zona de tránsito de datos entre software",
          "description_en": "Data transit area between software",
          "type": "string",
          "maxLength": 50
        },
        "PRXPRO": {
          "description": "Product price",
          "description_es": "Precio del producto",
          "description_en": "Product price",
          "type": "string",
          "pattern": "^[0-9]{1,6}\\.[0-9]{3}$",
          "examples": ["10.500"]
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "description_es": "Código de producto para EDI",
