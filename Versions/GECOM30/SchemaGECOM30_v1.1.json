{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Generix-b2b/API_JSON_WMS/raw/main/Messages/gecom30/SchemaGECOM30.json",
  "title": "GECOM30 - Product Master Data",
  "x-wms-icon": "GECOM30",
  "x-wms-author": "GENERIX Group Spain",
  "x-wms-endpoint": {
    "method": "POST",
    "path": "https://[URL_Client_Environment].generix.biz/m30_product?uuid=[Value]",
    "category": "Inbound",
    "version": "v1.1",
    "releaseDate": "2026-06-22"
  },
  "description": "JSON for product master data load",
  "type": "object",
  "properties": {
    "productMasterData": {
      "description": "Master Data declaration",
      "type": "array",
      "minItems": 1,
      "maxItems": 499,
      "items": {
				"$ref": "#/$defs/GEEX3000"
			}
    }
  },
  "required": ["productMasterData"],
  "$defs": {
    "GEEX3000": {
      "description": "Master Data declaration",
      "type": "object",
      "properties": {
        "TRTEXC": {
          "description": "Movement processing code - see EnumTRTEXC",
          "$ref": "#/$defs/Enums/EnumTRTEXC"
        },
        "CODACT": {
          "description": "Logistics activity code",
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "CODPRO": {
          "description": "Internal product code",
          "type": "string",
          "minLength": 1,
          "maxLength": 17
        },
        "VALPRO": {
          "description": "Logistics variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "DS1PRO": {
          "description": "Product designation line 1",
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "DS2PRO": {
          "description": "Product designation line 2",
          "type": "string",
          "maxLength": 30
        },
        "FOUPRO": {
          "description": "Product supplier code",
          "type": "string",
          "maxLength": 14
        },
        "VAPPRO": {
          "description": "Supply variant (Gencod)",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "FAMPRO": {
          "description": "Product classification family",
          "type": "string",
          "maxLength": 10
        },
        "ANAPRO": {
          "description": "Product analysis code",
          "type": "string",
          "maxLength": 15
        },
        "EDIPRO": {
          "description": "Product code for EDI",
          "type": "string",
          "maxLength": 17
        },
        "SPCPRO": {
          "description": "Product sub-pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 9999
        },
        "PCBPRO": {
          "description": "Product pack quantity",
          "type": "integer",
          "minimum": 0,
          "maximum": 99999
        },
        "UNIPRO": {
          "description": "Product unit of measure",
          "type": "string",
          "maxLength": 3
        },
        "MESPRO": {
          "description": "Product measurement method - see EnumMESPRO",
          "$ref": "#/$defs/Enums/EnumMESPRO"
        },
        "PDBUVC": {
          "description": "CSU gross weight in kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "PDNUVC": {
          "description": "CSU net weight in kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "HAUUVC": {
          "description": "CSU height expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LNGUVC": {
          "description": "CSU length expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LRGUVC": {
          "description": "CSU width expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "PDBCOL": {
          "description": "Package gross weight in kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "HAUCOL": {
          "description": "Package height expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LNGCOL": {
          "description": "Package length expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LRGCOL": {
          "description": "Package width expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "COLCOU": {
          "description": "Number of packages per layer",
          "type": "integer",
          "minimum": 1,
          "maximum": 9999
        },
        "COUPAL": {
          "description": "Number of layers per pallet",
          "type": "integer",
          "minimum": 1,
          "maximum": 9999
        },
        "GERPAL": {
          "description": "Number of pallet stacks in storage",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "GERHAU": {
          "description": "Number of pallets stacked high",
          "type": "string",
          "pattern": "^[0-9]{1,2}$"
        },
        "HAUCOU": {
          "description": "Layer height expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "CODEMB": {
          "description": "Package code handling",
          "type": "string",
          "maxLength": 3
        },
        "ABCPRO": {
          "description": "ABC product rotation class",
          "type": "string",
          "maxLength": 1
        },
        "CODMDR": {
          "description": "Goods receipt method",
          "type": "string",
          "maxLength": 3
        },
        "MODREC": {
          "description": "Receiving mode - see EnumMODREC",
          "$ref": "#/$defs/Enums/EnumMODREC"
        },
        "NBJDLV": {
          "description": "Number of DLV days",
          "type": "string",
          "maxLength": 3
        },
        "MOTIMM": {
          "description": "Immobilization reason",
          "type": "string",
          "maxLength": 3
        },
        "CODMDS": {
          "description": "Storage method code",
          "type": "string",
          "maxLength": 3
        },
        "ZONPRF": {
          "description": "Preferred storage area",
          "type": "string",
          "maxLength": 1
        },
        "ALLPRF": {
          "description": "Preferred storage aisle",
          "type": "string",
          "pattern": "^[0-9]{1,3}$"
        },
        "ABCSTS": {
          "description": "Storage class",
          "type": "string",
          "maxLength": 1
        },
        "CODADM": {
          "description": "Sheaf storage method",
          "type": "string",
          "maxLength": 3
        },
        "HOMGRB": {
          "description": "Type of sheaf homogeneity (rack or bulk) - see EnumHOMGRB",
          "$ref": "#/$defs/Enums/EnumHOMGRB"
        },
        "PERGRB": {
          "description": "Pattern homogeneity period (rack/bulk)",
          "type": "string",
          "maxLength": 3
        },
        "CODMDP": {
          "description": "Preparation process method",
          "type": "string",
          "maxLength": 3
        },
        "TOPPRN": {
          "description": "Indicator for composite or unit product - see EnumTOPPRN",
          "$ref": "#/$defs/Enums/EnumTOPPRN"
        },
        "ORIMAJ": {
          "description": "Update origin",
          "type": "string",
          "maxLength": 1
        },
        "TOPPRO": {
          "description": "Product indicator",
          "type": "string",
          "maxLength": 1
        },
        "GEEX3001": {
          "description": "Product Additional 01 declaration",
          "$ref": "#/$defs/GEEX3001Wrapper"
        },
        "GEEX3002": {
          "description": "Product Additional 02 declaration",
          "$ref": "#/$defs/GEEX3002Wrapper"
        },
        "GEEX3003": {
          "description": "Product Additional 03 declaration",
          "$ref": "#/$defs/GEEX3003Wrapper"
        },
        "GEEX3004": {
          "description": "Product Additional 04 declaration",
          "$ref": "#/$defs/GEEX3004Wrapper"
        },
        "GEEX3010": {
          "description": "Product components declaration",
          "type": "array",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX3010Wrapper"
          }
        },
        "GEEX3020": {
          "description": "Product EAN declaration",
          "type": "array",
          "maxItems": 49,
          "items": {
            "$ref": "#/$defs/GEEX3020Wrapper"
          }
        },
        "GEEX3030": {
          "type": "array",
          "description": "Product multi-language declaration",
          "maxItems": 49,
          "items": {
            "$ref": "#/$defs/GEEX3030Wrapper"
          }
        },
        "GEEX3040": {
          "type": "array",
          "description": "Product ICPE declaration",
          "maxItems": 49,
          "items": {
            "$ref": "#/$defs/GEEX3040Wrapper"
          }
        },
        "GEEX3050": {
          "type": "array",
          "description": "Product rubriques declaration",
          "maxItems": 99,
          "items": {
            "$ref": "#/$defs/GEEX3050Wrapper"
          }
        },
        "GEEX3060": {
          "type": "array",
          "description": "Product Satellite declaration",
          "maxItems": 49,
          "items": {
            "$ref": "#/$defs/GEEX3060Wrapper"
          }
        },
        "GEEX3080": {
          "type": "array",
          "description": "Product replacement declaration",
          "maxItems": 49,
          "items": {
            "$ref": "#/$defs/GEEX3080Wrapper"
          }
        }
      },
      "required": ["TRTEXC", "CODACT", "CODPRO", "DS1PRO"],
      "additionalProperties": false
    },
    "GEEX3001Wrapper": {
      "description": "Product Additional 01 declaration",
      "type": "object",
      "properties": {
        "INDPRO": {
          "description": "Configurable product indicators",
          "type": "array",
          "maxItems": 10,
          "items": {
            "description": "Configurable product indicators",
            "type": "string",
            "maxLength": 1
          }
        },
        "CODMRQ": {
          "description": "Manufacturer brand code",
          "type": "string",
          "maxLength": 8
        },
        "DESFOU": {
          "description": "Product designation at the supplier",
          "type": "string",
          "maxLength": 30
        },
        "CIRDET": {
          "description": "Detail picking preparation circuit",
          "type": "string",
          "maxLength": 3
        },
        "CIRPAL": {
          "description": "Full pallet preparation circuit",
          "type": "string",
          "maxLength": 3
        },
        "METRPL": {
          "description": "Product replacement method - see EnumMETRPL",
          "$ref": "#/$defs/Enums/EnumMETRPL"
        },
        "CODRPL": {
          "description": "Replacement product code",
          "type": "string",
          "maxLength": 17
        },
        "VALRPL": {
          "description": "Logistics variant of the substitute product",
          "type": "string",
          "maxLength": 2
        },
        "CODALC": {
          "description": "Liquor seal code",
          "type": "string",
          "maxLength": 4
        },
        "DEGALC": {
          "description": "Pure alcohol degree",
          "type": "string",
          "pattern": "^[0-9]{1,3}\\.[0-9]{2}$",
          "examples": ["12.50"]
        },
        "VOLALC": {
          "description": "Beverage volume for liquor management",
          "type": "string",
          "pattern": "^[0-9]{1,3}\\.[0-9]{3}$",
          "examples": ["0.750"]
        },
        "CODMDG": {
          "description": "Service management method code",
          "type": "string",
          "maxLength": 3
        },
        "TAUPST": {
          "description": "Profit rate",
          "type": "array",
          "maxItems": 4,
          "items": {
            "description": "Profit rate",
            "type": "string",
            "pattern": "^[0-9]{1,3}\\.[0-9]{2}$",
            "examples": ["15.00"]
          }
        },
        "COELOG": {
          "description": "Logistics coefficient",
          "type": "string",
          "pattern": "^[0-9]{1,2}\\.[0-9]{3}$",
          "examples": ["1.000"]
        },
        "PRXPRO": {
          "description": "Product price",
          "type": "array",
          "maxItems": 4,
          "items": {
            "description": "Product price",
            "type": "string",
            "pattern": "^[0-9]{1,6}\\.[0-9]{3}$",
            "examples": ["10.500"]
          }
        },
        "CODMDI": {
          "description": "Cycle counting method",
          "type": "string",
          "maxLength": 3
        },
        "NXTIVT": {
          "description": "Date of next product inventory (format YYYYMMDD)",
          "type": "string",
          "pattern": "^[1-9][0-9]{3}(0[1-9]|1[0-2])(0[1-9]|[12][0-9]|3[01])$",
          "examples": ["20250125"]
        },
        "SECSTK": {
          "description": "Safety stock in CSU",
          "type": "string",
          "maxLength": 9
        },
        "CODMDF": {
          "description": "Manufacturing process method",
          "type": "string",
          "maxLength": 3
        },
        "FMTFAB": {
          "description": "Product manufacturing format",
          "type": "string",
          "maxLength": 5
        },
        "ACTFAB": {
          "description": "Activity after manufacturing process",
          "type": "string",
          "maxLength": 3
        },
        "CODFAB": {
          "description": "Product code after manufacturing",
          "type": "string",
          "maxLength": 17
        },
        "VRAFAB": {
          "description": "Manufactured product code (For statistics)",
          "type": "string",
          "maxLength": 17
        },
        "VALFAB": {
          "description": "Logistics variant (Gencod) of manufacturing",
          "type": "string",
          "maxLength": 2
        },
        "CODZVI": {
          "description": "Wine production area code",
          "type": "string",
          "maxLength": 4
        },
        "CODEAP": {
          "description": "Packaging code associated with the product",
          "type": "string",
          "maxLength": 3
        },
        "TOPCNA": {
          "description": "Products with alcohol rate for the CNAMTS / false = not subject to tax , true = Subject to tax ",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "GEEX3002Wrapper": {
      "description": "Product Additional 02 declaration",
      "type": "object",
      "properties": {
        "CODTMD": {
          "description": "Dangerous goods transport code",
          "type": "string",
          "maxLength": 4
        },
        "CODSEC": {
          "description": "Safety code (Hazardous Materials)",
          "type": "string",
          "maxLength": 4
        },
        "CODSPE": {
          "description": "Returnable product / false = Non-returnable, true = Returnable",
          "type": "boolean",
          "default": false
        },
        "UNIFAC": {
          "description": "Billing unit",
          "type": "string",
          "maxLength": 3
        },
        "COEFAC": {
          "description": "Billing coefficient",
          "type": "string",
          "pattern": "^[0-9]{1,7}\\.[0-9]{3}$",
          "examples": ["1.000"]
        },
        "SECDLV": {
          "description": "Number of safety days in addition to DLV",
          "type": "string",
          "maxLength": 3
        },
        "CODRGP": {
          "description": "Product grouping code",
          "type": "string",
          "maxLength": 17
        },
        "CODRSC": {
          "description": "Product hazard type code",
          "type": "string",
          "maxLength": 3
        },
        "PROEAP": {
          "description": "Associated packaging code for the interface",
          "type": "string",
          "maxLength": 17
        },
        "VTLPRO": {
          "description": "Indicator for product to be broken down",
          "type": "string",
          "maxLength": 1
        },
        "CIRVTL": {
          "description": "Breakdown circuit code",
          "type": "string",
          "maxLength": 3
        },
        "INFEXP": {
          "description": "Inventory number (Alcohol Customs)",
          "type": "string",
          "maxLength": 16
        },
        "CODMTR": {
          "description": "Materials accounting",
          "type": "string",
          "maxLength": 5
        },
        "TEMPRE": {
          "description": "Recommended temperature for the product",
          "type": "string",
          "maxLength": 3
        },
        "QTELOT": {
          "description": "Quantity for batch size management",
          "type": "string",
          "maxLength": 9
        },
        "UNILOT": {
          "description": "Unit for batch size management",
          "type": "string",
          "maxLength": 3
        },
        "UNIARR": {
          "description": "Upper rounding unit - see EnumUNIARR",
          "$ref": "#/$defs/Enums/EnumUNIARR"
        },
        "UNICAL": {
          "description": "Hazardous materials quantity calculation unit - see EnumUNICAL",
          "$ref": "#/$defs/Enums/EnumUNICAL"
        },
        "TEMMIN": {
          "description": "Minimum temperature",
          "type": "string",
          "maxLength": 3
        },
        "TEMMAX": {
          "description": "Maximum temperature",
          "type": "string",
          "maxLength": 3
        },
        "TOLPOI": {
          "description": "Package weight deviation tolerance",
          "type": "string",
          "maxLength": 3
        },
        "COECOL": {
          "description": "Package expansion coefficient",
          "type": "string",
          "pattern": "^[0-9]{1}\\.[0-9]{3}$",
          "examples": ["1.000"]
        },
        "COESPC": {
          "description": "SPCB expansion coefficient",
          "type": "string",
          "pattern": "^[0-9]{1}\\.[0-9]{3}$",
          "examples": ["1.000"]
        },
        "COEUVC": {
          "description": "CSU expansion coefficient",
          "type": "string",
          "pattern": "^[0-9]{1}\\.[0-9]{3}$",
          "examples": ["1.000"]
        },
        "INDTOL": {
          "description": "Weight tolerance indicator / false = No tolerance, true = Tolerance",
          "type": "boolean",
          "default": false
        },
        "HAUSPC": {
          "description": "SPCB height",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LNGSPC": {
          "description": "SPCB length expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "LRGSPC": {
          "description": "SPCB width expressed in cm",
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "PDBSPC": {
          "description": "SPCB gross weight in kg",
          "type": "number",
          "minimum": 0,
          "maximum": 9999.999,
          "multipleOf": 0.001
        },
        "CODMDT": {
          "description": "Traceability method code",
          "type": "string",
          "maxLength": 3
        },
        "ETIMTR": {
          "description": "Materials labeling code",
          "type": "string",
          "maxLength": 3
        },
        "CODPHR": {
          "description": "Risk phrase code",
          "type": "string",
          "maxLength": 3
        },
        "NBJFVI": {
          "description": "Product shelf life",
          "type": "string",
          "maxLength": 4
        },
        "CODGAM": {
          "description": "Operation range code",
          "type": "string",
          "maxLength": 10
        },
        "CODQLP": {
          "description": "Product qualifier code",
          "type": "string",
          "maxLength": 3
        },
        "EMBCLQ": {
          "description": "LQ packaging type - see EnumEMBCLQ",
          "$ref": "#/$defs/Enums/EnumEMBCLQ"
        },
        "CTRPRP": {
          "description": "Quantity control during preparation / false = Non-systematic, true = Systematic",
          "type": "boolean",
          "default": false
        },
        "CODRDS": {
          "description": "Storage restriction code",
          "type": "string",
          "maxLength": 3
        },
        "HAUCOL2": {
          "description": "Package height expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "HAUCOU2": {
          "description": "Layer height expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "HAUSPC2": {
          "description": "SPCB height in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "HAUUVC2": {
          "description": "CSU height expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LNGCOL2": {
          "description": "Package length expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LNGSPC2": {
          "description": "SPCB length expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LNGUVC2": {
          "description": "CSU length expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LRGCOL2": {
          "description": "Package width expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LRGSPC2": {
          "description": "SPCB width expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "LRGUVC2": {
          "description": "CSU width expressed in cm",
          "type": "number",
          "minimum": 0,
          "maximum": 999.99,
          "multipleOf": 0.01
        },
        "CODMNN": {
          "description": "Handling rule code",
          "type": "string",
          "maxLength": 3
        }
      },
      "additionalProperties": false
    },
    "GEEX3003Wrapper": {
      "description": "Product Additional 03 declaration",
      "type": "object",
      "properties": {
        "CODCVI": {
          "description": "Wine color code",
          "type": "string",
          "maxLength": 10
        },
        "NBJIMM": {
          "description": "Number of immobilization days",
          "type": "string",
          "maxLength": 3
        },
        "NBHIMM": {
          "description": "Number of immobilization hours",
          "type": "string",
          "maxLength": 3
        },
        "IMMLOT": {
          "description": "Immobilization reason applicable to a batch",
          "type": "string",
          "maxLength": 3
        },
        "EMBUVC": {
          "description": "CSU packaging code",
          "type": "string",
          "maxLength": 3
        },
        "CODMTI": {
          "description": "Commercial code",
          "type": "string",
          "maxLength": 3
        },
        "CODOWN": {
          "description": "Owner code",
          "type": "string",
          "maxLength": 14
        },
        "DS3PRO": {
          "description": "Product designation line 3",
          "type": "string",
          "maxLength": 35
        },
        "CODRSQ": {
          "description": "Risk typology code",
          "type": "string",
          "maxLength": 3
        },
        "INDTEM": {
          "description": "Flash point: product ignition temperature.",
          "type": "string",
          "pattern": "^[0-9]{1,4}$"
        },
        "SENTEM": {
          "description": "Flash point direction",
          "type": "string",
          "maxLength": 1
        },
        "CODITC": {
          "description": "Interlayer packaging",
          "type": "string",
          "maxLength": 3
        },
        "QTEITC": {
          "description": "Quantity for the pallet standard",
          "type": "string",
          "maxLength": 2
        },
        "CODFCQ": {
          "description": "Quality control sheet code",
          "type": "string",
          "maxLength": 3
        }
      },
      "additionalProperties": false
    },
    "GEEX3004Wrapper": {
      "description": "Product Additional 04 declaration",
      "type": "object",
      "properties": {
        "CODCMM": {
